#!/usr/bin/env bash
# ============================================================================
# Athena平台 - Pre-push Hook
# 推送前执行完整质量检查
#
# 安装: make install-hooks
# 卸载: make uninstall-hooks
# 跳过: git push --no-verify
# ============================================================================

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 项目根目录
PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$PROJECT_ROOT"

echo -e "${BLUE}═══════════════════════════════════════════════════════${NC}"
echo -e "${BLUE}  🚀 Athena Pre-push 检查${NC}"
echo -e "${BLUE}═══════════════════════════════════════════════════════${NC}"
echo ""

# 获取当前分支
CURRENT_BRANCH=$(git branch --show-current)
echo -e "当前分支: ${YELLOW}$CURRENT_BRANCH${NC}"
echo ""

# 检查是否推送main分支
if [ "$CURRENT_BRANCH" = "main" ]; then
    echo -e "${YELLOW}⚠️  警告: 直接推送到main分支${NC}"
    echo -e "   建议使用PR流程: ${YELLOW}gh pr create${NC}"
    echo ""
fi

# 错误计数
ERRORS=0

# ==================== 完整认证检查 ====================
echo -e "${BLUE}[1/3]${NC} 完整Agent认证..."

if [ -f "tools/agent_certifier.py" ]; then
    echo -e "${BLUE}   运行完整认证（含性能检查）...${NC}"

    if python3 tools/agent_certifier.py --all --report reports/certification_report.json >/dev/null 2>&1; then
        # 检查认证结果
        FAILED_COUNT=$(python3 -c "
import json
with open('reports/certification_report.json') as f:
    data = json.load(f)
failed = sum(1 for a in data.get('agents', []) if a.get('status') == 'failed')
print(failed)
" 2>/dev/null || echo "0")

        if [ "$FAILED_COUNT" -gt "0" ]; then
            echo -e "${RED}❌ 有 $FAILED_COUNT 个Agent认证失败${NC}"
            echo -e "   运行: ${YELLOW}make certify${NC} 查看详情"
            ERRORS=$((ERRORS + 1))
        else
            echo -e "${GREEN}✅${NC} Agent认证通过"
        fi
    else
        echo -e "${RED}❌ Agent认证执行失败${NC}"
        ERRORS=$((ERRORS + 1))
    fi
else
    echo -e "${YELLOW}⚠️  认证工具不存在，跳过${NC}"
fi

# ==================== 完整测试套件 ====================
echo -e "${BLUE}[2/3]${NC} 完整测试套件..."

if command -v pytest &> /dev/null; then
    echo -e "${BLUE}   运行单元测试和集成测试...${NC}"

    if pytest tests/ -v -m "unit or integration" --tb=short -q 2>&1 | tee /tmp/pytest_output.txt; then
        echo -e "${GREEN}✅${NC} 测试套件通过"
    else
        echo -e "${RED}❌ 测试套件失败${NC}"
        ERRORS=$((ERRORS + 1))
    fi
else
    echo -e "${YELLOW}⚠️  pytest未安装，跳过测试${NC}"
fi

# ==================== 代码质量检查 ====================
echo -e "${BLUE}[3/3]${NC} 代码质量检查..."

if command -v ruff &> /dev/null; then
    if ruff check . && ruff format --check .; then
        echo -e "${GREEN}✅${NC} 代码质量检查通过"
    else
        echo -e "${RED}❌ 代码质量检查失败${NC}"
        echo -e "   运行: ${YELLOW}make lint-fix${NC} 修复问题"
        ERRORS=$((ERRORS + 1))
    fi
else
    echo -e "${YELLOW}⚠️  ruff未安装，跳过${NC}"
fi

# ==================== 汇总结果 ====================
echo ""
echo -e "${BLUE}═══════════════════════════════════════════════════════${NC}"

if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✅ 所有检查通过！可以推送。${NC}"
    exit 0
else
    echo -e "${RED}❌ 发现 $ERRORS 个错误，请修复后重试${NC}"
    echo -e "   跳过检查: ${YELLOW}git push --no-verify${NC}"
    exit 1
fi
