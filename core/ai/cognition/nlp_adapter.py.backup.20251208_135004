#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
NLP适配器 - 连接认知引擎与各种NLP服务
NLP Adapter - Connects cognition engine with various NLP services
"""

import logging
from typing import Dict, Any, Optional
from datetime import datetime

logger = logging.getLogger(__name__)

class NLPAdapter:
    """NLP适配器 - 为认知引擎提供统一的NLP接口"""

    def __init__(self, config: Optional[Dict[str, Any]] = None):
        self.config = config or {}
        self.nlp_service = None
        self.initialized = False

    async def initialize(self):
        """初始化NLP适配器"""
        try:
            # 尝试导入并初始化通用NLP服务
            import sys
            import os
            sys.path.append(os.path.dirname(os.path.dirname(__file__)))
            from nlp.universal_nlp_provider import get_nlp_service
            self.nlp_service = await get_nlp_service(self.config)
            self.initialized = True
            logger.info("✅ NLP适配器初始化成功 - 使用通用NLP服务")
        except Exception as e:
            logger.warning(f"通用NLP服务不可用: {e}")
            self.nlp_service = None
            self.initialized = False

    async def analyze_patent(self, text: str) -> Dict[str, Any]:
        """专利分析"""
        if self.nlp_service:
            try:
                # 使用通用NLP服务的process方法
                from nlp.universal_nlp_provider import TaskType
                result = await self.nlp_service.process(text, TaskType.PATENT_ANALYSIS)
                return result
            except Exception as e:
                logger.error(f"NLP专利分析失败: {e}")

        # 降级处理
        return {
            "success": False,
            "analysis": f"专利文本（长度：{len(text)}字符）需要人工分析",
            "key_points": ["技术方案", "创新点", "保护范围"],
            "confidence": 0.5
        }

    async def technical_reasoning(self, text: str, context: str = "") -> Dict[str, Any]:
        """技术推理"""
        if self.nlp_service:
            try:
                # 使用通用NLP服务的process方法
                from nlp.universal_nlp_provider import TaskType
                full_text = f"{context}\n\n{text}" if context else text
                result = await self.nlp_service.process(full_text, TaskType.TECHNICAL_REASONING)
                return result
            except Exception as e:
                logger.error(f"NLP技术推理失败: {e}")

        # 降级处理
        return {
            "success": False,
            "reasoning": f"基于文本的技术推理（长度：{len(text)}字符）",
            "conclusions": ["需要进一步分析"],
            "confidence": 0.4
        }

    async def emotional_analysis(self, text: str) -> Dict[str, Any]:
        """情感分析"""
        if self.nlp_service:
            try:
                # 使用通用NLP服务的process方法
                from nlp.universal_nlp_provider import TaskType
                result = await self.nlp_service.process(text, TaskType.EMOTIONAL_ANALYSIS)
                return result
            except Exception as e:
                logger.error(f"NLP情感分析失败: {e}")

        # 降级到基础关键词分析
        positive_words = ["开心", "高兴", "好", "棒", "成功", "满意"]
        negative_words = ["难过", "伤心", "不好", "失败", "问题", "错误"]

        pos_count = sum(1 for word in positive_words if word in text)
        neg_count = sum(1 for word in negative_words if word in text)

        if pos_count > neg_count:
            emotion = "positive"
            intensity = min(0.8, 0.5 + pos_count * 0.1)
        elif neg_count > pos_count:
            emotion = "negative"
            intensity = min(0.8, 0.5 + neg_count * 0.1)
        else:
            emotion = "neutral"
            intensity = 0.5

        return {
            "success": True,
            "primary_emotion": emotion,
            "emotion_intensity": intensity,
            "confidence": 0.6,
            "method": "keyword_based"
        }

    async def conversation_response(self, text: str, context: Dict = None) -> Dict[str, Any]:
        """对话响应"""
        if self.nlp_service:
            try:
                # 使用通用NLP服务的process方法
                from nlp.universal_nlp_provider import TaskType
                result = await self.nlp_service.process(text, TaskType.CONVERSATION, context=context or {})
                return result
            except Exception as e:
                logger.error(f"NLP对话响应失败: {e}")

        # 降级处理
        if "爸爸" in text:
            response = "爸爸，我在这里！有什么需要小诺帮助的吗？💖"
        elif "你好" in text or "hi" in text.lower():
            response = "你好！很高兴见到你！😊"
        else:
            response = f"我收到了你的消息：{text[:50]}..."

        return {
            "success": True,
            "response": response,
            "confidence": 0.7,
            "method": "rule_based"
        }

    async def creative_writing(self, text: str, style: str = "story") -> Dict[str, Any]:
        """创意写作"""
        if self.nlp_service:
            try:
                # 使用通用NLP服务的process方法
                from nlp.universal_nlp_provider import TaskType
                result = await self.nlp_service.process(f"风格：{style}\n主题：{text}", TaskType.CREATIVE_WRITING, style=style)
                return result
            except Exception as e:
                logger.error(f"NLP创意写作失败: {e}")

        # 降级处理
        if style == "story":
            response = f"从前，{text}发生了一个有趣的故事..."
        elif style == "poem":
            response = f"{text}\n如诗如画，\n美好时光。"
        else:
            response = f"关于'{text}'的创意表达：这是一个充满想象力的主题。"

        return {
            "success": True,
            "content": response,
            "style": style,
            "confidence": 0.5,
            "method": "template_based"
        }

    async def health_check(self) -> Dict[str, Any]:
        """健康检查"""
        if not self.initialized:
            return {
                "status": "not_initialized",
                "service_available": False,
                "message": "NLP适配器未初始化"
            }

        if self.nlp_service:
            try:
                status = await self.nlp_service.get_provider_status()
                return {
                    "status": "healthy" if status["available_providers"] else "degraded",
                    "service_available": len(status["available_providers"]) > 0,
                    "providers": status
                }
            except Exception as e:
                return {
                    "status": "error",
                    "service_available": False,
                    "error": str(e)
                }

        return {
            "status": "no_service",
            "service_available": False,
            "message": "没有可用的NLP服务"
        }

# 兼容Ollama接口的包装器
class OllamaNLPWrapper:
    """Ollama NLP接口包装器 - 让通用NLP服务兼容Ollama接口"""

    def __init__(self, universal_nlp_service):
        self.universal_nlp = universal_nlp_service

    async def analyze_patent(self, text: str) -> Dict[str, Any]:
        """专利分析（兼容Ollama接口）"""
        from ..nlp.universal_nlp_provider import TaskType
        result = await self.universal_nlp.process(text, TaskType.PATENT_ANALYSIS)
        return result.get("content", result)

    async def technical_reasoning(self, text: str, context: str = "") -> Dict[str, Any]:
        """技术推理（兼容Ollama接口）"""
        from ..nlp.universal_nlp_provider import TaskType
        full_text = f"{context}\n\n{text}" if context else text
        result = await self.universal_nlp.process(full_text, TaskType.TECHNICAL_REASONING)
        return result.get("content", result)

    async def emotional_analysis(self, text: str) -> Dict[str, Any]:
        """情感分析（兼容Ollama接口）"""
        from ..nlp.universal_nlp_provider import TaskType
        result = await self.universal_nlp.process(text, TaskType.EMOTIONAL_ANALYSIS)
        return result.get("content", result)

    async def conversation_response(self, text: str, context: Dict = None) -> Dict[str, Any]:
        """对话响应（兼容Ollama接口）"""
        from ..nlp.universal_nlp_provider import TaskType
        result = await self.universal_nlp.process(text, TaskType.CONVERSATION, context=context or {})
        return result.get("content", result)

    async def creative_writing(self, text: str, style: str = "story") -> Dict[str, Any]:
        """创意写作（兼容Ollama接口）"""
        from ..nlp.universal_nlp_provider import TaskType
        result = await self.universal_nlp.process(text, TaskType.CREATIVE_WRITING, style=style)
        return result.get("content", result)

# 导出适配器
__all__ = ['NLPAdapter', 'OllamaNLPWrapper']