#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
DeepResearch深度搜索系统集成
集成Jina AI的Node.js DeepResearch作为Athena的深度搜索工具

作者: 小娜 & 小诺
创建时间: 2025-12-04
"""

import asyncio
import json
import logging
import subprocess
import sys
import time
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from typing import Any, AsyncGenerator, Dict, List, Optional

# 添加项目路径
current_dir = Path(__file__).parent
project_root = current_dir.parent.parent.parent
sys.path.append(str(project_root))

from core.search.external.web_search_engines import (
    BaseSearchEngine,
    SearchResponse,
    SearchResult,
)

# 配置日志
logging.basic_Config(level=logging.INFO)
logger = logging.getLogger(__name__)

class DeepSearchStatus(Enum):
    """DeepResearch状态枚举"""
    IDLE = 'idle'
    SEARCHING = 'searching'
    READING = 'reading'
    REASONING = 'reasoning'
    COMPLETED = 'completed'
    ERROR = 'error'

@dataclass
class DeepSearchStep:
    """DeepResearch步骤数据"""
    step: int
    action: str
    think: str
    content: str
    timestamp: float
    references: List[Dict[str, str]] = None

@dataclass
class DeepSearchConfig:
    """DeepResearch配置"""
    project_path: Path
    node_path: str = 'node'
    max_steps: int = 50
    token_budget: int = 100000
    llm_provider: str = 'gemini'  # gemini, openai, local
    search_provider: str = 'jina'  # jina, brave, duckduckgo
    enable_streaming: bool = True
    timeout: int = 300  # 5分钟超时

class DeepSearchIntegration:
    """DeepResearch深度搜索集成"""

    def __init__(self, config: Optional[DeepSearchConfig] = None):
        """
        初始化DeepResearch集成

        Args:
            config: DeepSearch配置，如果为None则使用默认配置
        """
        self.config = config or self._get_default_config()
        self.status = DeepSearchStatus.IDLE
        self.current_process: Optional[subprocess.Popen] = None
        self.steps: List[DeepSearchStep] = []

        # 验证DeepResearch项目存在
        if not self.config.project_path.exists():
            raise FileNotFoundError(f"DeepResearch项目不存在: {self.config.project_path}")

        logger.info(f"DeepResearch集成初始化完成，项目路径: {self.config.project_path}")

    def _get_default_config(self) -> DeepSearchConfig:
        """获取默认配置"""
        deepsearch_path = project_root / 'projects' / 'node-DeepResearch'
        return DeepSearchConfig(project_path=deepsearch_path)

    def _set_environment(self) -> Dict[str, str]:
        """设置环境变量"""
        env = subprocess.os.environ.copy()

        # 设置API密钥（从环境变量读取）
        if self.config.llm_provider == 'gemini':
            gemini_key = subprocess.os.getenv('GEMINI_API_KEY')
            if gemini_key:
                env['GEMINI_API_KEY'] = gemini_key

        elif self.config.llm_provider == 'openai':
            openai_key = subprocess.os.getenv('OPENAI_API_KEY')
            if openai_key:
                env['OPENAI_API_KEY'] = openai_key

        # Jina API密钥
        jina_key = subprocess.os.getenv('JINA_API_KEY')
        if jina_key:
            env['JINA_API_KEY'] = jina_key

        # 配置LLM和搜索提供商
        env['LLM_PROVIDER'] = self.config.llm_provider
        env['SEARCH_PROVIDER'] = self.config.search_provider

        return env

    async def start_server(self, port: int = 3000, secret: Optional[str] = None) -> bool:
        """
        启动DeepResearch服务器

        Args:
            port: 服务器端口
            secret: 认证密钥（可选）

        Returns:
            bool: 是否启动成功
        """
        try:
            self.status = DeepSearchStatus.SEARCHING

            # 构建启动命令
            cmd = [
                self.config.node_path,
                str(self.config.project_path / 'dist' / 'server.js') if (self.config.project_path / 'dist').exists()
                else str(self.config.project_path / 'src' / 'server.ts')
            ]

            if secret:
                cmd.extend(['--secret', secret])

            logger.info(f"启动DeepResearch服务器: {' '.join(cmd)}")

            # 启动服务器进程
            env = self._set_environment()
            self.current_process = subprocess.Popen(
                cmd,
                cwd=str(self.config.project_path),
                env=env,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True
            )

            # 等待服务器启动
            await asyncio.sleep(3)

            if self.current_process.poll() is None:
                logger.info(f"DeepResearch服务器启动成功，端口: {port}")
                self.status = DeepSearchStatus.IDLE
                return True
            else:
                logger.error('DeepResearch服务器启动失败')
                self.status = DeepSearchStatus.ERROR
                return False

        except Exception as e:
            logger.error(f"启动DeepResearch服务器失败: {e}")
            self.status = DeepSearchStatus.ERROR
            return False

    async def stop_server(self):
        """停止DeepResearch服务器"""
        if self.current_process:
            self.current_process.terminate()
            try:
                self.current_process.wait(timeout=5)
            except subprocess.TimeoutExpired:
                self.current_process.kill()

            self.current_process = None
            self.status = DeepSearchStatus.IDLE
            logger.info('DeepResearch服务器已停止')

    async def deep_search(self, query: str, stream: bool = True) -> AsyncGenerator[DeepSearchStep, None]:
        """
        执行深度搜索

        Args:
            query: 搜索查询
            stream: 是否启用流式输出

        Yields:
            DeepSearchStep: 搜索步骤
        """
        if not self.current_process:
            raise RuntimeError('DeepResearch服务器未启动')

        try:
            self.status = DeepSearchStatus.SEARCHING
            self.steps.clear()

            # 构建CLI命令
            cmd = [self.config.node_path, str(self.config.project_path / 'src' / 'agent.ts'), query]
            env = self._set_environment()

            logger.info(f"执行深度搜索: {query}")

            # 执行搜索
            process = await asyncio.create_subprocess_exec(
                *cmd,
                cwd=str(self.config.project_path),
                env=env,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE
            )

            step_count = 0
            start_time = time.time()

            async def parse_output():
                """解析输出"""
                buffer = ''
                while True:
                    line = await process.stdout.readline()
                    if not line:
                        break

                    line_str = line.decode('utf-8').strip()
                    buffer += line_str + "\n"

                    # 解析步骤信息（简化版）
                    if 'action:' in line_str.lower() or 'search:' in line_str.lower():
                        step_count += 1

                        # 创建步骤对象
                        step = DeepSearchStep(
                            step=step_count,
                            action='search',
                            think=line_str,
                            content=line_str,
                            timestamp=time.time() - start_time
                        )

                        self.steps.append(step)
                        self.status = DeepSearchStatus.SEARCHING
                        yield step

                    elif 'answer:' in line_str.lower() or 'final:' in line_str.lower():
                        step_count += 1

                        step = DeepSearchStep(
                            step=step_count,
                            action='answer',
                            think=line_str,
                            content=line_str,
                            timestamp=time.time() - start_time
                        )

                        self.steps.append(step)
                        self.status = DeepSearchStatus.COMPLETED
                        yield step

            # 流式输出
            if stream:
                async for step in parse_output():
                    yield step
            else:
                # 非流式，等待完成
                output, error = await process.communicate()
                final_output = output.decode('utf-8')

                # 创建最终步骤
                final_step = DeepSearchStep(
                    step=0,
                    action='final',
                    think='搜索完成',
                    content=final_output,
                    timestamp=time.time() - start_time
                )

                self.steps.append(final_step)
                yield final_step

            # 等待进程结束
            return_code = await process.wait()

            if return_code == 0:
                self.status = DeepSearchStatus.COMPLETED
                logger.info(f"深度搜索完成，共{step_count}步")
            else:
                self.status = DeepSearchStatus.ERROR
                error_output = await process.stderr.read()
                logger.error(f"深度搜索失败: {error_output.decode('utf-8')}")

        except Exception as e:
            logger.error(f"深度搜索异常: {e}")
            self.status = DeepSearchStatus.ERROR
            raise

    async def get_search_results(self, query: str) -> 'SearchResponse':
        """
        获取搜索结果（兼容现有搜索引擎接口）

        Args:
            query: 搜索查询

        Returns:
            SearchResponse: 搜索结果
        """
        try:
            start_time = time.time()
            results = []

            # 执行深度搜索
            async for step in self.deep_search(query, stream=False):
                if step.action == 'answer' and step.content:
                    # 解析最终答案
                    content = step.content

                    # 创建搜索结果
                    result = SearchResult(
                        title=f"深度搜索结果: {query[:50]}...",
                        url=f"deepsearch://result/{step.step}",
                        snippet=content[:200] + '...' if len(content) > 200 else content,
                        relevance_score=0.95,
                        metadata={
                            'step': step.step,
                            'action': step.action,
                            'think': step.think,
                            'timestamp': step.timestamp,
                            'search_engine': 'deepsearch',
                            'search_method': 'multi_step_reasoning'
                        }
                    )
                    results.append(result)

            search_time = time.time() - start_time

            return SearchResponse(
                success=len(results) > 0,
                query=query,
                results=results,
                total_results=len(results),
                search_time=search_time,
                engine='deepsearch',
                api_key_used='integrated',
                metadata={
                    'total_steps': len(self.steps),
                    'status': self.status.value,
                    'llm_provider': self.config.llm_provider,
                    'search_provider': self.config.search_provider
                }
            )

        except Exception as e:
            logger.error(f"DeepResearch搜索失败: {e}")
            return SearchResponse(
                success=False,
                query=query,
                results=[],
                total_results=0,
                search_time=0,
                engine='deepsearch',
                api_key_used='integrated',
                error_message=str(e)
            )

    def get_status(self) -> Dict[str, Any]:
        """获取当前状态"""
        return {
            'status': self.status.value,
            'project_path': str(self.config.project_path),
            'config': {
                'llm_provider': self.config.llm_provider,
                'search_provider': self.config.search_provider,
                'max_steps': self.config.max_steps,
                'token_budget': self.config.token_budget
            },
            'steps_completed': len(self.steps),
            'server_running': self.current_process is not None and self.current_process.poll() is None
        }

    def get_steps_summary(self) -> List[Dict[str, Any]]:
        """获取步骤摘要"""
        return [
            {
                'step': step.step,
                'action': step.action,
                'think': step.think[:100] + '...' if len(step.think) > 100 else step.think,
                'content': step.content[:200] + '...' if len(step.content) > 200 else step.content,
                'timestamp': step.timestamp,
                'references': step.references or []
            }
            for step in self.steps
        ]

class DeepSearchEngine(BaseSearchEngine):
    """DeepResearch搜索引擎适配器"""

    def __init__(self, api_keys: List[str] = None, config: Dict[str, Any] = None):
        """初始化DeepResearch搜索引擎"""
        super().__init__(api_keys or ['integrated'], config)
        self.deepsearch = DeepSearchIntegration()

    async def search(self, query: str, max_results: int = 10) -> SearchResponse:
        """执行搜索"""
        return await self.deepsearch.get_search_results(query)

    def get_engine_info(self) -> Dict[str, Any]:
        """获取引擎信息"""
        return {
            'name': 'DeepResearch',
            'version': '1.0.0',
            'description': '基于多步推理的深度搜索引擎',
            'features': [
                '多步推理',
                '智能工具链',
                '流式输出',
                'OpenAI兼容API'
            ],
            'config': self.deepsearch.get_status()
        }

# 全局实例
_deepsearch_instance: Optional[DeepSearchIntegration] = None

def get_deepsearch_instance() -> DeepSearchIntegration:
    """获取DeepResearch全局实例"""
    global _deepsearch_instance
    if _deepsearch_instance is None:
        _deepsearch_instance = DeepSearchIntegration()
    return _deepsearch_instance

async def initialize_deepsearch():
    """初始化DeepSearch系统"""
    deepsearch = get_deepsearch_instance()
    success = await deepsearch.start_server()
    if success:
        logger.info('DeepSearch深度搜索系统初始化成功')
    else:
        logger.error('DeepSearch深度搜索系统初始化失败')
    return success

if __name__ == '__main__':
    # 测试代码
    async def test_deepsearch():
        deepsearch = DeepSearchIntegration()

        # 启动服务器
        success = await deepsearch.start_server()
        if not success:
            logger.info('启动失败')
            return

        try:
            # 执行搜索测试
            query = '什么是人工智能的最新发展趋势？'
            logger.info(f"开始深度搜索: {query}")

            async for step in deepsearch.deep_search(query):
                logger.info(f"步骤 {step.step}: {step.action}")
                logger.info(f"思考: {step.think}")
                logger.info(f"内容: {step.content[:100]}...")
                logger.info(str('-' * 50))

        finally:
            await deepsearch.stop_server()

    asyncio.run(test_deepsearch())