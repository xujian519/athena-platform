    "qa_patterns": [
      {
        "pattern_id": "QA001",
        "question_type": "权利查询",
        "intent_template": "{主体}在{情形}下享有什么权利",
        "query_template": "\n                MATCH (subject:LegalSubject)-[r:has_right]->(right:LegalConcept)\n                WHERE subject.name = $主体\n                MATCH (right)-[:applies_to]->(situation:LegalConcept)\n                WHERE situation.name = $情形\n                RETURN subject.name, right.name, right.定义, right.法律依据\n                ",
        "answer_template": "{主体}在{情形}下享有{权利}，具体包括：{权利说明}"
      },
      {
        "pattern_id": "QA002",
        "question_type": "义务查询",
        "intent_template": "{主体}需要承担什么义务",
        "query_template": "\n                MATCH (subject:LegalSubject)-[r:has_obligation]->(obligation:LegalConcept)\n                WHERE subject.name = $主体\n                RETURN subject.name, obligation.name, obligation.构成要件, obligation.法律后果\n                ",
        "answer_template": "{主体}需要承担{义务}，具体要求是：{义务说明}"
      },
      {
        "pattern_id": "QA003",
        "question_type": "法律后果查询",
        "intent_template": "{行为}会导致什么法律后果",
        "query_template": "\n                MATCH (action:LegalAction)-[:causes]->(consequence:LegalConsequence)\n                WHERE action.name = $行为\n                RETURN action.name, consequence.name, consequence.责任范围, consequence.救济途径\n                ",
        "answer_template": "{行为}可能导致{后果}，责任范围包括{责任说明}"
      },
      {
        "pattern_id": "QA004",
        "question_type": "时效查询",
        "intent_template": "{权利}的诉讼时效是多久",
        "query_template": "\n                MATCH (right:LegalConcept)-[:subject_to_limitation]->(limit:TimeLimit)\n                WHERE right.name = $权利\n                RETURN right.name, limit.期限长度, limit.起算点, limit.中断情形\n                ",
        "answer_template": "{权利}的诉讼时效为{期限长度}，从{起算点}开始计算"
      },
      {
        "pattern_id": "QA005",
        "question_type": "案例查询",
        "intent_template": "关于{法律问题}的相关案例",
        "query_template": "\n                MATCH (case:LegalCase)-[:applies_rule]->(rule:LegalRule)\n                MATCH (rule)-[:governs]->(concept:LegalConcept)\n                WHERE concept.name = $法律问题\n                RETURN case.案号, case.争议焦点, case.裁判要点\n                ORDER BY case.裁判日期 DESC\n                LIMIT 5\n                ",
        "answer_template": "关于{法律问题}的相关案例包括：{案例摘要}"
      },
      {
        "pattern_id": "QA006",
        "question_type": "管辖查询",
        "intent_template": "{案件}应该由哪个法院管辖",
        "query_template": "\n                MATCH (court:JudicialAuthority)-[:has_jurisdiction_over]->(case:LegalCase)\n                WHERE case.案号 = $案件 OR case.争议焦点 CONTAINS $案件关键词\n                RETURN court.name, court.机关层级, court.管辖范围\n                ",
        "answer_template": "{案件}应由{法院}管辖，该法院具有{管辖权说明}"
      }
    ]
  },
