        "confidence": 0.9
      },
      {
        "rule_id": "LR002",
        "name": "特殊法优于一般法规则",
        "description": "特殊规定优先于一般规定适用",
        "condition": [
          "?special_rule governs ?situation",
          "?general_rule governs ?situation",
          "?special_rule is_subclass_of ?general_rule"
        ],
        "conclusion": [
          "优先适用(?special_rule, ?general_rule)"
        ],
        "variables": {
          "?special_rule": "LegalRule",
          "?general_rule": "LegalRule",
          "?situation": "LegalConcept"
        },
        "confidence": 0.95
      },
      {
        "rule_id": "LR003",
        "name": "新法优于旧法规则",
        "description": "新法规定优于旧法规定",
        "condition": [
          "?new_rule governs ?situation",
          "?old_rule governs ?situation",
          "effective_time(?new_rule) > effective_time(?old_rule)"
        ],
        "conclusion": [
          "优先适用(?new_rule, ?old_rule)"
        ],
        "variables": {
          "?new_rule": "LegalRule",
          "?old_rule": "LegalRule",
          "?situation": "LegalConcept"
        },
        "confidence": 0.9
      },
      {
        "rule_id": "LR004",
        "name": "上位法优于下位法规则",
        "description": "效力层级高的法律优于效力层级低的法律",
        "condition": [
          "?higher_rule governs ?situation",
          "?lower_rule governs ?situation",
          "legal_hierarchy(?higher_rule) > legal_hierarchy(?lower_rule)"
        ],
        "conclusion": [
          "优先适用(?higher_rule, ?lower_rule)"
        ],
        "variables": {
          "?higher_rule": "LegalRule",
          "?lower_rule": "LegalRule",
          "?situation": "LegalConcept"
        },
        "confidence": 0.95
      },
      {
        "rule_id": "LR005",
        "name": "因果关系推定规则",
        "description": "特定行为通常导致的法律后果",
        "condition": [
          "?action performed_by ?subject",
          "?action is_instance_of ?action_type",
          "?action_type normally_causes ?consequence"
        ],
        "conclusion": [
          "?subject legally_responsible_for ?consequence"
        ],
        "variables": {
          "?action": "LegalAction",
          "?subject": "LegalSubject",
          "?action_type": "LegalConcept",
          "?consequence": "LegalConsequence"
        },
        "confidence": 0.8
      }
