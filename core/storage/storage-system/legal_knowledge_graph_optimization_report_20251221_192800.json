  "intelligence_enhancement": {
    "inference_rules": [
      {
        "rule_id": "LR001",
        "name": "权利义务对应规则",
        "description": "有权利必有对应义务",
        "condition": [
          "?subject has_right ?right"
        ],
        "conclusion": [
          "?other_subject has_obligation ?corresponding_obligation"
        ],
        "variables": {
          "?subject": "LegalSubject",
