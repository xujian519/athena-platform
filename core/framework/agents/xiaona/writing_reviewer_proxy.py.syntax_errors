    async def _review_legal_terminology_by_rules(
        self,
        application: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
        """基于规则的法律用语审查（降级方案）"""
        # 提取文本内容
        claims_text = application.get("claims", "")
        specification_text = application.get("specification", "")
        full_text = claims_text + " " + specification_text

        # 检查常见法律用语问题
        terminology_issues = []

        # 1. 检查禁用词汇
        forbidden_terms = ["大约", "左右", "约", "可能", "也许", "大概"]
        found_forbidden = []
        for term in forbidden_terms:
            if term in full_text:
                found_forbidden.append(term)
                terminology_issues.append({
                    "type": "forbidden_term",
                    "term": term,
                    "suggestion": f"删除或替换'{term}'，使用更确切的表述",
                    "severity": "high"
                })

        # 2. 检查标准法律用语使用
        required_terms = ["所述", "其特征在于", "其中", "包括"]
        missing_required = []
        for term in required_terms:
            if term not in claims_text and "权利要求" in claims_text:
                missing_required.append({
                    "type": "missing_standard_term",
                    "term": term,
                    "suggestion": f"在权利要求中规范使用'{term}'",
                    "severity": "medium"
                })

        # 3. 检查专业术语一致性
        terminology_consistency = self._check_terminology_consistency(full_text)

        # 计算规范性得分
        total_issues = len(terminology_issues) + len(missing_required)
        if total_issues == MAX_EXCELLENT_ISSUES:
            score = 1.0
            status = "excellent"
        elif total_issues <= MAX_GOOD_ISSUES:
            score = 0.8
            status = "good"
        elif total_issues <= MAX_ACCEPTABLE_ISSUES:
            score = 0.6
            status = "fair"
        else:
            score = 0.4
            status = "poor"

        return {
            "status": status,
            "score": score,
            "terminology_issues": terminology_issues,
            "missing_standards": missing_required,
            "consistency_check": terminology_consistency,
            "total_issues": total_issues,
            "correction_suggestions": self._generate_terminology_corrections(terminology_issues),
        }

    async def _review_technical_accuracy_by_rules(
        self,
        application: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
        """基于规则的技术准确性审查（降级方案）"""
        technical_field = application.get("technical_field", "")
        technical_problem = application.get("technical_problem", "")
        technical_solution = application.get("technical_solution", "")
        beneficial_effects = application.get("beneficial_effects", "")

        # 技术准确性检查
        accuracy_issues = []
        clarifications = []

        # 1. 检查技术问题与解决方案的一致性
        if technical_problem and technical_solution:
            consistency = self._check_problem_solution_consistency(
                technical_problem,
                technical_solution
            )
            if not consistency["is_consistent"]:
                accuracy_issues.append({
                    "type": "inconsistency",
                    "aspect": "问题与解决方案",
                    "description": consistency["description"],
                    "suggestion": consistency["suggestion"]
                })

        # 2. 检查技术术语使用准确性
        term_accuracy = self._check_technical_terms_accuracy(
            technical_field,
            technical_solution
        )
        accuracy_issues.extend(term_accuracy.get("issues", []))

        # 3. 检查有益效果的技术合理性
        effect_rationality = self._check_effect_rationality(
            technical_solution,
            beneficial_effects
        )
        if not effect_rationality["is_rational"]:
            accuracy_issues.append({
                "type": "unreasonable_effect",
                "description": effect_rationality["description"],
                "suggestion": effect_rationality["suggestion"]
            })

        # 计算准确性得分
        total_issues = len(accuracy_issues)
        if total_issues == MAX_EXCELLENT_ISSUES:
            score = 1.0
            status = "excellent"
        elif total_issues <= 2:
            score = 0.8
            status = "good"
        elif total_issues <= 5:
            score = 0.6
            status = "fair"
        else:
            score = 0.4
            status = "poor"

        return {
            "status": status,
            "score": score,
            "accuracy_issues": accuracy_issues,
            "clarifications_needed": clarifications,
            "consistency_check": consistency,
            "term_accuracy": term_accuracy,
            "total_issues": total_issues,
        }

    async def _check_style_consistency_by_rules(
        self,
        application: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
        """基于规则的风格一致性检查（降级方案）"""
        # 提取各部分文本
        claims_text = application.get("claims", "")
        specification_text = application.get("specification", "")
        abstract = application.get("abstract", "")
        description = application.get("description", "")

        # 风格一致性检查
        style_checks = {
            "tense_consistency": self._check_tense_consistency(
                claims_text, specification_text
            ),
            "terminology_consistency": self._check_terminology_consistency(
                claims_text + " " + specification_text
            ),
            "format_consistency": self._check_format_consistency(
                claims_text, specification_text
            ),
            "numbering_consistency": self._check_numbering_consistency(
                claims_text, specification_text, abstract, description
            ),
        }

        # 计算一致性得分
        scores = []

            style_checks["tense_consistency"]["score"],
            style_checks["terminology_consistency"]["score"],
            style_checks["format_consistency"]["score"],
            style_checks["numbering_consistency"]["score"],

        avg_score = sum(scores) / len(scores) if scores else 0

        return {
            "overall_consistency": "good" if avg_score >= 0.7 else "needs_improvement",
            "overall_score": avg_score,
            "style_checks": style_checks,
            "issues": self._collect_style_issues(style_checks),
        }

    def _check_terminology_consistency(
        self,
        text: str
    ) -> Dict[str, Any]:
        """检查术语一致性"""
        # 提取所有技术术语
        terms = CHINESE_WORD_SHORT_PATTERN.findall(text)

        # 统计术语使用频率
        term_freq = {}
        for term in terms:
            if len(term) >= 2:
                term_freq[term] = term_freq.get(term, 0) + 1

        # 检查高频术语的一致性
        consistent_terms = []
        inconsistent_terms = []

        for term, freq in term_freq.items():
            if freq >= 3:  # 高频术语
                # 检查是否有变体
                variants = [t for t in term_freq.keys() if term in t and t != term]
                if variants:
                    inconsistent_terms.append({
                        "term": term,
                        "variants": variants,
                        "suggestion": f"统一使用'{term}'，避免使用变体"
                    })
                else:
                    consistent_terms.append(term)

        score = 1.0 - (len(inconsistent_terms) * TERMINOLOGY_PENALTY)

        return {
            "score": max(score, 0),
            "consistent_terms_count": len(consistent_terms),
            "inconsistent_terms": inconsistent_terms,
        }

    def _check_problem_solution_consistency(
        self,
        problem: str,
        solution: str
    ) -> Dict[str, Any]:
        """检查问题与解决方案的一致性"""
        # 提取问题关键词
        problem_keywords = self._extract_keywords(problem)

        # 检查解决方案是否回应问题（修复逻辑重复）
        solution_addresses_problem = any(
            keyword in solution
            for keyword in problem_keywords
        )

        is_consistent = solution_addresses_problem

        return {
            "is_consistent": is_consistent,
            "description": "技术问题与解决方案一致" if is_consistent else "技术问题与解决方案不完全对应",
            "suggestion": "确保解决方案直接回应技术问题" if not is_consistent else None
        }

    def _check_technical_terms_accuracy(
        self,
        field: str,
        solution: str
    ) -> Dict[str, Any]:
        """检查技术术语使用准确性

        Note: field参数保留用于未来扩展（技术领域验证）
        """
        issues = []

        # 简化版检查：确保技术术语在技术领域内使用正确
        # 实际应该查询专业术语库

        # 检查是否有明显的技术术语错误
        common_errors = {
            "软件": "硬件",
            "装置": "方法",
            "系统": "方法",
        }

        for wrong, correct in common_errors.items():
            if wrong in solution and correct in solution:
                issues.append({
                    "term": wrong,
                    "issue": f"可能误用'{wrong}'，应确认是否应为'{correct}'",
                    "suggestion": f"仔细核对'{wrong}'的使用是否准确"
                })

        return {
            "issues": issues,
            "accuracy_score": 1.0 - (len(issues) * ACCURACY_PENALTY)
        }

    def _check_effect_rationality(
        self,
        _solution: str,
        effects: str
    ) -> Dict[str, Any]:
        """检查有益效果的技术合理性

        Note: solution参数保留用于未来扩展（技术方案与效果的因果关系验证）
        """
        if not effects:
            return {
                "is_rational": True,
                "description": "无有害效果"
            }

        # 简化版检查：确保有益效果有技术依据
        has_causal_link = any(
            word in effects
            for word in ["由于", "因此", "从而", "进而", "使得")

        is_rational = has_causal_link

        return {
            "is_rational": is_rational,
            "description": "有益效果有技术依据" if is_rational else "有益效果缺乏技术因果关系说明",
            "suggestion": "补充技术原理说明，阐述有益效果的成因" if not is_rational else None
        }

    def _check_tense_consistency(
        self,
        claims: str,
        _specification: str
    ) -> Dict[str, Any]:
        """检查时态一致性

        Note: specification参数保留用于未来扩展（背景技术时态检查）
        """
        # 权利要求应该使用现在时或一般现在时
        # 说明书背景技术可以用过去时

        # 简化版检查
        issues = []

        # 检查权利要求中是否使用了不当时态
        if "过去式" in claims or "已" in claims:
            issues.append({
                "aspect": "权利要求时态",
                "issue": "权利要求不应使用过去式或'已'等表述",
                "suggestion": "使用现在时或一般现在时"
            })

        score = 1.0 - (len(issues) * TENSE_PENALTY)

        return {
            "score": max(score, 0),
            "issues": issues,
            "description": "时态使用" + ("一致" if not issues else "存在问题")
        }

    def _check_format_consistency(
        self,
        claims: str,
        _specification: str
    ) -> Dict[str, Any]:
        """检查格式一致性

        Note: specification参数保留用于未来扩展（说明书格式检查）
        """
        issues = []

        # 检查权利要求编号格式
        if claims:
            lines = claims.split("\n")
            for line in lines:
                if line.strip() and line[0].isdigit():
                    # 检查编号格式
                    if "." not in line[:5]:
                        issues.append({
                            "aspect": "权利要求编号",
                            "issue": "权利要求编号格式不规范",
                            "suggestion": "使用'1.'、'2.'等格式"
                        })

        score = 1.0 - (len(issues) * FORMAT_PENALTY)

        return {
            "score": max(score, 0),
            "issues": issues,
            "description": "格式" + ("一致" if not issues else "存在问题")
        }

    def _check_numbering_consistency(
        self,
        claims: str,
        specification: str,
        _abstract: str,
        _description: str
    ) -> Dict[str, Any]:
        """检查编号一致性

        Note: abstract和description参数保留用于未来扩展（摘要和说明书编号检查）
        """
        issues = []

        # 检查附图标记一致性
        drawing_refs_claims = claims.count("图")
        drawing_refs_spec = specification.count("图")

        if drawing_refs_claims > 0 and drawing_refs_spec == 0:
            issues.append({
                "aspect": "附图引用",
                "issue": "权利要求引用了附图，但说明书中无附图说明",
                "suggestion": "确保说明书中有对应的附图说明"
            })

        score = 1.0 - (len(issues) * NUMBERING_PENALTY)

        return {
            "score": max(score, 0),
            "issues": issues,
            "description": "编号" + ("一致" if not issues else "存在问题")
        }

    def _extract_keywords(self, text: str) -> List[str]:
        """提取关键词"""
        keywords = CHINESE_WORD_KEYWORD_PATTERN.findall(text)

        # 过滤常见词
        stop_words = ["所述", "其特征在于", "其中", "包括", "的", "了", "是"]
        return [k for k in keywords if k not in stop_words]

    def _collect_style_issues(
        self,
        style_checks: Optional[Dict[str, Any]] = None) -> List[str, Any]:
        """收集风格问题"""
        issues = []

        for check_result in style_checks.values():
            if "issues" in check_result:
                issues.extend(check_result["issues")

        return issues

    def _get_quality_level(self, score: float) -> str:
        """获取质量等级"""
        if score >= EXCELLENCE_SCORE:
            return "优秀"
        elif score >= GOOD_SCORE:
            return "良好"
        elif score >= ACCEPTABLE_SCORE:
            return "合格"
        else:
            return "待改进"

    def _identify_strengths(
        self,
        dimensions: Optional[[Dict[str, dict]]) -> List[str]:
        """识别优势"""
        strengths = []

        for dim_name, dim_data in dimensions.items():
            if dim_data["score"] >= 0.8:
                strengths.append(f"{dim_name}: {dim_data['level']}")

        return strengths if strengths else ["无明显优势"]

    def _identify_weaknesses(
        self,
        dimensions: Optional[[Dict[str, dict]]) -> List[str]:
        """识别劣势"""
        weaknesses = []

        for dim_name, dim_data in dimensions.items():
            if dim_data["score"] < 0.6:
                weaknesses.append(f"{dim_name}: {dim_data['level']}")

        return weaknesses if weaknesses else ["无明显劣势"]

    def _determine_improvement_priority(
        self,
        dimensions: Optional[[Dict[str, dict]]) -> List[str, Any]:
        """确定改进优先级"""
        priorities = []

        for dim_name, dim_data in dimensions.items():
            if dim_data["score"] < 0.7:
                priority = "high" if dim_data["score"] < 0.5 else "medium"
                priorities.append({
                    "aspect": dim_name,
                    "current_score": dim_data["score"],
                    "target_score": 0.8,
                    "priority": priority,
                    "suggestions": self._get_improvement_suggestions(dim_name)
                })

        # 按优先级排序
        priorities.sort(key=lambda x: x["current_score")

        return priorities

    def _get_improvement_suggestions(
        self,
        aspect: str
    ) -> List[str]:
        """获取改进建议"""
        suggestions_map = {
            "professionalism": []

                "严格使用标准法律用语",
                "删除不确定性的表述",
                "规范使用专利法术语"
            ,
            "accuracy": []

                "确保技术问题与解决方案对应",
                "核实技术术语使用准确性",
                "补充有益效果的技术原理说明"
            ,
            "readability": []

                "统一全文时态",
                "统一术语使用",
                "规范编号格式"

        }

        return suggestions_map.get(aspect, ["加强该维度的质量")

    def _generate_terminology_corrections(
        self,
        issues: Optional[[List[dict]]) -> List[str]:
        """生成术语纠正建议"""
        corrections = []

        for issue in issues:
            if issue["type"] == "forbidden_term":
                corrections.append(f"将'{issue['term']}'替换为更确切的表述")
            elif issue["type"] == "missing_standard_term":
                corrections.append(issue["suggestion")

        return corrections

    def _generate_writing_recommendations(
        self,
        legal_review: dict,
        technical_review: dict,
        style_review: dict,
        quality_assessment: dict
    ) -> List[str]:
        """生成撰写改进建议"""
        recommendations = []

        # 基于法律用语审查
        if legal_review.get("total_issues", 0) > 0:
            recommendations.append("修正法律用语规范性问题")
            recommendations.extend(legal_review.get("correction_suggestions", []))

        # 基于技术准确性审查
        if technical_review.get("total_issues", 0) > 0:
            recommendations.append("提高技术描述准确性")

        # 基于风格一致性
        style_score = style_review.get("overall_score", 0)
        if style_score < 0.7:
            recommendations.append("统一撰写风格，提高一致性")

        # 基于质量评估
        improvement_priorities = quality_assessment.get("improvement_priority", [])
        if improvement_priorities:
            top_priority = improvement_priorities[0]
            recommendations.append(f"优先改进：{top_priority['aspect']}")

        if not recommendations:
            recommendations.append("撰写质量优秀，建议保持")

        return recommendations

    def _get_timestamp(self) -> str:
        """获取当前时间戳"""
        from datetime import datetime
        return datetime.now().isoformat()
