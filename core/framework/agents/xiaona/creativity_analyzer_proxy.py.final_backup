"""
创造性分析专用代理

专注于专利创造性分析，提供深入的创造性评估。

集成LLM智能分析能力，支持：
- 显而易见性评估
- 创造性步骤评估
- 技术进步分析
- 完整创造性分析
"""

import json
import logging
import re
from typing import Any, Dict, List, Optional

from core.framework.agents.xiaona.base_component import BaseXiaonaComponent

logger = logging.getLogger(__name__)


class CreativityAnalyzerProxy(BaseXiaonaComponent):
    """
    创造性分析专用代理

    核心能力：
    - 技术特征分析
    - 现有技术评估
    - 区别特征识别
    - 显著进步判断
    - 预料不到效果评估
    """

    def _initialize(self) -> str:
        """初始化创造性分析代理"""
        self._register_capabilities([
            AgentCapability(
                name="obviousness_assessment",
                description="显而易见性评估（LLM增强）",
                input_types=["技术方案", "现有技术"],
                output_types=["显而易见性结论"],
                estimated_time=15.0,
            ),
            AgentCapability(
                name="inventive_step_evaluation",
                description="创造性步骤评估（LLM增强）",
                input_types=["发明", "现有技术"],
                output_types=["创造性步骤结论"],
                estimated_time=20.0,
            ),
            AgentCapability(
                name="technical_advancement_analysis",
                description="技术进步分析（LLM增强）",
                input_types=["发明", "技术领域"],
                output_types=["进步性分析"],
                estimated_time=20.0,
            ),
            AgentCapability(
                name="creativity_evaluation",
                description="创造性评估（LLM增强）",
                input_types=["目标专利", "对比文件"],
                output_types=["创造性分析报告"],
                estimated_time=25.0,
            ),
        ])

    def get_system_prompt(self) -> str:
        """获取系统提示词"""
        return """
你是一位专业的专利创造性分析专家，具备深厚的专利法知识和丰富的审查经验。

你的职责是：
1. 评估发明的显而易见性
2. 分析发明的创造性步骤
3. 判断发明的显著技术进步
4. 识别预料不到的技术效果

请以专业、严谨的态度进行分析，并提供明确的结论和理由。
输出必须是严格的JSON格式，不要添加任何额外的文字说明。
"""

    async def execute(self, context) -> str:
        """
        执行智能体任务

        Args:
            context: 执行上下文

        Returns:
            执行结果
        """
        task_type = context.config.get("task_type", "comprehensive")

        if task_type == "obviousness":
            return await self.assess_obviousness(context.input_data)
        elif task_type == "inventive_step":
            return await self.evaluate_inventive_step(context.input_data)
        elif task_type == "technical_advancement":
            return await self.analyze_technical_advancement(context.input_data)
        else:
            # 完整创造性分析
            return await self.analyze_creativity(context.input_data)

    async def analyze_creativity(
        self,
        patent_data: Optional[Dict[str, Any]],
        analysis_mode: str = "standard"
    ) -> Dict[str, Any]:
        """
        分析创造性（LLM版本）

        Args:
            patent_data: 专利数据（包含prior_art等信息）
            analysis_mode: 分析模式（comprehensive/quick）

        Returns:
            创造性分析结果
        """
        # 尝试使用LLM分析
        try:
            prompt = self._build_comprehensive_creativity_prompt(patent_data)
            response = await self._call_llm_with_fallback(
                prompt=prompt,
                task_type="creativity_evaluation"
            )

            # 解析LLM响应
            return self._parse_comprehensive_creativity_response(response, patent_data)
        except Exception as e:
            self.logger.warning(f"LLM创造性分析失败: {e}，使用规则-based分析")
            return await self._analyze_creativity_by_rules(patent_data, analysis_mode)

    async def assess_obviousness(
        self,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """
        评估显而易见性（LLM版本）

        Args:
            patent_data: 专利数据

        Returns:
            显而易见性评估结果
        """
        # 尝试使用LLM分析
        try:
            prompt = self._build_obviousness_assessment_prompt(patent_data)
            response = await self._call_llm_with_fallback(
                prompt=prompt,
                task_type="obviousness_assessment"
            )

            # 解析LLM响应
            return self._parse_obviousness_response(response)
        except Exception as e:
            self.logger.warning(f"LLM显而易见性评估失败: {e}，使用规则-based评估")
            return await self._assess_obviousness_by_rules(patent_data)

    async def evaluate_inventive_step(
        self,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """
        评估创造性步骤（LLM版本）

        Args:
            patent_data: 专利数据

        Returns:
            创造性步骤评估结果
        """
        # 尝试使用LLM分析
        try:
            prompt = self._build_inventive_step_prompt(patent_data)
            response = await self._call_llm_with_fallback(
                prompt=prompt,
                task_type="inventive_step_evaluation"
            )

            # 解析LLM响应
            return self._parse_inventive_step_response(response)
        except Exception as e:
            self.logger.warning(f"LLM创造性步骤评估失败: {e}，使用规则-based评估")
            return await self._evaluate_inventive_step_by_rules(patent_data)

    async def analyze_technical_advancement(
        self,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """
        分析技术进步（LLM版本）

        Args:
            patent_data: 专利数据

        Returns:
            技术进步分析结果
        """
        # 尝试使用LLM分析
        try:
            prompt = self._build_technical_advancement_prompt(patent_data)
            response = await self._call_llm_with_fallback(
                prompt=prompt,
                task_type="technical_advancement_analysis"
            )

            # 解析LLM响应
            return self._parse_technical_advancement_response(response)
        except Exception as e:
            self.logger.warning(f"LLM技术进步分析失败: {e}，使用规则-based分析")
            return await self._analyze_technical_advancement_by_rules(patent_data)

    def _extract_differences(self, patent_text: str) -> str:
        """提取区别特征"""
        if "区别" in patent_text:
            # 简单提取包含"区别"的句子
            parts = patent_text.split("。")
            differences = []
            for part in parts:
                if "区别" in part:
                    differences.append(part.strip())
            return differences
        return ["本发明与现有技术的区别在于技术方案"]

    def _assess_teaching_away(self, prior_art: list) -> Dict[str, Any]:
        """评估教导away"""
        has_teaching_away = False
        teaching_away_evidence = []

        for ref in prior_art:
            content = ref.get("content", "")
            if "不可行" in content or "无法实现" in content or "否定" in content:
                has_teaching_away = True
                teaching_away_evidence.append(ref.get("publication_number", "未知文献"))

        return {
            "has_teaching_away": has_teaching_away,
            "evidence": teaching_away_evidence,
        }

    def _identify_surprising_effect(self, patent_data: Optional[Dict[str, Any]]) -> Dict[str, Any]:
        """识别预料不到的效果"""
        invention_content = patent_data.get("invention_content", "")
        beneficial_effects = patent_data.get("beneficial_effects", "")

        # 查找预料不到的关键词
        surprising_keywords = [
            "预料不到", "意外", "显著提高", "大幅改善",
            "远超", "突破", "出乎意料"
        ]

        has_surprising_effect = False
        effect_description = "未发现明显预料不到的效果"

        for keyword in surprising_keywords:
            if keyword in invention_content or keyword in beneficial_effects:
                has_surprising_effect = True
                effect_description = f"发现预料不到的效果：{keyword}"
                break

        return {
            "has_surprising_effect": has_surprising_effect,
            "effect_description": effect_description,
        }

    # 私有方法重命名
    async def _assess_obviousness_internal(
        self,
        differences: Any,
        prior_art: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """内部显而易见性评估"""
        return {
            "is_obvious": False,
            "reasoning": "区别特征非显而易见",
            "evidence": ["证据1", "证据2"],
        }

    async def _evaluate_inventive_step_internal(
        self,
        differences: Any
    ) -> Dict[str, Any]:
        """内部创造性步骤评估"""
        return {
            "has_inventive_step": True,
            "magnitude": "significant",
            "evidence": ["证据1", "证据2"],
        }

    async def _analyze_technical_advancement_internal(
        self,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """内部技术进步分析"""
        return {
            "has_advancement": True,
            "type": "性能提升",
            "degree": "显著",
            "evidence": ["证据1", "证据2"],
        }

    def _calculate_confidence_score(
        self,
        obviousness: Optional[Dict[str, Any],]

        progress: Optional[Dict[str, Any],]

        effects: Optional[Dict[str, Any]]

    ) -> str:
        """计算置信度分数"""
        score = 0.5  # 基础分

        if not obviousness.get("is_obvious", True):
            score += 0.2

        if progress.get("has_significant_progress", False):
            score += 0.2

        if effects.get("has_unexpected_effects", False):
            score += 0.1

        return min(score, 1.0)

    def _get_timestamp(self) -> str:
        """获取时间戳"""
        from datetime import datetime
        return datetime.now().isoformat()

    # 保留原有的内部方法（用于兼容）
    async def _assess_obviousness(
        self,
        differences: Optional[[list[Dict[str, Any]]],]

        prior_art: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """评估显而易见性（保留用于兼容）"""
        return await self._assess_obviousness_internal(differences, prior_art)

    async def _evaluate_progress(
        self,
        differences: Optional[[list[Dict[str, Any]]]
    ) -> Dict[str, Any]:
        """评估显著进步（保留用于兼容）"""
        return {
            "has_significant_progress": True,
            "progress_type": "性能提升",
            "benefits": ["有益效果1", "有益效果2"],
        }

    async def _identify_differences(
        self,
        features: Optional[Dict[str, Any],]

        prior_art: Optional[Dict[str, Any]]

    ) -> list[str, Any]:
        """识别区别特征（保留用于兼容）"""
        return []

            {
                "feature": "特征3",
                "difference": "与现有技术的区别",
                "novel": True,
            }


    async def _assess_unexpected_effects(
        self,
        differences: Optional[[list[Dict[str, Any]]]
    ) -> Dict[str, Any]:
        """评估预料不到的效果（保留用于兼容）"""
        return {
            "has_unexpected_effects": True,
            "effects": ["预料不到的效果1", "预料不到的效果2"],
        }

    async def analyze_creativity_legacy(
        self,
        target_patent: Optional[Dict[str, Any],]

        reference_docs: Optional[[list[Dict[str, Any]]],]

        analysis_depth: str = "standard"
    ) -> Dict[str, Any]:
        """
        分析创造性（兼容旧接口）
        """
        """
        分析创造性

        Args:
            target_patent: 目标专利
            reference_docs: 对比文件列表
            analysis_depth: 分析深度（standard/deep）

        Returns:
            创造性分析结果
        """
        # 1. 提取技术特征
        features = await self._extract_technical_features(target_patent)

        # 2. 分析现有技术
        prior_art = await self._analyze_prior_art(reference_docs)

        # 3. 识别区别特征
        differences = await self._identify_differences(features, prior_art)

        # 4. 评估显而易见性
        obviousness = await self._assess_obviousness(differences, prior_art)

        # 5. 判断显著进步
        significant_progress = await self._evaluate_progress(differences)

        # 6. 评估预料不到的效果
        unexpected_effects = await self._assess_unexpected_effects(differences)

        return {
            "analysis_type": "creativity",
            "target_patent": target_patent.get("patent_id", "未知"),
            "technical_features": features,
            "differences": differences,
            "obviousness": obviousness,
            "significant_progress": significant_progress,
            "unexpected_effects": unexpected_effects,
            "conclusion": self._generate_creativity_conclusion(
                obviousness,
                significant_progress,
                unexpected_effects
            ),
        }

    async def _extract_technical_features(
        self,
        patent: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """提取技术特征"""
        return {
            "essential_features": ["特征1", "特征2", "特征3"],
            "additional_features": ["特征4", "特征5"],
            "technical_field": patent.get("field", "未知领域"),
        }

    async def _analyze_prior_art(
        self,
        reference_docs: Optional[[list[Dict[str, Any]]]
    ) -> Dict[str, Any]:
        """分析现有技术"""
        return {
            "closest_prior_art": Optional[reference_docs[0] if reference_docs else None,]

            "disclosed_features": ["特征1", "特征2"],
            "technical_teachings": ["教导1", "教导2"],
        }

    async def _identify_differences(
        self,
        features: Optional[Dict[str, Any],]

        prior_art: Optional[Dict[str, Any]]

    ) -> list[str, Any]:
        """识别区别特征"""
        return []

            {
                "feature": "特征3",
                "difference": "与现有技术的区别",
                "novel": True,
            }


    async def _assess_obviousness(
        self,
        differences: Optional[[list[Dict[str, Any]]],]

        prior_art: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """评估显而易见性"""
        return {
            "is_obvious": False,
            "reasoning": "区别特征非显而易见",
            "evidence": ["证据1", "证据2"],
        }

    async def _evaluate_progress(
        self,
        differences: Optional[[list[Dict[str, Any]]]
    ) -> Dict[str, Any]:
        """评估显著进步"""
        return {
            "has_significant_progress": True,
            "progress_type": "性能提升",
            "benefits": ["有益效果1", "有益效果2"],
        }

    async def _assess_unexpected_effects(
        self,
        differences: Optional[[list[Dict[str, Any]]]
    ) -> Dict[str, Any]:
        """评估预料不到的效果"""
        return {
            "has_unexpected_effects": True,
            "effects": ["预料不到的效果1", "预料不到的效果2"],
        }

    def _generate_creativity_conclusion(
        self,
        obviousness: Optional[Dict[str, Any],]

        progress: Optional[Dict[str, Any],]

        effects: Optional[Dict[str, Any]]

    ) -> str:
        """生成创造性结论"""
        if (not obviousness.get("is_obvious") and
            progress.get("has_significant_progress")):
            return "具备创造性"
        else:
            return "不具备创造性"

    # ========== LLM集成方法 ==========

    def _build_comprehensive_creativity_prompt(self, patent_data: Optional[Dict[str, Any])] -> str:
        """构建完整创造性分析提示词"""
        prior_art = patent_data.get("prior_art", [])
        patent_data.get("differences", [])

        return f"""# 任务：专利创造性综合分析

## 目标专利信息
```json
{json.dumps(patent_data, ensure_ascii=False, indent=2)}
```

## 对比文件（现有技术）
```json
{json.dumps(prior_art, ensure_ascii=False, indent=2)}
```

## 综合分析要点

### 1. 创造性判断的三大要素
1. **显著进步**：发明是否具有显著的技术进步
2. **非显而易见性**：发明对本领域技术人员来说是否显而易见
3. **预料不到的效果**：发明是否带来预料不到的技术效果

### 2. 综合评估流程
1. 确定最接近的现有技术
2. 识别区别技术特征
3. 评估显而易见性
4. 判断显著进步
5. 识别预料不到的效果
6. 综合得出创造性结论

### 3. 创造性等级
- **高创造性**：显著进步 + 非显而易见 + 预料不到的效果
- **中等创造性**：明显进步 + 非显而易见
- **低创造性**：一定进步 + 一定非显而易见性
- **无创造性**：无显著进步或显而易见

## 输出要求

请严格按照以下JSON格式输出评估结果：

```json
{{
    "obviousness_assessment": {{
        "is_obvious": false,
        "confidence": 0.85,
        "reasoning": "推理过程"
    }},
    "inventive_step_evaluation": {{
        "has_inventive_step": true,
        "step_magnitude": "significant",
        "confidence": 0.8,
        "evidence": ["证据1", "证据2"]
    }},
    "technical_advancement": {{
        "has_advancement": true,
        "advancement_type": "performance",
        "improvement_degree": "significant",
        "evidence": ["证据1", "证据2"]
    }},
    "unexpected_effects": {{
        "has_unexpected_effects": true,
        "effects": ["预料不到的效果1", "预料不到的效果2"],
        "evidence": ["证据1", "证据2"]
    }},
    "creativity_conclusion": "具备创造性",
    "creativity_level": "high或medium或low或none",
    "overall_confidence": 0.85,
    "key_reasoning": []

        "理由1：非显而易见的技术方案",
        "理由2：显著的技术进步",
        "理由3：预料不到的技术效果"
    ,
    "recommendations": ["建议1", "建议2"]
}}
```

请只输出JSON，不要添加任何额外说明。
"""

    def _parse_comprehensive_creativity_response(
        self,
        response: str,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """解析完整创造性分析LLM响应"""
        try:
            # 提取JSON
            json_match = re.search(r'```json\s*([\s\S]*?)```', response)
            if json_match:
                json_str = json_match.group(1).strip()
            else:
                json_str = response.strip()

            result = json.loads(json_str)

            # 验证必需字段
            required_fields = []

                "obviousness_assessment", "inventive_step_evaluation",
                "technical_advancement", "unexpected_effects",
                "creativity_conclusion", "creativity_level"

            for field in required_fields:
                if field not in result:
                    result[field] = None

            # 添加元数据
            result["patent_id"] = patent_data.get("patent_id", "未知")
            result["analyzed_at"] = self._get_timestamp()

            return result

        except (json.JSONDecodeError, Exception) as e:
            self.logger.error(f"解析完整创造性分析响应失败: {e}")
            # 返回默认响应
            return {
                "patent_id": patent_data.get("patent_id", "未知"),
                "obviousness_assessment": {"is_obvious": True, "confidence": 0.5},
                "inventive_step_evaluation": {"has_inventive_step": False},
                "technical_advancement": {"has_advancement": False},
                "unexpected_effects": {"has_unexpected_effects": False},
                "creativity_conclusion": "分析失败",
                "creativity_level": "unknown",
                "analyzed_at": self._get_timestamp(),
            }

    def _build_obviousness_assessment_prompt(self, patent_data: Optional[Dict[str, Any])] -> str:
        """构建显而易见性评估提示词"""
        prior_art = patent_data.get("prior_art", [])
        differences = patent_data.get("differences", "存在区别特征")

        return f"""# 任务：专利显而易见性评估

## 目标专利信息
```json
{json.dumps(patent_data, ensure_ascii=False, indent=2)}
```

## 对比文件（现有技术）
```json
{json.dumps(prior_art, ensure_ascii=False, indent=2)}
```

## 区别特征
```json
{json.dumps(differences, ensure_ascii=False, indent=2)}
```

## 评估要点

### 1. 问题-解决方案法（Problem-Solution Approach）
- **确定最接近的现有技术**：从对比文件中找到最接近的现有技术
- **确定区别技术特征**：目标专利与最接近现有技术的区别
- **确定技术问题**：这些区别特征要解决的技术问题
- **评估显而易见性**：本领域技术人员是否会显而易见地采用这些区别特征

### 2. 判断标准
- **显而易见**：区别特征是现有技术的简单组合、替换或常规手段
- **非显而易见**：区别特征带来预料不到的效果，或现有技术存在反向教导

### 3. 关键考虑因素
- 现有技术是否明确教导或暗示采用这些区别特征
- 区别特征是否是本领域的公知常识
- 区别特征是否带来预料不到的技术效果
- 现有技术是否存在教导away（反向教导）

## 输出要求

请严格按照以下JSON格式输出评估结果：

```json
{{
    "is_obvious": true或false,
    "confidence": 0.85,
    "reasoning": "详细推理过程",
    "key_factors": []

        "因素1：现有技术是否明确教导",
        "因素2：是否带来预料不到的效果",
        "因素3：是否存在反向教导"
    ,
    "closest_prior_art": "最接近的现有技术编号或描述",
    "distinguishing_features": ["区别特征1", "区别特征2"],
    "technical_problem": "要解决的技术问题",
    "obviousness_conclusion": "显而易见性结论及理由"
}}
```

请只输出JSON，不要添加任何额外说明。
"""

    def _parse_obviousness_response(self, response: str) -> Dict[str, Any]:
        """解析显而易见性评估LLM响应"""
        try:
            # 提取JSON
            json_match = re.search(r'```json\s*([\s\S]*?)```', response)
            if json_match:
                json_str = json_match.group(1).strip()
            else:
                json_str = response.strip()

            result = json.loads(json_str)

            # 验证必需字段
            if "is_obvious" not in result:
                result["is_obvious"] = True
            if "confidence" not in result:
                result["confidence"] = 0.5
            if "reasoning" not in result:
                result["reasoning"] = "推理过程缺失"

            return result

        except (json.JSONDecodeError, Exception) as e:
            self.logger.error(f"解析显而易见性评估响应失败: {e}")
            return {
                "is_obvious": True,
                "confidence": 0.5,
                "reasoning": "LLM响应解析失败",
                "key_factors": Optional[[],]

                "closest_prior_art": "未知",
                "distinguishing_features": Optional[[],]

                "technical_problem": "未知",
                "obviousness_conclusion": "分析失败",
            }

    def _build_inventive_step_prompt(self, patent_data: Optional[Dict[str, Any])] -> str:
        """构建创造性步骤评估提示词"""
        differences = patent_data.get("differences", "存在区别特征")

        return f"""# 任务：专利创造性步骤评估

## 目标专利信息
```json
{json.dumps(patent_data, ensure_ascii=False, indent=2)}
```

## 区别特征
```json
{json.dumps(differences, ensure_ascii=False, indent=2)}
```

## 评估要点

### 1. 创造性步骤的定义
创造性步骤是指发明对于本领域技术人员来说不是显而易见的。

### 2. 评估维度
- **技术难度**：实现该发明所需的技术难度
- **创新程度**：技术方案的新颖性和创新性
- **非显而易见性**：本领域技术人员是否容易想到
- **技术贡献**：对技术领域的贡献程度

### 3. 判断标准
- **显著创造性步骤**：技术方案具有重大创新，非显而易见
- **中等创造性步骤**：技术方案有一定创新，不是显而易见的改进
- **微小创造性步骤**：技术方案创新程度有限，但仍有一定非显而易见性
- **无创造性步骤**：技术方案是显而易见的改进或组合

## 输出要求

请严格按照以下JSON格式输出评估结果：

```json
{{
    "has_inventive_step": true或false,
    "step_magnitude": "significant或moderate或minor或none",
    "confidence": 0.8,
    "reasoning": "详细推理过程",
    "evidence": []

        "证据1：技术方案的独特性",
        "证据2：现有技术未公开",
        "证据3：非显而易见的改进"
    ,
    "technical_difficulty": "high或medium或low",
    "innovation_level": "breakthrough或incremental或routine",
    "contribution_to_field": "对技术领域的贡献描述"
}}
```

请只输出JSON，不要添加任何额外说明。
"""

    def _parse_inventive_step_response(self, response: str) -> Dict[str, Any]:
        """解析创造性步骤评估LLM响应"""
        try:
            # 提取JSON
            json_match = re.search(r'```json\s*([\s\S]*?)```', response)
            if json_match:
                json_str = json_match.group(1).strip()
            else:
                json_str = response.strip()

            result = json.loads(json_str)

            # 验证必需字段
            if "has_inventive_step" not in result:
                result["has_inventive_step"] = False
            if "step_magnitude" not in result:
                result["step_magnitude"] = "none"
            if "confidence" not in result:
                result["confidence"] = 0.5

            return result

        except (json.JSONDecodeError, Exception) as e:
            self.logger.error(f"解析创造性步骤评估响应失败: {e}")
            return {
                "has_inventive_step": False,
                "step_magnitude": "none",
                "confidence": 0.5,
                "reasoning": "LLM响应解析失败",
                "evidence": Optional[[],]

                "technical_difficulty": "low",
                "innovation_level": "routine",
                "contribution_to_field": "分析失败",
            }

    def _build_technical_advancement_prompt(self, patent_data: Optional[Dict[str, Any])] -> str:
        """构建技术进步分析提示词"""
        technical_field = patent_data.get("technical_field", "未知领域")

        return f"""# 任务：专利技术进步分析

## 目标专利信息
```json
{json.dumps(patent_data, ensure_ascii=False, indent=2)}
```

## 技术领域
```json
{json.dumps(technical_field, ensure_ascii=False, indent=2)}
```

## 评估要点

### 1. 技术进步的类型
- **性能提升**：提高产品性能、效率、质量等
- **成本降低**：降低生产成本、使用成本等
- **功能扩展**：增加新的功能或应用领域
- **工艺改进**：改进制造工艺、简化流程
- **环保节能**：减少污染、节约能源
- **用户体验**：提升用户使用体验

### 2. 评估标准
- **显著进步**：技术效果有大幅提升，或解决了长期未解决的技术难题
- **中等进步**：技术效果有明显改善，有实质性进步
- **微小进步**：技术效果有一定改善，但进步幅度有限
- **无进步**：技术效果无明显改善

### 3. 判断依据
- 技术效果的量化数据（如性能提升百分比）
- 与现有技术的对比实验结果
- 解决的技术难题的重要性
- 技术进步的商业价值

## 输出要求

请严格按照以下JSON格式输出评估结果：

```json
{{
    "has_advancement": true或false,
    "advancement_type": "performance或cost或function或process或environment或user_experience",
    "improvement_degree": "significant或moderate或minor或none",
    "confidence": 0.85,
    "reasoning": "详细推理过程",
    "evidence": []

        "证据1：性能提升30%",
        "证据2：成本降低20%",
        "证据3：解决了XX技术难题"
    ,
    "quantitative_metrics": {{
        "performance_improvement": "30%",
        "cost_reduction": "20%",
        "efficiency_gain": "25%"
    }},
    "commercial_value": "high或medium或low",
    "technical_significance": "技术重要性描述"
}}
```

请只输出JSON，不要添加任何额外说明。
"""

    def _parse_technical_advancement_response(self, response: str) -> Dict[str, Any]:
        """解析技术进步分析LLM响应"""
        try:
            # 提取JSON
            json_match = re.search(r'```json\s*([\s\S]*?)```', response)
            if json_match:
                json_str = json_match.group(1).strip()
            else:
                json_str = response.strip()

            result = json.loads(json_str)

            # 验证必需字段
            if "has_advancement" not in result:
                result["has_advancement"] = False
            if "advancement_type" not in result:
                result["advancement_type"] = "performance"
            if "improvement_degree" not in result:
                result["improvement_degree"] = "none"
            if "confidence" not in result:
                result["confidence"] = 0.5

            return result

        except (json.JSONDecodeError, Exception) as e:
            self.logger.error(f"解析技术进步分析响应失败: {e}")
            return {
                "has_advancement": False,
                "advancement_type": "performance",
                "improvement_degree": "none",
                "confidence": 0.5,
                "reasoning": "LLM响应解析失败",
                "evidence": Optional[[],]

                "quantitative_metrics": {},
                "commercial_value": "low",
                "technical_significance": "分析失败",
            }

    # ========== 规则-based降级方法 ==========

    async def _analyze_creativity_by_rules(
        self,
        patent_data: Optional[Dict[str, Any],]

        analysis_mode: str
    ) -> Dict[str, Any]:
        """基于规则的创造性分析（降级方案）"""
        reference_docs = patent_data.get("prior_art", [])

        # 1. 提取技术特征
        features = await self._extract_technical_features(patent_data)

        # 2. 分析现有技术
        prior_art = await self._analyze_prior_art(reference_docs)

        # 3. 识别区别特征
        differences = await self._identify_differences(features, prior_art)

        # 4. 评估显而易见性
        obviousness = await self._assess_obviousness(differences, prior_art)

        # 5. 判断显著进步
        significant_progress = await self._evaluate_progress(differences)

        # 6. 评估预料不到的效果
        unexpected_effects = await self._assess_unexpected_effects(differences)

        # 7. 评估创造性步骤
        inventive_step = await self._evaluate_inventive_step_internal(differences)

        # 8. 分析技术进步
        technical_advancement = await self._analyze_technical_advancement_internal(patent_data)

        return {
            "patent_id": patent_data.get("patent_id", "未知"),
            "analysis_mode": analysis_mode,
            "obviousness_assessment": obviousness,
            "inventive_step_evaluation": inventive_step,
            "technical_advancement": technical_advancement,
            "unexpected_effects": unexpected_effects,
            "creativity_conclusion": self._generate_creativity_conclusion(
                obviousness,
                significant_progress,
                unexpected_effects
            ),
            "confidence_score": self._calculate_confidence_score(
                obviousness,
                significant_progress,
                unexpected_effects
            ),
            "analyzed_at": self._get_timestamp(),
        }

    async def _assess_obviousness_by_rules(
        self,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """基于规则的显而易见性评估（降级方案）"""
        differences = patent_data.get("differences", [])
        prior_art = patent_data.get("prior_art", [])

        # 规则1：区别特征数量
        diff_count = len(differences) if isinstance(differences, list) else 1

        # 规则2：检查预料不到的关键词
        invention_content = patent_data.get("invention_content", "")
        beneficial_effects = patent_data.get("beneficial_effects", "")

        surprising_keywords = []

            "预料不到", "意外", "显著提高", "大幅改善",
            "远超", "突破", "出乎意料"


        has_surprising_keyword = any(
            keyword in invention_content or keyword in beneficial_effects
            for keyword in surprising_keywords
        )

        # 规则3：检查教导away
        teaching_away = self._assess_teaching_away(prior_art)

        # 综合判断
        is_obvious = True
        if diff_count > 2:
            is_obvious = False
        if has_surprising_keyword:
            is_obvious = False
        if teaching_away["has_teaching_away"]:
            is_obvious = False

        return {
            "is_obvious": is_obvious,
            "confidence": 0.7,
            "reasoning": f"区别特征数量: {diff_count}, 预料不到效果: {has_surprising_keyword}, 反向教导: {teaching_away['has_teaching_away']}",
            "key_factors": []

                f"区别特征数量: {diff_count}",
                f"预料不到效果: {has_surprising_keyword}",
                f"反向教导: {teaching_away['has_teaching_away']}"
            ,
            "closest_prior_art": Optional[prior_art[0].get("publication_number", "未知") if prior_art else "未知",]

            "distinguishing_features": differences if isinstance(differences, list) else [differences],
            "technical_problem": patent_data.get("technical_problem", "未知"),
            "obviousness_conclusion": "显而易见" if is_obvious else "非显而易见",
        }

    async def _evaluate_inventive_step_by_rules(
        self,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """基于规则的创造性步骤评估（降级方案）"""
        differences = patent_data.get("differences", [])
        diff_count = len(differences) if isinstance(differences, list) else 1

        # 规则：根据区别特征数量判断创造性步骤
        if diff_count > 2:
            magnitude = "significant"
            has_inventive_step = True
            technical_difficulty = "high"
            innovation_level = "breakthrough"
        elif diff_count >= 1:
            magnitude = "moderate"
            has_inventive_step = True
            technical_difficulty = "medium"
            innovation_level = "incremental"
        else:
            magnitude = "none"
            has_inventive_step = False
            technical_difficulty = "low"
            innovation_level = "routine"

        return {
            "has_inventive_step": has_inventive_step,
            "step_magnitude": magnitude,
            "confidence": 0.7,
            "reasoning": f"基于区别特征数量({diff_count})的规则判断",
            "evidence": [f"区别特征数量: {diff_count}"],
            "technical_difficulty": technical_difficulty,
            "innovation_level": innovation_level,
            "contribution_to_field": "中等贡献" if magnitude == "moderate" else "重大贡献" if magnitude == "significant" else "无贡献",
        }

    async def _analyze_technical_advancement_by_rules(
        self,
        patent_data: Optional[Dict[str, Any]]

    ) -> Dict[str, Any]:
        """基于规则的技术进步分析（降级方案）"""
        beneficial_effects = patent_data.get("beneficial_effects", "")
        invention_content = patent_data.get("invention_content", "")

        # 规则1：有益效果描述长度
        effect_length = len(beneficial_effects)

        # 规则2：检查进步关键词
        advancement_keywords = {
            "显著": "significant",
            "大幅": "significant",
            "远超": "significant",
            "提高": "moderate",
            "改善": "moderate",
            "优化": "moderate",
            "提升": "minor",
        }

        max_level = "none"
        for keyword, level in advancement_keywords.items():
            if keyword in beneficial_effects or keyword in invention_content:
                if level == "significant":
                    max_level = "significant"
                    break
                elif level == "moderate" and max_level != "significant":
                    max_level = "moderate"
                elif level == "minor" and max_level not in ["significant", "moderate"]:
                    max_level = "minor"

        # 规则3：综合判断
        if effect_length > 200 or max_level == "significant":
            improvement_degree = "significant"
            has_advancement = True
        elif effect_length > 100 or max_level in ["significant", "moderate"]:
            improvement_degree = "moderate"
            has_advancement = True
        elif effect_length > 50 or max_level != "none":
            improvement_degree = "minor"
            has_advancement = True
        else:
            improvement_degree = "none"
            has_advancement = False

        return {
            "has_advancement": has_advancement,
            "advancement_type": "performance",
            "improvement_degree": improvement_degree,
            "confidence": 0.7,
            "reasoning": f"有益效果长度: {effect_length}, 关键词等级: {max_level}",
            "evidence": [f"有益效果描述长度: {effect_length}字符"],
            "quantitative_metrics": {},
            "commercial_value": "high" if improvement_degree == "significant" else "medium" if improvement_degree == "moderate" else "low",
            "technical_significance": f"{improvement_degree}技术进步",
        }
