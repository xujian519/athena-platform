#!/usr/bin/env python3
"""
语义推理引擎
Semantic Reasoning Engine

为法律和专利知识图谱提供高级语义推理和逻辑分析能力
"""

import asyncio
from core.async_main import async_main
import json
import logging
from core.logging_config import setup_logging
import sys
from dataclasses import dataclass
from datetime import datetime
from enum import Enum
from pathlib import Path
from typing import Any

# 添加项目路径
sys.path.append(str(Path(__file__).parent.parent.parent))

try:
    import numpy as np
    from sentence_transformers import SentenceTransformer
    TRANSFORMERS_AVAILABLE = True
except ImportError:
    print("⚠️ sentence-transformers未安装")
    TRANSFORMERS_AVAILABLE = False

try:
    import networkx as nx
    NETWORKX_AVAILABLE = True
except ImportError:
    print("⚠️ networkx未安装")
    NETWORKX_AVAILABLE = False

# 配置日志
logging.basicConfig(level=logging.INFO)
logger = setup_logging()

class ReasoningType(Enum):
    """推理类型"""
    RULE_BASED = "rule_based"           # 基于规则的推理
    SEMANTIC = "semantic"               # 语义推理
    CASE_BASED = "case_based"           # 基于案例的推理
    HYBRID = "hybrid"                   # 混合推理
    TEMPORAL = "temporal"               # 时间推理
    CAUSAL = "causal"                   # 因果推理

class ConfidenceLevel(Enum):
    """置信度级别"""
    VERY_HIGH = "very_high"             # 非常高 (>0.9)
    HIGH = "high"                       # 高 (0.7-0.9)
    MEDIUM = "medium"                   # 中等 (0.5-0.7)
    LOW = "low"                         # 低 (0.3-0.5)
    VERY_LOW = "very_low"               # 非常低 (<0.3)

@dataclass
class ReasoningResult:
    """推理结果"""
    reasoning_type: ReasoningType
    conclusion: str
    confidence: float
    evidence: list[str]
    reasoning_path: list[str]
    metadata: dict[str, Any]
    timestamp: datetime

@dataclass
class ReasoningRule:
    """推理规则"""
    rule_id: str
    name: str
    description: str
    conditions: list[str]
    conclusion_template: str
    confidence_base: float
    domain: str
    metadata: dict[str, Any]

class SemanticReasoningEngine:
    """语义推理引擎"""

    def __init__(self):
        self.embedding_model = None
        self.reasoning_graph = nx.DiGraph()
        self.reasoning_rules = {}
        self.case_database = {}
        self.ontology_concepts = {}

        # 初始化组件
        self._init_embedding_model()
        self._load_reasoning_rules()
        self._load_case_database()
        self._load_ontology()

    def _init_embedding_model(self) -> Any:
        """初始化嵌入模型 - 使用本地MPS优化模型"""
        if not TRANSFORMERS_AVAILABLE:
            logger.warning("⚠️ 嵌入模型不可用，使用基础推理")
            return

        try:
            import torch

            # 模型搜索顺序：优先MPS优化模型，然后普通本地模型
            model_paths = [
                "/Users/xujian/Athena工作平台/models/converted/BAAI/bge-m3",  # MPS优化模型
                "/Users/xujian/Athena工作平台/models/BAAI/bge-m3",            # 普通本地模型
            ]

            model_path = None
            for path in model_paths:
                if Path(path).exists():
                    model_path = path
                    break

            # 设备选择：优先MPS，然后CPU
            device = "cpu"
            if torch.backends.mps.is_available():
                device = "mps"
                logger.info("🔥 检测到MPS支持，启用MPS加速")
            elif torch.cuda.is_available():
                device = "cuda"
                logger.info("🔥 检测到CUDA支持，启用CUDA加速")

            # 加载模型
            if model_path:
                logger.info(f"📂 使用本地模型: {model_path}")
                self.embedding_model = SentenceTransformer(model_path, device=device)
            else:
                logger.info("📥 本地模型不存在，使用HuggingFace远程模型")
                self.embedding_model = SentenceTransformer('BAAI/BAAI/bge-m3', device=device)

            logger.info(f"✅ BGE嵌入模型加载成功，设备: {device}")

        except Exception as e:
            logger.error(f"❌ 嵌入模型初始化失败: {e}")
            self.embedding_model = None

