                conclusion_template="由于存在{行为}，造成{损害}，且存在因果关系，应当承担{责任}",
                confidence_base=0.8,
                domain="legal",
                metadata={"severity": "high", "legal_basis": "民法典第1165条"}
            ),

            # 合同效力推理
            "contract_validity": ReasoningRule(
