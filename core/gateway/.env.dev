# Athena API Gateway - Development Environment Variables

# 服务配置
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=5

# 认证配置
JWT_SECRET=athena-gateway-dev-jwt-secret-not-for-production-please-change
TOKEN_EXPIRE=24h
REFRESH_EXPIRE=168h
JWT_ISSUER=athena-gateway-dev

# 限流配置
LIMITER_ENABLED=true
LIMITER_REQUESTS_PER_MINUTE=5000
LIMITER_BURST=500
LIMITER_DISTRIBUTED_ENABLED=false

# 日志配置
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_OUTPUT=stdout

# 监控配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PATH=/metrics
TRACING_ENABLED=true
TRACING_PROVIDER=jaeger
TRACING_SAMPLE_RATE=1.0
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# 安全配置
CORS_ENABLED=true
CSRF_ENABLED=false
RATE_LIMIT_ENABLED=true
IP_WHITELIST_ENABLED=false

# 环境标识
ENV=development
CONFIG_PATH=./configs

# 数据库配置（如果需要）
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=athena_dev
DATABASE_PASSWORD=dev_password
DATABASE_NAME=athena_gateway_dev

# 服务发现配置
CONSUL_ENABLED=false
CONSUL_HOST=localhost
CONSUL_PORT=8500

# 健康检查配置
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=15s

# 性能调优
MAX_HEADER_BYTES=2097152
READ_TIMEOUT=60s
WRITE_TIMEOUT=60s

# 调试模式
DEBUG=true
PROFILE_ENABLED=true

# 热重载配置
AIR_ENABLED=true
AIR_TEMP_DIR=./tmp