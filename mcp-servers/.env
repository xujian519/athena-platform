# =============================================================================
# MCP服务配置 - 本地开发环境
# MCP Services Configuration - Local Development
# =============================================================================
# 注意: 此文件包含敏感信息，不应提交到版本控制
# 敏感密钥应存储在 .env.secrets 中
# =============================================================================

# GitHub API配置
GITHUB_TOKEN=your_github_token_here
GITHUB_API_URL=https://api.github.com

# 必应搜索API配置
BING_SEARCH_API_KEY=your_bing_search_api_key_here
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# PostgreSQL MCP配置
DATABASE_URL=postgresql://xiaonuo:your_password_here@localhost:5432/patent_legal_db

# Jina AI API配置
JINA_API_KEY=your_jina_api_key_here

# 学术搜索API配置
SCHOLAR_API_KEY=your_scholar_api_key_here

# 高德地图API配置
AMAP_API_KEY=your_amap_api_key_here
AMAP_SECRET_KEY=your_amap_secret_key_here

# 通用配置
MCP_LOG_LEVEL=INFO
REDIS_PASSWORD=your_redis_password_here

# Chrome MCP配置
CHROME_HEADLESS=true
