# 高德地图API配置
AMAP_API_KEY=your_amap_api_key_here
AMAP_SECRET_KEY=your_amap_secret_key_here
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT=30
AMAP_MAX_RETRIES=3
AMAP_RETRY_DELAY=1.0

# 限流配置
AMAP_RATE_LIMIT_RPM=100
AMAP_RATE_LIMIT_RPS=2

# 缓存配置
AMAP_CACHE_ENABLED=true
AMAP_CACHE_TTL=300

# MCP服务器配置
MCP_SERVER_NAME=gaode-mcp-server
MCP_SERVER_VERSION=1.0.0
MCP_SERVER_DESCRIPTION=高德地图MCP服务器 - 为AI模型提供地理空间智能服务
MCP_LOG_LEVEL=INFO
MCP_LOG_FILE=
MCP_HOST=localhost
MCP_PORT=8080
MCP_ALLOWED_ORIGINS=["*"]

# Redis配置 (如果使用Redis缓存)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 缓存策略
CACHE_STRATEGY=redis
MAX_CACHE_SIZE=1000