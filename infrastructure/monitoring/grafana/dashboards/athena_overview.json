{
  "dashboard": {
    "id": null,
    "title": "Athena AI平台总览",
    "tags": ["athena", "overview"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": [
        {
          "name": "environment",
          "type": "custom",
          "datasource": "Prometheus",
          "multi": false,
          "includeAll": false,
          "allValue": null,
          "current": {
            "text": "production",
            "value": "production"
          },
          "options": [
            {
              "text": "development",
              "value": "development"
            },
            {
              "text": "staging",
              "value": "staging"
            },
            {
              "text": "production",
              "value": "production"
            }
          ],
          "query": "label_values(up, environment)"
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "deployments",
          "datasource": "Prometheus",
          "enable": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "expr": "changes(deployment_timestamp[1h])",
          "titleFormat": "部署时间",
          "tags": [],
          "type": "tags"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "系统状态",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=~\"athena-.*\"}",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 0.5},
                {"color": "green", "value": 1}
              ]
            },
            "unit": "short"
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        }
      },
      {
        "id": 2,
        "title": "请求率",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{environment=\"$environment\"}[5m])) by (job)",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "请求/秒",
            "min": 0
          }
        ]
      },
      {
        "id": 3,
        "title": "错误率",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{environment=\"$environment\",status=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total{environment=\"$environment\"}[5m])) by (job)",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "错误率",
            "max": 1,
            "min": 0,
            "unit": "percentunit"
          }
        ]
      },
      {
        "id": 4,
        "title": "响应时间",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le, job))",
            "legendFormat": "{{job}} P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le, job))",
            "legendFormat": "{{job}} P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le, job))",
            "legendFormat": "{{job}} P99",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "响应时间(秒)",
            "min": 0
          }
        ]
      },
      {
        "id": 5,
        "title": "CPU使用率",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\",environment=\"$environment\"}[5m])) * 100)",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "CPU使用率(%)",
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        ]
      },
      {
        "id": 6,
        "title": "内存使用率",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "targets": [
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes{environment=\"$environment\"} / node_memory_MemTotal_bytes{environment=\"$environment\"})) * 100",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "内存使用率(%)",
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        ]
      },
      {
        "id": 7,
        "title": "磁盘使用率",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
        "targets": [
          {
            "expr": "(1 - (node_filesystem_avail_bytes{environment=\"$environment\",mountpoint=\"/\"} / node_filesystem_size_bytes{environment=\"$environment\",mountpoint=\"/\"})) * 100",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "磁盘使用率(%)",
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        ]
      },
      {
        "id": 8,
        "title": "数据库连接数",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "pg_stat_activity_count{environment=\"$environment\"}",
            "legendFormat": "活动连接",
            "refId": "A"
          },
          {
            "expr": "pg_settings_max_connections{environment=\"$environment\"}",
            "legendFormat": "最大连接",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "连接数",
            "min": 0
          }
        ]
      },
      {
        "id": 9,
        "title": "Redis内存使用",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "redis_memory_used_bytes{environment=\"$environment\"} / 1024 / 1024",
            "legendFormat": "已使用(MB)",
            "refId": "A"
          },
          {
            "expr": "redis_memory_max_bytes{environment=\"$environment\"} / 1024 / 1024",
            "legendFormat": "最大(MB)",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "内存(MB)",
            "min": 0
          }
        ]
      },
      {
        "id": 10,
        "title": "AI服务性能",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "rate(ai_predictions_total{environment=\"$environment\"}[5m])",
            "legendFormat": "预测率",
            "refId": "A"
          },
          {
            "expr": "ai_model_accuracy{environment=\"$environment\"}",
            "legendFormat": "模型准确率",
            "refId": "B"
          }
        ]
      },
      {
        "id": 11,
        "title": "容器状态",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "container_last_seen{name!=\"\",environment=\"$environment\"}",
            "legendFormat": "{{name}}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "container": "容器名",
                "name": "容器名",
                "instance": "节点"
              }
            }
          }
        ]
      }
    ]
  }
}