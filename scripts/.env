# ============================================================================
# Athena工作平台环境变量配置 - 自动更新
# ============================================================================
# 数据库密码（必需，至少8个字符）
DB_PASSWORD=athena_dev_password_2024_secure

# JWT密钥（必需，至少32个字符）
JWT_SECRET=athena_jwt_secret_key_for_development_min_32_chars_secure_2024
JWT_SECRET_KEY=athena_jwt_secret_key_for_development_min_32_chars_secure_2024

# Neo4j图数据库密码（必需）
NEO4J_PASSWORD=athena_neo4j_2024

# Redis密码（可选，生产环境建议设置）
REDIS_PASSWORD=None

# ============================================================================
# 数据库连接配置
# ============================================================================

# PostgreSQL数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=athena

# ============================================================================
# Neo4j图数据库配置
# ============================================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_DATABASE=neo4j

# ============================================================================
# Redis配置
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# Qdrant向量数据库配置
# ============================================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333

# ============================================================================
# 安全配置
# ============================================================================

# CORS允许的来源（开发环境）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# 允许的HTTP方法
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# 允许的请求头
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================================================
# 开发模式配置
# ============================================================================

DEBUG=true
TESTING=false

# ============================================================================
# 日志配置
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE_PATH=data/logs/athena.log
