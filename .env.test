# Athena 测试环境配置
# Test Environment Configuration

# =========================
# 数据库配置
# =========================
TEST_DATABASE_URL=postgresql://athena_test:athena_test_password_2024@localhost:5433/athena_test_db
TEST_DATABASE_HOST=localhost
TEST_DATABASE_PORT=5433
TEST_DATABASE_NAME=athena_test_db
TEST_DATABASE_USER=athena_test
TEST_DATABASE_PASSWORD=athena_test_password_2024

# =========================
# Redis 配置
# =========================
TEST_REDIS_URL=redis://localhost:6380/15
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6380
TEST_REDIS_DB=15

# =========================
# Qdrant 向量数据库配置
# =========================
TEST_QDRANT_URL=http://localhost:6334
TEST_QDRANT_HOST=localhost
TEST_QDRANT_PORT=6334
TEST_QDRANT_GRPC_PORT=6335
TEST_QDRANT_API_KEY=

# =========================
# Neo4j 图数据库配置
# =========================
TEST_NEO4J_URI=bolt://localhost:7688
TEST_NEO4J_HOST=localhost
TEST_NEO4J_PORT=7688
TEST_NEO4J_USER=neo4j
TEST_NEO4J_PASSWORD=athena_test_2024
TEST_NEO4J_DATABASE=neo4j

# =========================
# MinIO 对象存储配置
# =========================
TEST_MINIO_ENDPOINT=http://localhost:9001
TEST_MINIO_ACCESS_KEY=minioadmin
TEST_MINIO_SECRET_KEY=minioadmin123
TEST_MINIO_BUCKET=athena-test
TEST_MINIO_USE_SSL=false

# =========================
# 应用配置
# =========================
TEST_MODE=true
DEBUG=true
LOG_LEVEL=DEBUG
ENVIRONMENT=test

# =========================
# API 配置
# =========================
TEST_API_HOST=localhost
TEST_API_PORT=8000
TEST_API_BASE_URL=http://localhost:8000

# =========================
# 认证配置
# =========================
TEST_SECRET_KEY=test_secret_key_for_development_only
TEST_JWT_ALGORITHM=HS256
TEST_JWT_EXPIRATION_MINUTES=60
TEST_REFRESH_TOKEN_EXPIRATION_DAYS=7

# =========================
# 速率限制配置
# =========================
TEST_RATE_LIMIT_ENABLED=false
TEST_RATE_LIMIT_PER_MINUTE=1000

# =========================
# 缓存配置
# =========================
TEST_CACHE_ENABLED=true
TEST_CACHE_TTL_SECONDS=300

# =========================
# 向量配置
# =========================
TEST_EMBEDDING_MODEL=BAAI/bge-m3
TEST_EMBEDDING_DIMENSION=768
TEST_VECTOR_SIMILARITY_THRESHOLD=0.7

# =========================
# LLM 配置 (可选)
# =========================
# TEST_OPENAI_API_KEY=sk-test...
# TEST_OPENAI_MODEL=gpt-4
# TEST_OPENAI_TEMPERATURE=0.7
# TEST_OPENAI_MAX_TOKENS=2000

# =========================
# 外部服务配置 (可选)
# =========================
# TEST_EXTERNAL_API_KEY=your_test_api_key
# TEST_EXTERNAL_API_TIMEOUT=30

# =========================
# 测试超时配置
# =========================
TEST_DATABASE_TIMEOUT=30
TEST_REDIS_TIMEOUT=5
TEST_QDRANT_TIMEOUT=10
TEST_NEO4J_TIMEOUT=30
TEST_API_TIMEOUT=30

# =========================
# 并发测试配置
# =========================
TEST_MAX_CONCURRENT_REQUESTS=10
TEST_REQUEST_TIMEOUT=60

# =========================
# Mock 配置
# =========================
# 设置为true以使用mock而非真实服务
USE_MOCK_EXTERNAL_SERVICES=false
USE_MOCK_LLM=false
USE_MOCK_VECTOR=false
