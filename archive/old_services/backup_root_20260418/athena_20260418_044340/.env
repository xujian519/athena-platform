# ============================================================================
# Athena工作平台环境变量配置示例
# ============================================================================
# 复制此文件为 .env 并填写实际配置值
# 注意：.env 文件包含敏感信息，不应提交到版本控制系统
# ============================================================================

# ============================================================================
# 🔐 安全配置 - 生产环境必需
# ============================================================================

# 数据库密码（必需，至少8个字符）
# 生成命令: openssl rand -base64 16
DB_PASSWORD=athena_dev_password_2024_secure

# JWT密钥（必需，至少32个字符）
# 生成命令: openssl rand -hex 32
JWT_SECRET=athena_jwt_secret_key_for_development_min_32_chars_secure_2024
JWT_SECRET_KEY=athena_jwt_secret_key_for_development_min_32_chars_secure_2024

# Neo4j图数据库密码（必需）
NEO4J_PASSWORD=athena_neo4j_2024

# Redis密码（可选，生产环境建议设置）
REDIS_PASSWORD=redis123

# ============================================================================
# 数据库连接配置
# ============================================================================

# PostgreSQL数据库（已支持密码环境变量）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=athena

# ============================================================================
# 专利数据库配置
# ============================================================================

# 专利专用数据库配置（200G真实专利数据）
PATENT_DB_HOST=localhost
PATENT_DB_PORT=5432
PATENT_DB_NAME=patent_db
PATENT_DB_USER=postgres
PATENT_DB_PASSWORD=athena_dev_password_2024_secure
PATENT_DB_SCHEMA=public

# 专利数据库连接池配置
PATENT_DB_POOL_SIZE=10

# ============================================================================
# 法律世界模型数据库配置 (Legal World Model)
# ============================================================================

# 法律世界模型PostgreSQL数据库（8.2GB法律知识库）
LWM_DB_HOST=localhost
LWM_DB_PORT=5432
LWM_DB_NAME=legal_world_model
LWM_DB_USER=postgres
LWM_DB_PASSWORD=athena_dev_password_2024_secure

# 法律世界模型数据概览:
# - legal_articles_v2_embeddings: 4GB (法律条文向量)
# - patent_invalid_embeddings: 1.8GB (专利无效向量)
# - patent_invalid_decisions: 898MB (无效决定文书)
# - legal_articles_v2: 323MB (法律条文原文)
# - judgment相关表: 判决文书和实体
# - patent_judgment相关表: 专利判决案例
PATENT_DB_MAX_OVERFLOW=20
PATENT_DB_POOL_TIMEOUT=30
PATENT_DB_POOL_RECYCLE=3600

# 专利表配置
PATENTS_TABLE=patents
PATENTS_FULLTEXT_INDEX=patents_ft_idx
PATENTS_VECTOR_TABLE=patent_vectors
PATENTS_CITATIONS_TABLE=patent_citations
PATENTS_IPC_TABLE=patent_ipc

# 专利搜索配置
PATENT_SEARCH_LIMIT=20
PATENT_SEARCH_MAX_LIMIT=100
PATENT_SEARCH_HIGHLIGHT=true
PATENT_RANK_TITLE_WEIGHT=2.0
PATENT_RANK_ABSTRACT_WEIGHT=1.5
PATENT_RANK_CLAIMS_WEIGHT=1.0
PATENT_RANK_DESCRIPTION_WEIGHT=0.8
PATENT_SEARCH_LANGUAGES=chinese,english
PATENT_SEARCH_MIN_QUERY_LENGTH=2

# 如果需要完整的连接字符串（不推荐，密码部分已使用环境变量）
# DATABASE_URL=postgresql://postgres:your_secure_database_password_here@localhost:5432/athena

# ============================================================================
# Neo4j图数据库配置
# ============================================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j

# ============================================================================
# Redis配置
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Qdrant向量数据库配置
# ============================================================================

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================================================
# AI模型API密钥
# ============================================================================

# OpenAI API密钥（可选）
OPENAI_API_KEY=sk-your-openai-api-key-here

# 智谱AI API密钥（可选）
ZHIPU_API_KEY=your-zhipu-ai-api-key-here

# DeepSeek API密钥（可选）
DEEPSEEK_API_KEY=sk-b8f452a470e84a26a75f33474e5d7c08

# ============================================================================
# MCP服务配置
# ============================================================================

# 高德地图API密钥
# 获取地址: https://console.amap.com/dev/key/app
AMAP_API_KEY=your_amap_api_key_here

# MCP日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
MCP_LOG_LEVEL=INFO

# ========================================
# 通信服务配置
# ========================================

# 消息队列最大大小
COMMUNICATION_MAX_QUEUE_SIZE=10000

# 最大连接数
COMMUNICATION_MAX_CONNECTIONS=1000

# 消息超时时间（秒）
COMMUNICATION_MESSAGE_TIMEOUT=30

# ========================================
# 数据库配置
# ========================================

# PostgreSQL连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/athena

# Redis连接字符串
REDIS_URL=redis://localhost:6379/0

# ========================================
# 监控配置
# ========================================

# Prometheus指标端口
PROMETHEUS_PORT=9090

# Grafana端口
GRAFANA_PORT=3000

# ========================================
# 日志配置
# ========================================

# 日志级别
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=data/logs/athena.log

# ========================================
# AI模型配置
# ========================================

# OpenAI API密钥
OPENAI_API_KEY=your_openai_api_key_here

# 智谱AI API密钥
ZHIPU_API_KEY=your_zhipu_api_key_here

# BGE-M3 嵌入模型配置 (MLX 4-bit 量化版, 统一 Embedding 服务)
BGE_M3_MODEL_PATH=/Users/xujian/.models/bge-m3-mlx-4bit
BGE_M3_MODEL_NAME=bge-m3-mlx-4bit
BGE_M3_DIMENSION=1024
# MLX Embedding 服务 (OpenAI 兼容 API, 由 mlx-server.sh 管理)
MLX_EMBEDDING_URL=http://127.0.0.1:8766/v1/embeddings

# ========================================
# 多模态模型配置 (8009端口常驻)
# ========================================

# 多模态模型 - Gemma 4 (通过8009端口提供OpenAI兼容API)
MULTIMODAL_MODEL_URL=http://127.0.0.1:8009
MULTIMODAL_MODEL_NAME=gemma-4-e2b-it-4bit
MULTIMODAL_API_KEY=xj781102@

# ========================================
# Rerank模型配置 (8009端口常驻)
# ========================================

# Rerank模型 - Jina Reranker v3 MLX
RERANK_MODEL_URL=http://127.0.0.1:8009
RERANK_MODEL_NAME=jina-reranker-v3-mlx
RERANK_API_KEY=xj781102@

# ========================================
# MinerU文档解析服务配置 (端口7860)
# ========================================

# MinerU服务地址
MINERU_BASE_URL=http://127.0.0.1:7860

# 解析后端: pipeline / hybrid-auto-engine
MINERU_BACKEND=pipeline

# 解析方法: auto / txt / ocr
MINERU_PARSE_METHOD=auto

# 默认语言
MINERU_DEFAULT_LANGUAGE=ch

# 功能开关
MINERU_TABLE_ENABLE=true
MINERU_FORMULA_ENABLE=true
MINERU_RETURN_MD=true

# 请求超时（秒）
MINERU_REQUEST_TIMEOUT=300

# 降级策略
MINERU_AUTO_FALLBACK_ENABLED=true
MINERU_FALLBACK_TO_TESSERACT=true

# ========================================
# 安全配置
# ========================================

# JWT密钥（已在上方配置，此处保留注释）

# 加密密钥
ENCRYPTION_KEY=your_encryption_key_here

# CORS允许的来源（逗号分隔）
# ⚠️  生产环境必须配置具体域名，不要使用通配符
# 开发环境示例:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080
# 生产环境示例:
# ALLOWED_ORIGINS=https://athena.example.com,https://app.athena.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# CORS允许的HTTP方法（逗号分隔）
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# CORS允许的请求头（逗号分隔，* 表示允许所有）
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# CORS预检请求缓存时间（秒）
CORS_MAX_AGE=3600

# 信任的主机（逗号分隔，用于防止Host头攻击）
# 开发环境:
# ALLOWED_HOSTS=localhost,127.0.0.1
# 生产环境:
# ALLOWED_HOSTS=athena.example.com,app.athena.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# 开发模式配置
# ========================================

# 调试模式
DEBUG=true

# 测试模式
TESTING=false
