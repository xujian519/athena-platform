"""

    def _parse_claims_review_response(self, response: str) -> Dict[str, Any]:
        """解析权利要求审查LLM响应"""
        try:
            # 提取JSON
            json_match = re.search(r'```json\s*([\s\S]*?)```', response)
            if json_match:
                json_str = json_match.group(1).strip()
