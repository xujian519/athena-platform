# ==============================================================================
# LLM模型环境变量配置模板
# Athena平台 - 统一LLM层
# ==============================================================================
#
# 使用说明:
# 1. 复制此文件为 .env 或 llm_models.env
# 2. 填写您拥有的API密钥
# 3. 将不需要使用的模型的API密钥留空或注释掉
#
# 注意: 请妥善保管API密钥，不要提交到版本控制系统！
# ==============================================================================

# ------------------------------------------------------------------------------
# 国内模型配置
# ------------------------------------------------------------------------------

# 智谱AI (GLM-4.7系列)
# 获取地址: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# DeepSeek (深度求索)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问 (阿里云)
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ------------------------------------------------------------------------------
# 模型选择配置
# ------------------------------------------------------------------------------

# 默认推理模型 (用于复杂分析任务)
DEFAULT_REASONING_MODEL=glm-4-plus
# 可选: glm-4-plus, deepseek-reasoner

# 默认对话模型 (用于日常对话)
DEFAULT_CHAT_MODEL=deepseek-chat
# 可选: deepseek-chat

# 默认编程模型 (用于代码生成)
DEFAULT_CODE_MODEL=deepseek-coder-v2
# 可选: deepseek-coder-v2, starcoder2-15b

# 默认多模态模型 (用于图像分析)
DEFAULT_MULTIMODAL_MODEL=qwen-vl-max
# 可选: qwen-vl-max, qwen-vl-plus

# ------------------------------------------------------------------------------
# 高级配置
# ------------------------------------------------------------------------------

# 模型选择策略
# 可选: cost_optimized, performance_optimized, quality_optimized, balanced, local_first
MODEL_SELECTION_STRATEGY=balanced

# 成本预算 (元/月)
COST_BUDGET_MONTHLY=100.0

# 启用本地模型优先
LOCAL_MODEL_FIRST=false

# 响应缓存TTL (秒)
RESPONSE_CACHE_TTL=3600

# ------------------------------------------------------------------------------
# 本地模型配置 (如果使用本地部署)
# ------------------------------------------------------------------------------

# StarCoder2本地模型路径
STARCODER2_MODEL_PATH=/models/starcoder2-15b

# Qwen2.5本地模型路径
QWEN_LOCAL_MODEL_PATH=/models/qwen2.5-7b-instruct-gguf

# 本地模型设备 (auto/cuda/cpu)
LOCAL_MODEL_DEVICE=auto

# ------------------------------------------------------------------------------
# 开发/调试配置
# ------------------------------------------------------------------------------

# 启用详细日志
LLM_DEBUG=false

# 启用模型性能监控
ENABLE_MODEL_MONITORING=true

# 启用成本追踪
ENABLE_COST_TRACKING=true

# ------------------------------------------------------------------------------
# 功能开关
# ------------------------------------------------------------------------------

# 启用流式输出
ENABLE_STREAMING=true

# 启用函数调用
ENABLE_FUNCTION_CALLING=true

# 启用思考模式
ENABLE_THINKING_MODE=false

# ------------------------------------------------------------------------------
# 安全配置
# ------------------------------------------------------------------------------

# 启用内容过滤
ENABLE_CONTENT_FILTER=true

# 最大请求重试次数
MAX_REQUEST_RETRIES=3

# 请求超时时间 (秒)
REQUEST_TIMEOUT=120

# ------------------------------------------------------------------------------
# 性能优化配置
# ------------------------------------------------------------------------------

# 并发请求数量
MAX_CONCURRENT_REQUESTS=5

# 批处理大小
BATCH_SIZE=4

# 预加载模型
PRELOAD_MODELS=true

# ------------------------------------------------------------------------------
# 监控和告警配置
# ------------------------------------------------------------------------------

# Prometheus指标端口
PROMETHEUS_PORT=9090

# 成本告警阈值 (元)
COST_ALERT_THRESHOLD=50.0

# 延迟告警阈值 (毫秒)
LATENCY_ALERT_THRESHOLD=5000

# ------------------------------------------------------------------------------
# 配置完成提示
# ------------------------------------------------------------------------------
#
# 配置完成后，请运行以下命令测试连接:
# python -m core.llm.test_llm_integration
#
# 查看可用模型:
# python -m core.llm.list_available_models
#
# 生成模型配置报告:
# python -m core.llm.generate_model_report
