# Athena工作平台 - 生产环境配置
# Production Environment Configuration
# Created: 2026-02-24

# ========== 环境类型 ==========
ENVIRONMENT=production
NODE_ENV=production
DEBUG=false

# ========== 服务端口 ==========
GATEWAY_PORT=8005
GATEWAY_HOST=0.0.0.0
WS_PORT=8006

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=/Users/xujian/Athena工作平台/logs
LOG_ROTATION=true
LOG_MAX_BYTES=100MB
LOG_BACKUP_COUNT=10

# ========== LLM配置 ==========
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7

# ========== 智能体配置 ==========
XIAONUO_ENABLED=true
PLANNER_ENABLED=true
PLANNER_PHASE_2_ENABLED=true
PLANNER_PHASE_3_ENABLED=true

# ========== 性能配置 ==========
MAX_CONCURRENT_REQUESTS=100
MAX_WORKERS=4
CACHE_ENABLED=true

# ========== 安全配置 ==========
CORS_ORIGINS=https://athena.yunpat.com
JWT_EXPIRATION_HOURS=24
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ========== 监控配置 ==========
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
HEALTH_CHECK_ENABLED=true
