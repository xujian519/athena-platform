{
  "dashboard": {
    "title": "Athena Gateway WebSocket控制平面",
    "tags": ["athena", "gateway", "websocket"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "连接数统计",
        "type": "graph",
        "targets": [
          {
            "expr": "websocket_sessions_total",
            "legendFormat": "总会话数",
            "refId": "A"
          },
          {
            "expr": "websocket_active_sessions",
            "legendFormat": "活跃会话",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "会话数",
            "min": 0
          }
        ]
      },
      {
        "id": 2,
        "title": "消息吞吐量",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(websocket_messages_total[1m])",
            "legendFormat": "消息速率",
            "refId": "A"
          },
          {
            "expr": "sum(rate(websocket_messages_total[5m]))",
            "legendFormat": "5分钟平均",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "消息/秒",
            "min": 0
          }
        ]
      },
      {
        "id": 3,
        "title": "消息延迟",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, websocket_message_duration_seconds)",
            "legendFormat": "P50延迟",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, websocket_message_duration_seconds)",
            "legendFormat": "P95延迟",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, websocket_message_duration_seconds)",
            "legendFormat": "P99延迟",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "延迟（秒）",
            "min": 0
          }
        ]
      },
      {
        "id": 4,
        "title": "错误率",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(websocket_errors_total[1m])",
            "legendFormat": "错误速率",
            "refId": "A"
          },
          {
            "expr": "rate(websocket_errors_total[1m]) / rate(websocket_messages_total[1m])",
            "legendFormat": "错误率",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "错误率",
            "min": 0,
            "max": 1,
            "format": "percentunit"
          }
        ]
      },
      {
        "id": 5,
        "title": "Agent任务统计",
        "type": "graph",
        "targets": [
          {
            "expr": "agent_tasks_total{agent=\"xiaona\"}",
            "legendFormat": "小娜任务",
            "refId": "A"
          },
          {
            "expr": "agent_tasks_total{agent=\"xiaonuo\"}",
            "legendFormat": "小诺任务",
            "refId": "B"
          },
          {
            "expr": "agent_tasks_total{agent=\"yunxi\"}",
            "legendFormat": "云希任务",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "任务数",
            "min": 0
          }
        ]
      },
      {
        "id": 6,
        "title": "系统资源使用",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024",
            "legendFormat": "内存（MB）",
            "refId": "A"
          },
          {
            "expr": "rate(process_cpu_seconds_total[1m]) * 100",
            "legendFormat": "CPU使用率",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "资源使用",
            "min": 0
          }
        ]
      }
    ]
  }
}
