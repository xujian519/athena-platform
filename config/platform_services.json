{
  "platform": {
    "name": "Athena工作平台",
    "version": "2.0.0",
    "environment": "production",
    "owner": "Athena & 小诺",
    "description": "企业级智能工作平台"
  },
  "services": [
    {
      "id": "hybrid-crawler",
      "name": "混合爬虫服务",
      "description": "集成了内部爬虫、Crawl4AI和FireCrawl的智能爬虫系统",
      "type": "microservice",
      "status": "active",
      "owner": "Athena & 小诺",
      "version": "2.0.0",
      "endpoint": {
        "protocol": "http",
        "host": "localhost",
        "port": 8002,
        "base_path": "/",
        "health_check": "/health",
        "metrics": "/metrics",
        "docs": "/docs"
      },
      "api_gateway": {
        "enabled": true,
        "route": "/api/v2/crawler",
        "strip_prefix": false
      },
      "dependencies": [
        {
          "name": "firecrawl-api",
          "type": "external",
          "required": true,
          "description": "FireCrawl商业爬虫服务"
        },
        {
          "name": "crawl4ai",
          "type": "library",
          "required": true,
          "description": "Crawl4AI AI增强爬虫库"
        }
      ],
      "configuration": {
        "config_file": "config/platform_crawler_config.json",
        "env_file": ".env.platform",
        "required_env_vars": [
          "FIRECRAWL_API_KEY"
        ],
        "optional_env_vars": [
          "CRAWL4AI_LLM_API_KEY",
          "CRAWLER_MONTHLY_LIMIT",
          "ALERT_WEBHOOK_URL"
        ]
      },
      "resources": {
        "cpu": "low",
        "memory": "medium",
        "storage": "medium",
        "network": "medium"
      },
      "scaling": {
        "min_instances": 1,
        "max_instances": 4,
        "auto_scaling": false,
        "target_cpu": 70,
        "target_memory": 80
      },
      "monitoring": {
        "enabled": true,
        "metrics": true,
        "logging": true,
        "tracing": false,
        "alerting": true,
        "health_check": {
          "enabled": true,
          "interval": 30,
          "timeout": 10,
          "unhealthy_threshold": 3,
          "healthy_threshold": 2
        }
      },
      "security": {
        "authentication": {
          "enabled": false,
          "type": "none"
        },
        "authorization": {
          "enabled": false,
          "type": "none"
        },
        "encryption": {
          "transit": false,
          "at_rest": false
        },
        "rate_limiting": {
          "enabled": true,
          "requests_per_minute": 1000
        }
      },
      "backup": {
        "enabled": true,
        "schedule": "daily",
        "retention_days": 7,
        "include": [
          "config/",
          "data/"
        ]
      },
      "deployment": {
        "method": "script",
        "script": "scripts/platform_crawler_manager.sh",
        "pre_deployment_checks": [
          "environment_validation",
          "dependency_check",
          "configuration_validation"
        ],
        "post_deployment_checks": [
          "health_check",
          "api_test",
          "integration_test"
        ]
      },
      "tags": [
        "crawler",
        "data-collection",
        "ai-powered",
        "hybrid",
        "production",
        "managed-by-athena"
      ]
    }
  ],
  "service_groups": [
    {
      "name": "data-services",
      "description": "数据处理和采集服务组",
      "services": ["hybrid-crawler"],
      "load_balancer": {
        "enabled": false,
        "algorithm": "round_robin"
      }
    }
  ],
  "platform_features": {
    "service_discovery": {
      "enabled": true,
      "type": "static"
    },
    "load_balancing": {
      "enabled": false,
      "global_algorithm": "round_robin"
    },
    "api_gateway": {
      "enabled": true,
      "version": "2.0",
      "config_file": "config/api_gateway_crawler.json"
    },
    "monitoring": {
      "enabled": true,
      "prometheus": {
        "enabled": true,
        "config_file": "config/monitoring_crawler.yaml"
      },
      "grafana": {
        "enabled": false,
        "dashboard_url": ""
      }
    },
    "logging": {
      "enabled": true,
      "centralized": true,
      "format": "json",
      "level": "info"
    },
    "security": {
      "ssl": {
        "enabled": false,
        "cert_file": "",
        "key_file": ""
      },
      "firewall": {
        "enabled": false,
        "rules": []
      }
    },
    "backup": {
      "enabled": true,
      "schedule": "daily",
      "storage": "local"
    }
  },
  "environment_variables": {
    "platform": {
      "PLATFORM_NAME": "Athena工作平台",
      "PLATFORM_VERSION": "2.0.0",
      "PLATFORM_ENVIRONMENT": "production",
      "PLATFORM_OWNER": "Athena & 小诺"
    },
    "service_specific": {
      "CRAWLER_SERVICE_NAME": "platform-hybrid-crawler",
      "CRAWLER_SERVICE_PORT": 8002,
      "CRAWLER_SERVICE_HOST": "0.0.0.0"
    }
  },
  "external_integrations": [
    {
      "name": "firecrawl",
      "type": "api",
      "description": "FireCrawl商业爬虫服务",
      "api_key_env": "FIRECRAWL_API_KEY",
      "base_url": "https://api.firecrawl.dev/v1",
      "status": "configured"
    },
    {
      "name": "openai",
      "type": "api",
      "description": "OpenAI API - 用于Crawl4AI LLM功能",
      "api_key_env": "CRAWL4AI_LLM_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "status": "optional"
    }
  ],
  "last_updated": "2025-12-11T21:45:00Z",
  "updated_by": "Athena & 小诺"
}