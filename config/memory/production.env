# ============================================================================
# Athena记忆模块 - 生产环境配置
# ============================================================================
# 此文件包含记忆模块连接真实数据库和基础设施所需的所有配置
#
# 使用方法:
#   1. 复制此文件为 .env.production
#   2. 填写实际的数据库连接信息
#   3. 运行: source .env.production
#   4. 启动服务
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL数据库配置 (必需)
# ----------------------------------------------------------------------------
# 记忆系统使用PostgreSQL存储持久化记忆数据
# 需要安装pgvector扩展支持向量搜索

# PostgreSQL连接信息
export MEMORY_DB_HOST=localhost
export MEMORY_DB_PORT=5432
export MEMORY_DB_NAME=athena_memory
export MEMORY_DB_USER=athena_admin
export MEMORY_DB_PASSWORD=your_secure_password_here

# PostgreSQL连接池配置
export MEMORY_DB_POOL_MIN=5
export MEMORY_DB_POOL_MAX=20
export MEMORY_DB_TIMEOUT=60

# ----------------------------------------------------------------------------
# Redis缓存配置 (推荐)
# ----------------------------------------------------------------------------
# Redis用于缓存热点记忆，提升查询性能
# 如果不可用，系统会降级运行但性能会下降

# Redis连接信息
export REDIS_HOST=localhost
export REDIS_PORT=6379
export REDIS_DB=0
export REDIS_PASSWORD=your_redis_password_here

# Redis缓存TTL配置 (秒)
export REDIS_TTL_AGENT_STATS=300      # 智能体统计缓存: 5分钟
export REDIS_TTL_SEARCH_RESULTS=60    # 搜索结果缓存: 1分钟
export REDIS_TTL_MEMORY_DATA=180      # 记忆数据缓存: 3分钟
export REDIS_TTL_HOT_MEMORY=600       # 热记忆缓存: 10分钟

# ----------------------------------------------------------------------------
# Qdrant向量数据库配置 (推荐)
# ----------------------------------------------------------------------------
# Qdrant用于向量相似度搜索
# 如果不可用，向量搜索功能将无法使用

# Qdrant连接信息
export QDRANT_HOST=localhost
export QDRANT_PORT=6333
export QDRANT_API_KEY=your_qdrant_api_key_here  # 如果需要认证

# Qdrant集合配置
export QDRANT_COLLECTION_MAIN=athena_memories
export QDRANT_COLLECTION_EPISODIC=episodic_memories
export QDRANT_COLLECTION_SEMANTIC=semantic_memories

# ----------------------------------------------------------------------------
# OpenAI API配置 (可选)
# ----------------------------------------------------------------------------
# 如果不使用本地嵌入模型，可以使用OpenAI API
# 需要安装: pip install openai

# OpenAI API密钥
export OPENAI_API_KEY=your_openai_api_key_here

# OpenAI嵌入模型选择
# 可选值: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
export OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------------------------------------------------------
# 本地嵌入模型配置 (推荐)
# ----------------------------------------------------------------------------
# 使用本地BGE-M3模型，免费且高质量
# 需要安装: pip install sentence-transformers torch

# 启用真实嵌入模型 (默认: true)
export ENABLE_REAL_EMBEDDINGS=true

# 本地模型路径 (可选，用于自定义模型位置)
export BGE_M3_MODEL_PATH=/opt/models/BAAI/bge-m3

# ----------------------------------------------------------------------------
# 知识图谱配置 (可选)
# ----------------------------------------------------------------------------
# 如果使用知识图谱增强记忆搜索

export KNOWLEDGE_GRAPH_URL=http://localhost:8080
export KNOWLEDGE_GRAPH_HEALTH_ENDPOINT=/health

# ----------------------------------------------------------------------------
# 日志配置
# ----------------------------------------------------------------------------

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
export LOG_LEVEL=INFO

# 日志文件路径
export LOG_FILE_PATH=/var/log/athena/memory_system.log

# ----------------------------------------------------------------------------
# 性能配置
# ----------------------------------------------------------------------------

# 热记忆缓存限制 (每个智能体)
export HOT_CACHE_LIMIT=50

# 批量操作大小
export BATCH_SIZE=100

# 查询超时时间 (秒)
export QUERY_TIMEOUT=30

# ----------------------------------------------------------------------------
# 生产环境安全设置
# ----------------------------------------------------------------------------

# 生产环境标识
export ENVIRONMENT=production

# 启用详细错误信息 (生产环境建议设为false)
export DEBUG_MODE=false

# CORS设置 (如果提供Web API)
export CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ----------------------------------------------------------------------------
# Docker部署配置
# ----------------------------------------------------------------------------
# 如果使用Docker Compose部署，部分配置会被docker-compose.yml覆盖

# Docker网络名称
export DOCKER_NETWORK=athena_network

# 数据持久化路径
export DATA_PATH=./data/memory

# 备份路径
export BACKUP_PATH=./backups/memory
