# Athena工作平台环境配置模板
# 复制此文件为 .env 并修改相应配置

# =============================================================================
# 基础环境配置
# =============================================================================

# 环境类型: development, testing, staging, production
ATHENA_ENV=development

# Athena平台根目录 - 部署时必须修改
ATHENA_HOME=/Users/xujian/Athena工作平台

# Python路径
PYTHONPATH=${ATHENA_HOME}

# =============================================================================
# 数据库配置
# =============================================================================

# PostgreSQL数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=athena_db
DB_USER=athena_user
DB_PASSWORD=your_secure_db_password

# 数据库连接字符串
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# 复制配置（如使用主从复制）
REPLICATION_HOST=${DB_HOST}
REPLICATION_PORT=${DB_PORT}
REPLICATION_USER=replicator
REPLICATION_PASSWORD=your_replication_password

# =============================================================================
# 缓存和存储配置
# =============================================================================

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# 向量数据库配置
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=6333
VECTOR_DB_API_KEY=your_vector_db_api_key

# =============================================================================
# AI模型配置
# =============================================================================

# GLM模型配置
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# OpenAI配置（可选）
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# 本地模型路径
MODEL_PATH=${ATHENA_HOME}/models
BERT_MODEL_PATH=${MODEL_PATH}/chinese_bert
BGE_MODEL_PATH=${MODEL_PATH}/bge-large-zh-v1.5

# =============================================================================
# 身份档案配置
# =============================================================================

# 身份档案存储路径
IDENTITY_STORAGE_PATH=${ATHENA_HOME}/data/identity_permanent_storage

# 小诺配置路径
XIANONU_CONFIG_PATH=${ATHENA_HOME}/config/identity/xiaonuo_pisces_princess.json

# =============================================================================
# 安全配置
# =============================================================================

# JWT配置
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# API安全
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=http://localhost:3000,http://localhost:8020

# =============================================================================
# 监控和日志配置
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志路径
LOG_PATH=${ATHENA_HOME}/logs

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=your_grafana_password

# 告警配置
ALERT_WEBHOOK_URL=your_webhook_url
ALERT_EMAIL=your_alert_email@example.com

# =============================================================================
# 服务端口配置
# =============================================================================

# YunPat Agent服务
YUNPAT_PORT=8020
YUNPAT_HOST=0.0.0.0

# 小诺·双鱼公主服务
XIANUO_PORT=8021
XIANUO_HOST=0.0.0.0

# 爬虫服务
CRAWLER_PORT=8022
CRAWLER_HOST=0.0.0.0

# =============================================================================
# 文件存储配置
# =============================================================================

# 上传文件路径
UPLOAD_PATH=${ATHENA_HOME}/uploads
TEMP_PATH=${ATHENA_HOME}/temp
CACHE_PATH=${ATHENA_HOME}/cache

# 文件大小限制（字节）
MAX_UPLOAD_SIZE=104857600  # 100MB

# =============================================================================
# 外部服务配置
# =============================================================================

# 高德地图API（如使用）
AMAP_API_KEY=your_amap_api_key

# 邮件服务配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# =============================================================================
# 开发和调试配置
# =============================================================================

# 调试模式
DEBUG=true

# 性能分析
PROFILING_ENABLED=false

# 测试模式
TEST_MODE=false

# Mock模式（用于测试）
MOCK_EXTERNAL_APIS=false

# =============================================================================
# 部署特定配置
# =============================================================================

# Docker配置
DOCKER_REGISTRY=your-registry.com
DOCKER_TAG=latest

# Kubernetes配置
K8S_NAMESPACE=athena
K8S_SERVICE_NAME=athena-platform

# SSL/TLS配置
SSL_CERT_PATH=${ATHENA_HOME}/config/ssl/cert.pem
SSL_KEY_PATH=${ATHENA_HOME}/config/ssl/key.pem

# =============================================================================
# 备份和恢复配置
# =============================================================================

# 备份路径
BACKUP_PATH=${ATHENA_HOME}/backups

# 自动备份（启用/禁用）
AUTO_BACKUP_ENABLED=true

# 备份频率（小时）
BACKUP_INTERVAL_HOURS=24

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# =============================================================================
# 消息队列配置
# =============================================================================

# RabbitMQ配置（如使用）
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# =============================================================================
# 性能优化配置
# =============================================================================

# 数据库连接池
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# 缓存配置
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# 并发配置
MAX_WORKERS=4
MAX_CONNECTIONS=1000

# =============================================================================
# 扩展功能配置
# =============================================================================

# 知识图谱配置
KNOWLEDGE_GRAPH_ENABLED=true
KNOWLEDGE_GRAPH_PATH=${ATHENA_HOME}/data/knowledge_graph

# 浏览器自动化配置
BROWSER_AUTOMATION_ENABLED=true
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# MCP服务配置
MCP_ENABLED=true
MCP_SERVERS_PATH=${ATHENA_HOME}/mcp-servers
MCP_LOG_LEVEL=INFO

# =============================================================================
# 微服务配置（服务间通信）
# =============================================================================

# YunPat Agent服务配置
YUNPAT_AGENT_URL=http://localhost:8020
YUNPAT_AGENT_NAME=YunPat (云熙) Agent
YUNPAT_DEFAULT_LLM=deepseek-chat
YUNPAT_TEMPERATURE=0.7
YUNPAT_MAX_TOKENS=2000

# Athena内部服务URL
ATHENA_MAIN_URL=http://localhost:8000
ATHENA_MEMORY_URL=http://localhost:8008
ATHENA_IDENTITY_URL=http://localhost:8010
ATHENA_KNOWLEDGE_URL=http://localhost:8009

# =============================================================================
# 外部API密钥配置（MCP服务）
# =============================================================================

# GitHub API
GITHUB_TOKEN=your_github_token_here
GITHUB_API_URL=https://api.github.com

# 必应搜索API
BING_SEARCH_API_KEY=your_bing_search_api_key_here
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Jina AI API
JINA_API_KEY=your_jina_api_key_here

# 学术搜索API
SCHOLAR_API_KEY=your_scholar_api_key_here

# 高德地图API
AMAP_API_KEY=your_amap_api_key_here
AMAP_SECRET_KEY=your_amap_secret_key_here

# Chrome MCP配置
CHROME_HEADLESS=true