{
  "system": {
    "name": "顶级专家版小娜专利系统",
    "version": "v1.0",
    "description": "集成了星河系列专家团队的智能专利分析平台",
    "author": "小娜·天秤女神",
    "build_date": "2025-12-16",
    "environment": "development"
  },
  "server": {
    "host": "localhost",
    "port": 8000,
    "debug": true,
    "workers": 4,
    "timeout": 300,
    "max_connections": 1000
  },
  "database": {
    "type": "sqlite",
    "path": "data/xiaona_patent.db",
    "pool_size": 10,
    "max_overflow": 20,
    "echo": false
  },
  "knowledge_base": {
    "patents_db": {
      "type": "json",
      "path": "knowledge/patents_database.json",
      "auto_reload": true,
      "cache_ttl": 3600
    },
    "legal_precedents_db": {
      "type": "json",
      "path": "knowledge/legal_precedents.json",
      "auto_reload": true,
      "cache_ttl": 3600
    },
    "technical_insights_db": {
      "type": "json",
      "path": "knowledge/technical_insights.json",
      "auto_reload": true,
      "cache_ttl": 3600
    },
    "vector_db": {
      "type": "qdrant",
      "url": "http://localhost:6333",
      "collection_name": "patent_vectors",
      "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
      "dimension": 384
    },
    "graph_db": {
      "type": "neo4j",
      "url": "bolt://localhost:7687",
      "username": "neo4j",
      "password": "password",
      "database": "patent_knowledge"
    }
  },
  "expert_system": {
    "experts_db": {
      "path": "knowledge/top_patent_experts.json",
      "auto_reload": true
    },
    "team_composition": {
      "default_size": 3,
      "max_size": 5,
      "min_consensus_threshold": 0.6
    },
    "expert_types": {
      "patent_agent": {
        "max_per_analysis": 2,
        "specializations": ["电子通信", "生物医药", "机械制造", "化学工程"]
      },
      "patent_lawyer": {
        "max_per_analysis": 1,
        "specializations": ["侵权诉讼", "无效宣告", "许可谈判", "合同纠纷"]
      },
      "patent_examiner": {
        "max_per_analysis": 2,
        "specializations": ["实质审查", "审查标准", "指南解释"]
      },
      "technical_expert": {
        "max_per_analysis": 2,
        "specializations": ["IPC_A", "IPC_B", "IPC_C", "IPC_D", "IPC_E", "IPC_F", "IPC_G", "IPC_H"]
      }
    }
  },
  "llm_interface": {
    "default_provider": "openai",
    "providers": {
      "openai": {
        "api_key": "${OPENAI_API_KEY}",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-4o",
        "temperature": 0.7,
        "max_tokens": 4000,
        "timeout": 60,
        "cost_per_1k_tokens": 0.005
      },
      "anthropic": {
        "api_key": "${ANTHROPIC_API_KEY}",
        "base_url": "https://api.anthropic.com",
        "model": "claude-3-5-sonnet-20241022",
        "temperature": 0.7,
        "max_tokens": 4000,
        "timeout": 60,
        "cost_per_1k_tokens": 0.015
      },
      "deepseek": {
        "api_key": "${DEEPSEEK_API_KEY}",
        "base_url": "https://api.deepseek.com/v1",
        "model": "deepseek-chat",
        "temperature": 0.7,
        "max_tokens": 4000,
        "timeout": 60,
        "cost_per_1k_tokens": 0.0014
      },
      "moonshot": {
        "api_key": "${MOONSHOT_API_KEY}",
        "base_url": "https://api.moonshot.cn/v1",
        "model": "moonshot-v1-8k",
        "temperature": 0.7,
        "max_tokens": 4000,
        "timeout": 60,
        "cost_per_1k_tokens": 0.012
      }
    },
    "prompt_cache": {
      "enabled": true,
      "ttl": 3600,
      "max_size": 1000
    }
  },
  "analysis_workflow": {
    "max_concurrent_analyses": 10,
    "queue_size": 50,
    "timeout": 300,
    "retry_attempts": 3,
    "retry_delay": 5,
    "steps": {
      "knowledge_retrieval": {
        "enabled": true,
        "timeout": 30,
        "max_results": 10
      },
      "expert_analysis": {
        "enabled": true,
        "timeout": 60,
        "min_confidence": 0.6
      },
      "llm_analysis": {
        "enabled": true,
        "timeout": 60,
        "temperature": 0.7
      },
      "patentability_analysis": {
        "enabled": true,
        "weights": {
          "novelty": 0.3,
          "inventive_step": 0.4,
          "utility": 0.3
        }
      },
      "risk_assessment": {
        "enabled": true,
        "risk_thresholds": {
          "high": 0.8,
          "medium": 0.5,
          "low": 0.2
        }
      }
    }
  },
  "report_generator": {
    "default_format": "markdown",
    "supported_formats": ["markdown", "html", "json", "pdf"],
    "templates_dir": "templates/reports",
    "output_dir": "output/reports",
    "include_raw_data": false,
    "cache_reports": true,
    "report_ttl": 86400
  },
  "security": {
    "authentication": {
      "enabled": true,
      "jwt_secret": "${JWT_SECRET}",
      "jwt_expiration": 3600,
      "api_key_header": "Authorization"
    },
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 100,
      "requests_per_hour": 1000,
      "requests_per_day": 10000
    },
    "input_validation": {
      "max_description_length": 50000,
      "max_title_length": 500,
      "allowed_file_types": [".txt", ".md", ".json"],
      "max_file_size": 10485760
    },
    "encryption": {
      "enabled": false,
      "algorithm": "AES-256-GCM",
      "key_rotation_days": 90
    }
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "handlers": {
      "console": {
        "enabled": true,
        "level": "INFO"
      },
      "file": {
        "enabled": true,
        "level": "DEBUG",
        "path": "logs/xiaona_patent.log",
        "max_size": "100MB",
        "backup_count": 5,
        "rotation": "daily"
      }
    },
    "audit_log": {
      "enabled": true,
      "path": "logs/audit.log",
      "include_user_info": true,
      "include_request_details": true
    }
  },
  "monitoring": {
    "metrics": {
      "enabled": true,
      "port": 9090,
      "path": "/metrics"
    },
    "health_check": {
      "enabled": true,
      "path": "/health",
      "interval": 30
    },
    "performance_monitoring": {
      "enabled": true,
      "slow_query_threshold": 1.0,
      "memory_threshold": 0.8,
      "cpu_threshold": 0.8
    }
  },
  "notifications": {
    "email": {
      "enabled": false,
      "smtp_server": "smtp.gmail.com",
      "smtp_port": 587,
      "username": "${SMTP_USERNAME}",
      "password": "${SMTP_PASSWORD}",
      "from_address": "noreply@xiaona-patent.com"
    },
    "webhook": {
      "enabled": false,
      "urls": [],
      "events": ["analysis_completed", "analysis_failed", "system_error"]
    }
  },
  "cache": {
    "redis": {
      "enabled": false,
      "host": "localhost",
      "port": 6379,
      "db": 0,
      "password": "${REDIS_PASSWORD}",
      "ttl": 3600
    },
    "memory": {
      "enabled": true,
      "max_size": 1000,
      "ttl": 1800
    }
  },
  "development": {
    "debug_mode": true,
    "profiling": {
      "enabled": false,
      "output_dir": "profiles"
    },
    "testing": {
      "mock_llm": true,
      "mock_knowledge_base": true,
      "test_data_dir": "tests/data"
    }
  },
  "features": {
    "experimental": {
      "multi_modal_analysis": false,
      "real_time_collaboration": false,
      "voice_input": false
    },
    "beta": {
      "batch_analysis": true,
      "export_to_excel": false,
      "patent_family_analysis": false
    },
    "stable": {
      "patent_analysis": true,
      "expert_consultation": true,
      "report_generation": true,
      "knowledge_search": true
    }
  }
}