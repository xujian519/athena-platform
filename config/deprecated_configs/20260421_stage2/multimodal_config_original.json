{
  "multimodal_system": {
    "version": "1.0.0",
    "deployment_date": "2025-12-06",
    "system_name": "Athena多模态文件处理系统",
    "description": "统一的多模态文件处理、管理和分析平台"
  },
  "workspace": {
    "base_directory": "/Users/xujian/Athena工作平台",
    "upload_directory": "/Users/xujian/Athena工作平台/uploads",
    "processed_directory": "/Users/xujian/Athena工作平台/processed",
    "archive_directory": "/Users/xujian/Athena工作平台/archive",
    "cache_directory": "/Users/xujian/Athena工作平台/cache",
    "temp_directory": "/Users/xujian/Athena工作平台/temp"
  },
  "database": {
    "sqlite_path": "/Users/xujian/Athena工作平台/metadata/multimodal_file_manager.db",
    "backup_enabled": true,
    "backup_interval_hours": 24,
    "max_connections": 10
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 2,
    "cache_ttl": 3600,
    "connection_pool_size": 5
  },
  "processing": {
    "max_workers": 4,
    "batch_size": 20,
    "timeout_seconds": 300,
    "retry_attempts": 3,
    "auto_process_enabled": true
  },
  "supported_file_types": {
    "image": {
      "enabled": true,
      "extensions": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp", ".svg", ".ico", ".tiff"],
      "max_size_mb": 50,
      "operations": ["extract_metadata", "generate_thumbnail", "analyze_content", "convert_format"]
    },
    "document": {
      "enabled": true,
      "extensions": [".pdf", ".doc", ".docx", ".txt", ".md", ".rtf", ".odt", ".pages", ".epub"],
      "max_size_mb": 100,
      "operations": ["extract_text", "extract_metadata", "convert_format", "analyze_content"]
    },
    "audio": {
      "enabled": true,
      "extensions": [".mp3", ".wav", ".flac", ".aac", ".ogg", ".m4a", ".wma"],
      "max_size_mb": 200,
      "operations": ["extract_metadata", "convert_format", "transcribe_audio", "analyze_content"]
    },
    "video": {
      "enabled": true,
      "extensions": [".mp4", ".avi", ".mkv", ".mov", ".wmv", ".flv", ".webm", ".m4v"],
      "max_size_mb": 500,
      "operations": ["extract_metadata", "extract_frames", "convert_format", "analyze_content"]
    },
    "data": {
      "enabled": true,
      "extensions": [".json", ".xml", ".csv", ".xlsx", ".yaml", ".yml", ".sql", ".db", ".sqlite"],
      "max_size_mb": 100,
      "operations": ["extract_metadata", "convert_format", "analyze_content", "validate_structure"]
    },
    "code": {
      "enabled": true,
      "extensions": [".py", ".js", ".html", ".css", ".java", ".cpp", ".c", ".h", ".go", ".rs", ".php"],
      "max_size_mb": 10,
      "operations": ["analyze_code", "extract_functions", "generate_documentation", "check_quality"]
    },
    "archive": {
      "enabled": true,
      "extensions": [".zip", ".rar", ".7z", ".tar", ".gz", ".bz2"],
      "max_size_mb": 1000,
      "operations": ["extract_content", "list_contents", "compress_files", "analyze_content"]
    },
    "presentation": {
      "enabled": true,
      "extensions": [".ppt", ".pptx", ".key", ".odp"],
      "max_size_mb": 100,
      "operations": ["extract_metadata", "extract_text", "convert_format", "analyze_content"]
    }
  },
  "quality_assessment": {
    "enabled": true,
    "factors": {
      "title_quality": 0.2,
      "abstract_quality": 0.3,
      "content_completeness": 0.25,
      "tech_relevance": 0.15,
      "data_richness": 0.1
    },
    "thresholds": {
      "high_quality": 0.8,
      "medium_quality": 0.6,
      "low_quality": 0.4
    }
  },
  "vectorization": {
    "enabled": true,
    "dimensions": 768,
    "method": "tfidf_example",
    "cache_enabled": true,
    "batch_processing": true,
    "model_path": "/Users/xujian/Athena工作平台/models"
  },
  "patent_pipeline": {
    "enabled": true,
    "stages": [
      "validation",
      "content_extraction",
      "quality_assessment",
      "vectorization",
      "neo4j_preparation",
      "completion"
    ],
    "auto_crawl": true,
    "crawl_queries": [
      "artificial intelligence",
      "machine learning",
      "blockchain",
      "neural network",
      "big data"
    ],
    "neo4j_preparation": {
      "enabled": true,
      "concept_extraction": true,
      "relationship_extraction": true
    }
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8085,
    "cors_enabled": true,
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 100
    },
    "authentication": {
      "enabled": false,
      "api_key_required": false
    },
    "endpoints": {
      "file_management": "/api/files",
      "processing": "/api/process",
      "search": "/api/search",
      "stats": "/api/stats",
      "patents": "/api/patents"
    }
  },
  "monitoring": {
    "enabled": true,
    "log_level": "INFO",
    "metrics_interval": 60,
    "health_check_interval": 30,
    "performance_tracking": true,
    "alert_thresholds": {
      "error_rate": 0.05,
      "response_time_ms": 5000,
      "storage_usage_percent": 80
    }
  },
  "storage_management": {
    "auto_cleanup": true,
    "retention_days": 30,
    "archive_after_days": 7,
    "max_storage_gb": 100,
    "cleanup_interval_hours": 24
  },
  "security": {
    "scan_uploads": true,
    "allowed_file_types": "all",
    "max_file_size_mb": 1000,
    "quarantine_suspicious": true
  },
  "integration": {
    "athena_platform": {
      "enabled": true,
      "auto_register_services": true,
      "shared_storage": true,
      "unified_authentication": false
    },
    "neo4j": {
      "enabled": true,
      "connection_url": "bolt://localhost:7687",
      "username": "neo4j",
      "password": "password",
      "database": "neo4j"
    },
    "elasticsearch": {
      "enabled": false,
      "hosts": ["localhost:9200"],
      "index_prefix": "athena_files"
    }
  },
  "performance": {
    "caching": {
      "enabled": true,
      "metadata_ttl": 1800,
      "processing_results_ttl": 3600,
      "search_results_ttl": 900
    },
    "concurrency": {
      "max_concurrent_uploads": 5,
      "max_concurrent_processing": 10,
      "max_concurrent_searches": 20
    },
    "optimization": {
      "lazy_loading": true,
      "batch_operations": true,
      "async_processing": true
    }
  },
  "development": {
    "debug_mode": false,
    "mock_processing": false,
    "test_data_path": "/Users/xujian/Athena工作平台/test_data",
    "logging_verbose": false
  }
}