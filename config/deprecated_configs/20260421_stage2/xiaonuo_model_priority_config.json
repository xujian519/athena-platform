{
  "model_priority_policy": {
    "name": "小诺智能体模型优先级配置",
    "version": "2.0.0",
    "created_at": "2025-12-14",
    "created_by": "小诺·双鱼座",
    "principle": "优先使用GLM-4包月服务，最大化性价比",

    "primary_model": {
      "name": "glm-4",
      "provider": "zhipu",
      "api_endpoint": "https://open.bigmodel.cn/api/paas/v4/",
      "priority": 1,
      "reason": "包月服务，无额外调用成本",
      "preferred_scenarios": ["all"]
    },

    "model_selection_rules": {
      "default_rule": {
        "condition": "default",
        "selected_model": "glm-4",
        "confidence": 0.95,
        "description": "默认情况下，所有任务都优先使用GLM-4"
      },

      "patent_tasks": {
        "condition": "task_type == 'patent_analysis' or task_type == 'patent_application'",
        "selected_model": "glm-4",
        "temperature": 0.3,
        "max_tokens": 2000,
        "confidence": 1.0,
        "description": "专利分析任务使用GLM-4的专业能力"
      },

      "legal_tasks": {
        "condition": "task_type == 'legal_analysis' or task_type == 'legal_review'",
        "selected_model": "glm-4",
        "temperature": 0.2,
        "max_tokens": 2500,
        "confidence": 1.0,
        "description": "法律任务使用GLM-4的严谨推理"
      },

      "code_generation": {
        "condition": "task_type == 'code_generation' or task_type == 'technical_development'",
        "selected_model": "glm-4",
        "temperature": 0.1,
        "max_tokens": 3000,
        "confidence": 0.95,
        "description": "代码生成使用GLM-4的编程能力"
      },

      "creative_tasks": {
        "condition": "task_type == 'content_creation' or task_type == 'creative_writing'",
        "selected_model": "glm-4",
        "temperature": 0.8,
        "max_tokens": 1500,
        "confidence": 0.9,
        "description": "创意任务使用GLM-4的创造力"
      },

      "data_analysis": {
        "condition": "task_type == 'data_analysis' or task_type == 'report_generation'",
        "selected_model": "glm-4",
        "temperature": 0.4,
        "max_tokens": 2000,
        "confidence": 0.9,
        "description": "数据分析使用GLM-4的分析能力"
      },

      "conversation": {
        "condition": "task_type == 'general_chat' or task_type == 'qa'",
        "selected_model": "glm-4",
        "temperature": 0.7,
        "max_tokens": 1000,
        "confidence": 1.0,
        "description": "日常对话使用GLM-4的交互能力"
      }
    },

    "fallback_strategy": {
      "glm_4_unavailable": {
        "condition": "glm-4 api fails or timeout",
        "fallback_models": [
          {
            "model": "qwen:7b",
            "provider": "mlx",
            "weight": 0.7,
            "reason": "本地备用模型"
          },
          {
            "model": "qwen2.5vl:latest",
            "provider": "mlx",
            "weight": 0.3,
            "reason": "本地多模态模型"
          }
        ]
      },

      "high_load_scenario": {
        "condition": "concurrent_requests > 50",
        "load_balancing": {
          "glm_4_ratio": 0.8,
          "local_models_ratio": 0.2,
          "description": "高负载时80%使用GLM-4，20%使用本地模型"
        }
      }
    },

    "embedding_tasks": {
      "chinese_text": {
        "selected_model": "bge-large-zh-v1.5",
        "provider": "local",
        "reason": "本地向量模型，速度快"
      },
      "multilingual": {
        "selected_model": "qwen3-embedding:4b",
        "provider": "mlx",
        "reason": "多语言支持"
      },
      "lightweight": {
        "selected_model": "nomic-embed-text:latest",
        "provider": "mlx",
        "reason": "轻量级嵌入"
      }
    },

    "usage_optimization": {
      "batch_processing": {
        "enabled": true,
        "batch_size": 10,
        "description": "批量处理请求，提高GLM-4利用率"
      },

      "caching": {
        "enabled": true,
        "cache_duration": 3600,
        "description": "缓存常见查询结果"
      },

      "request_merging": {
        "enabled": true,
        "description": "合并相似请求，减少调用次数"
      }
    },

    "cost_optimization": {
      "monthly_budget_usage": {
        "target_utilization": "90-95%",
        "description": "目标月度利用率90-95%"
      },

      "real_time_monitoring": {
        "enabled": true,
        "metrics": ["requests_per_minute", "tokens_used", "cost_savings"],
        "description": "实时监控使用情况"
      }
    },

    "quality_assurance": {
      "response_validation": {
        "min_quality_score": 0.8,
        "auto_retry": true,
        "max_retries": 3
      },

      "performance_tracking": {
        "track_latency": true,
        "track_accuracy": true,
        "track_user_satisfaction": true
      }
    }
  }
}