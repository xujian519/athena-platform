# ============================================================================
# Athena工作平台环境变量配置示例
# ============================================================================
# 复制此文件为 .env 并填写实际配置值
# 注意：.env 文件包含敏感信息，不应提交到版本控制系统
# ============================================================================

# ============================================================================
# 🔐 安全配置 - 生产环境必需
# ============================================================================

# 数据库密码（必需，至少8个字符）
# 生成命令: openssl rand -base64 16
DB_PASSWORD=your_secure_database_password_here

# JWT密钥（必需，至少32个字符）
# 生成命令: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_characters
JWT_SECRET_KEY=your_super_secret_jwt_key_here_at_least_32_characters

# Neo4j图数据库密码（必需）
NEO4J_PASSWORD=your_neo4j_password_here

# Redis密码（可选，生产环境建议设置）
REDIS_PASSWORD=

# ============================================================================
# 数据库连接配置
# ============================================================================

# PostgreSQL数据库（已支持密码环境变量）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=athena

# 如果需要完整的连接字符串（不推荐，密码部分已使用环境变量）
# DATABASE_URL=postgresql://postgres:your_secure_database_password_here@localhost:5432/athena

# ============================================================================
# Neo4j图数据库配置
# ============================================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j

# ============================================================================
# Redis配置
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Qdrant向量数据库配置
# ============================================================================

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================================================
# AI模型API密钥
# ============================================================================

# OpenAI API密钥（可选）
OPENAI_API_KEY=sk-your-openai-api-key-here

# 智谱AI API密钥（可选）
ZHIPU_API_KEY=your-zhipu-ai-api-key-here

# DeepSeek API密钥（可选）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ============================================================================
# MCP服务配置
# ============================================================================

# 高德地图API密钥
# 获取地址: https://console.amap.com/dev/key/app
AMAP_API_KEY=your_amap_api_key_here

# MCP日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
MCP_LOG_LEVEL=INFO

# ========================================
# 通信服务配置
# ========================================

# 消息队列最大大小
COMMUNICATION_MAX_QUEUE_SIZE=10000

# 最大连接数
COMMUNICATION_MAX_CONNECTIONS=1000

# 消息超时时间（秒）
COMMUNICATION_MESSAGE_TIMEOUT=30

# ========================================
# 数据库配置
# ========================================

# PostgreSQL连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/athena

# Redis连接字符串
REDIS_URL=redis://localhost:6379/0

# ========================================
# 监控配置
# ========================================

# Prometheus指标端口
PROMETHEUS_PORT=9090

# Grafana端口
GRAFANA_PORT=3000

# ========================================
# 日志配置
# ========================================

# 日志级别
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=data/logs/athena.log

# ========================================
# AI模型配置
# ========================================

# OpenAI API密钥
OPENAI_API_KEY=your_openai_api_key_here

# 智谱AI API密钥
ZHIPU_API_KEY=your_zhipu_api_key_here

# ========================================
# 安全配置
# ========================================

# JWT密钥（用于身份验证）
JWT_SECRET_KEY=your_jwt_secret_key_here

# 加密密钥
ENCRYPTION_KEY=your_encryption_key_here

# CORS允许的来源（逗号分隔）
# ⚠️  生产环境必须配置具体域名，不要使用通配符
# 开发环境示例:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080
# 生产环境示例:
# ALLOWED_ORIGINS=https://athena.example.com,https://app.athena.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# CORS允许的HTTP方法（逗号分隔）
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# CORS允许的请求头（逗号分隔，* 表示允许所有）
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# CORS预检请求缓存时间（秒）
CORS_MAX_AGE=3600

# 信任的主机（逗号分隔，用于防止Host头攻击）
# 开发环境:
# ALLOWED_HOSTS=localhost,127.0.0.1
# 生产环境:
# ALLOWED_HOSTS=athena.example.com,app.athena.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# 开发模式配置
# ========================================

# 调试模式
DEBUG=true

# 测试模式
TESTING=false
