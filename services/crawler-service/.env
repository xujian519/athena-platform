# Athena Crawler Service Configuration
# 使用生产环境统一配置

# =============================================================================
# 应用配置
# =============================================================================
APP_NAME=Athena Crawler Service
VERSION=2.0.0
DEBUG=false
PORT=8001

# =============================================================================
# 爬虫配置
# =============================================================================
MAX_CONCURRENT_CRAWLS=5
DEFAULT_TIMEOUT=30
ENABLE_CACHE=true
CACHE_TTL=3600

# =============================================================================
# 成本控制
# =============================================================================
MONTHLY_COST_LIMIT=100.0
DAILY_COST_LIMIT=10.0
ENABLE_COST_MONITORING=true

# =============================================================================
# 存储配置
# =============================================================================
STORAGE_TYPE=file
STORAGE_PATH=./data/crawler

# =============================================================================
# 代理配置
# =============================================================================
ENABLE_PROXY=false
PROXY_LIST=

# =============================================================================
# 外部服务API密钥
# =============================================================================

# Crawl4AI (可选)
CRAWL4AI_API_KEY=

# FireCrawl (已配置)
FIRECRAWL_API_KEY=fc-a647874a30414979882d378ec924eda7
FIRECRAWL_API_URL=https://api.firecrawl.dev

# OpenAI (用于AI增强提取) - 使用智谱API替代
OPENAI_API_KEY=
OPENAI_MODEL=

# 智谱AI GLM (使用生产环境配置)
ZHIPU_API_KEY=9efe5766a7cd4bb687e40082ee4032b6.0mYTotbC7aRmoNCe
GLM_API_KEY=9efe5766a7cd4bb687e40082ee4032b6.0mYTotbC7aRmoNCe

# 本地模型服务 (Athena工作平台内部)
# 智能路由优先使用本地模型服务，如果不可用则使用智谱API
DEEPSEEK_URL=http://localhost:8088
DUAL_ORCHESTRATOR_URL=http://localhost:8089
GLM_FULL_SUITE_URL=http://localhost:8090
GLM_INTEGRATION_URL=http://localhost:8091

# =============================================================================
# 数据库配置 (继承生产环境配置)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=patent_legal_db
DB_USER=postgres
DB_PASSWORD=YsUM&fVa2gIU7ueypOSw

# =============================================================================
# Redis配置 (继承生产环境配置)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# 浏览器配置
# =============================================================================
BROWSER_TYPE=chromium
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# =============================================================================
# CORS配置 (继承生产环境配置)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8080

# =============================================================================
# 安全配置
# =============================================================================
SECRET_KEY=athena_secret_key_change_in_production_2024
ENABLE_AUTH=true
ENABLE_RATE_LIMIT=true

# =============================================================================
# 速率限制配置
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
