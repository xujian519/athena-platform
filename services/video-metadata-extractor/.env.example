# 环境变量配置文件
# 复制此文件为 .env 并修改相应配置

# 服务配置
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8080
SERVICE_DEBUG=false

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/video-metadata-extractor.log

# Cookie配置
COOKIE_CACHE_DURATION=3600
COOKIE_AUTO_REFRESH=true

# 数据目录配置
DATA_DIR=./data
CACHE_DIR=./cache

# 请求配置
DEFAULT_TIMEOUT=30
MAX_RETRY_COUNT=3
RATE_LIMIT_ENABLED=true

# 平台配置
ENABLE_BILIBILI=true
ENABLE_YOUTUBE=true
ENABLE_DOUYIN=true
ENABLE_KUAISHOU=false

# 安全配置
CORS_ORIGINS=*
API_KEY_REQUIRED=false
API_KEY=your_api_key_here

# 缓存配置
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# 监控配置
METRICS_ENABLED=false
METRICS_PORT=9090