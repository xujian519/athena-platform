# WebChat V2 Gateway 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ========== 服务器配置 ==========
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_DEBUG=false

# ========== WebSocket配置 ==========
GATEWAY_HEARTBEAT_INTERVAL=30
GATEWAY_MAX_MESSAGE_SIZE=1048576
GATEWAY_MAX_CONNECTIONS=1000

# ========== 安全配置 ==========
GATEWAY_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ========== JWT认证配置 ==========
# JWT密钥（生产环境必须修改为随机密钥）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
GATEWAY_JWT_SECRET=webchat-v2-secret-key-change-in-production

# Token过期时间（分钟）
GATEWAY_JWT_EXPIRE_MINUTES=1440

# ========== 身份配置 ==========
GATEWAY_DEFAULT_USER_ID=guest
GATEWAY_ADMIN_USER_ID=xujian

# ========== 模块配置 ==========
GATEWAY_ENABLE_MODULE_CACHE=true
GATEWAY_MODULE_HEALTH_CHECK_INTERVAL=60
GATEWAY_MODULE_INVOKE_TIMEOUT=30

# ========== 持久化配置 ==========
# 身份数据持久化路径
GATEWAY_IDENTITY_PERSISTENCE_PATH=data/identities.json

# ========== 日志配置 ==========
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
GATEWAY_LOG_LEVEL=INFO

# 日志文件路径
GATEWAY_LOG_FILE=logs/webchat_gateway.log

# 日志文件最大大小（MB）
GATEWAY_LOG_MAX_BYTES=10

# 保留的日志文件数量
GATEWAY_LOG_BACKUP_COUNT=5
