# Common Tools Service Configuration

# 服务配置
APP_NAME=Common Tools Service
VERSION=1.0.0
DEBUG=false
PORT=8007

# 浏览器自动化配置
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30
BROWSER_WINDOW_SIZE=1920,1080
BROWSER_DOWNLOAD_PATH=./downloads

# 爬虫配置
CRAWLER_TIMEOUT=60
CRAWLER_MAX_REDIRECTS=5
CRAWLER_RETRY_TIMES=3
CRAWLER_DELAY=1
CRAWLER_USER_AGENT=Athena-Crawler/1.0

# 代理配置
ENABLE_PROXY=false
PROXY_LIST=

# 文本提取配置
NLTK_DATA_PATH=./nltk_data
SPACY_MODEL=zh_core_web_sm
MAX_KEYWORDS=20
MIN_SENTENCE_LENGTH=10

# AI模型配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4

# 缓存配置
ENABLE_CACHE=true
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/common-tools.log

# 安全配置
RATE_LIMIT=100
CORS_ORIGINS=http://localhost:3000,http://localhost:8000