# Athena浏览器自动化服务环境配置
# Browser Automation Service Environment Configuration

# =============================================================================
# 安全配置（SECURITY CONFIGURATION）
# =============================================================================

# JWT密钥（生产环境必须使用强随机字符串）
# 警告：请勿将此文件提交到版本控制系统
SECRET_KEY=athena_browser_secret_key_change_in_production_2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API密钥认证（可选）
API_KEY=

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8010,http://localhost:8030,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8010,http://127.0.0.1:8030

# 环境标识
ENVIRONMENT=development

# =============================================================================
# 浏览器配置（BROWSER CONFIGURATION）
# =============================================================================

BROWSER_TYPE=chromium
BROWSER_HEADLESS=true
BROWSER_WINDOW_WIDTH=1920
BROWSER_WINDOW_HEIGHT=1080
BROWSER_DISABLE_SECURITY=true
BROWSER_DOWNLOADS_PATH=./downloads

# =============================================================================
# 服务器配置（SERVER CONFIGURATION）
# =============================================================================

HOST=0.0.0.0
PORT=8030
WORKERS=1
LOG_LEVEL=info

# =============================================================================
# Redis配置（REDIS CONFIGURATION）
# =============================================================================

REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=

# =============================================================================
# 数据库配置（DATABASE CONFIGURATION）
# =============================================================================

DATABASE_URL=sqlite:///./browser_automation.db

# =============================================================================
# 监控配置（MONITORING CONFIGURATION）
# =============================================================================

ENABLE_METRICS=true
METRICS_PORT=9010

# =============================================================================
# 日志配置（LOGGING CONFIGURATION）
# =============================================================================

LOG_FILE=./logs/browser_automation.log
LOG_ROTATION=1 week
LOG_RETENTION=4 weeks

# =============================================================================
# 代理配置（PROXY CONFIGURATION - 可选）
# =============================================================================

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# =============================================================================
# 功能开关（FEATURE FLAGS）
# =============================================================================

ENABLE_WEBSOCKET=true
ENABLE_BACKGROUND_TASKS=true
ENABLE_SCREENSHOTS=true
ENABLE_VIDEO_RECORDING=false
ENABLE_AUTH=false

# =============================================================================
# 性能配置（PERFORMANCE CONFIGURATION）
# =============================================================================

MAX_CONCURRENT_SESSIONS=10
SESSION_TIMEOUT=3600
SESSION_CLEANUP_INTERVAL=300
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=300
TASK_MAX_STEPS=50
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# =============================================================================
# 集成配置（INTEGRATION CONFIGURATION）
# =============================================================================

ATHENA_IDENTITY_URL=http://localhost:8010
ATHENA_MEMORY_URL=http://localhost:8008
XIAONUO_MEMORY_URL=http://localhost:8083

# =============================================================================
# LLM配置（LLM CONFIGURATION - 从主环境加载）
# =============================================================================

# 注意：API密钥应从环境变量或密钥管理服务获取
# 请勿在此文件中硬编码敏感信息

ZHIPU_API_KEY=
GLM_API_KEY=
GLM_MODEL=glm-4-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash-exp

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

MLX_BASE_URL=http://127.0.0.1:8765
MLX_MODEL=glm47flash
