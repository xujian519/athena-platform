# Athena浏览器自动化服务环境配置模板
# Browser Automation Service Environment Template
# 注意：复制此文件为 .env 并填入实际配置值

# =============================================================================
# 安全配置（必填）
# =============================================================================

# JWT密钥（生产环境必须更改，使用强随机字符串）
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API密钥认证（可选）
API_KEY=your_api_key_here

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8010,http://localhost:8030,http://localhost:8080

# 环境标识
ENVIRONMENT=development

# =============================================================================
# LLM配置（可选）
# =============================================================================

# 智谱AI GLM
ZHIPU_API_KEY=your_zhipu_api_key_here
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-flash

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash-exp

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# MLX（本地）
MLX_BASE_URL=http://127.0.0.1:8765
MLX_MODEL=llama3.1:8b

# =============================================================================
# 浏览器配置
# =============================================================================

BROWSER_TYPE=chromium
BROWSER_HEADLESS=true
BROWSER_WINDOW_WIDTH=1920
BROWSER_WINDOW_HEIGHT=1080
BROWSER_DISABLE_SECURITY=true
BROWSER_DOWNLOADS_PATH=./downloads

# =============================================================================
# 服务器配置
# =============================================================================

HOST=0.0.0.0
PORT=8030
WORKERS=1
LOG_LEVEL=info

# =============================================================================
# Redis配置
# =============================================================================

REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=

# =============================================================================
# 数据库配置
# =============================================================================

DATABASE_URL=sqlite:///./browser_automation.db

# =============================================================================
# 监控配置
# =============================================================================

ENABLE_METRICS=true
METRICS_PORT=9010

# =============================================================================
# 日志配置
# =============================================================================

LOG_FILE=./logs/browser_automation.log
LOG_ROTATION=1 week
LOG_RETENTION=4 weeks

# =============================================================================
# 代理配置（可选）
# =============================================================================

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# =============================================================================
# 功能开关
# =============================================================================

ENABLE_WEBSOCKET=true
ENABLE_BACKGROUND_TASKS=true
ENABLE_SCREENSHOTS=true
ENABLE_VIDEO_RECORDING=false
ENABLE_AUTH=true

# =============================================================================
# 性能配置
# =============================================================================

MAX_CONCURRENT_SESSIONS=10
SESSION_TIMEOUT=3600
SESSION_CLEANUP_INTERVAL=300
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=300
TASK_MAX_STEPS=50
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# =============================================================================
# 集成配置
# =============================================================================

ATHENA_IDENTITY_URL=http://localhost:8010
ATHENA_MEMORY_URL=http://localhost:8008
XIAONUO_MEMORY_URL=http://localhost:8083
