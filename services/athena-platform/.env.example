# Athena Platform Configuration
# 复制为 .env 并修改相应配置

# 服务配置
APP_NAME=Athena Platform
VERSION=1.0.0
DEBUG=false
PORT=8000
HOST=0.0.0.0

# API配置
API_PREFIX=/api/v1
CORS_ORIGINS=*

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/athena.log

# 数据库配置
DATABASE_URL=postgresql://athena:password@localhost:5432/athena

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 外部服务
MEMORY_SERVICE_URL=http://localhost:8008
IDENTITY_SERVICE_URL=http://localhost:8010
AI_SERVICE_URL=http://localhost:9001

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30