# Athena生产环境配置
# Production Environment Configuration

# =============================================================================
# 环境配置
# =============================================================================
ENVIRONMENT=production

# =============================================================================
# 服务配置
# =============================================================================
# API服务器配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info
API_ACCESS_LOG=true
API_RELOAD=false

# =============================================================================
# Qdrant向量数据库配置
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_TIMEOUT=60
QDRANT_PREFER_GRPC=false
QDRANT_CHECK_THRESHOLD=0.8

# =============================================================================
# NebulaGraph图数据库配置
# =============================================================================
NEBULA_HOST=nebula-graph
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=your_nebula_password_here
NEBULA_SPACE=patent_graph
NEBULA_MAX_CONNECTIONS=20
NEBULA_TIMEOUT=60

# =============================================================================
# 向量嵌入模型配置
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_CACHE_DIR=/app/models
EMBEDDING_BATCH_SIZE=64
EMBEDDING_NORMALIZE=true
EMBEDDING_SHOW_PROGRESS=false

# =============================================================================
# LLM配置 - 智谱AI
# =============================================================================
# LLM提供商: zhipu, openai, azure
LLM_PROVIDER=zhipu

# 智谱AI API密钥 (从 https://open.bigmodel.cn/ 获取)
LLM_API_KEY=9efe5766a7cd4bb687e40082ee4032b6.0mYTotbC7aRmoNCe

# 智谱AI模型 (glm-4, glm-3-turbo, glm-4-flash, glm-4-air, glm-4-plus)
# 可用模型已验证:
# - glm-4: 旗舰模型，综合能力强
# - glm-4-flash: 响应速度快
# - glm-4-air: 性价比高
# - glm-3-turbo: 上一代主力
# - glm-4-plus: 增强版
LLM_MODEL=glm-4

# LLM参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TOP_P=0.9
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# 智谱AI特有配置
# 是否启用联网搜索
LLM_ENABLE_SEARCH=false
# 是否启用Web搜索
LLM_ENABLE_WEB_SEARCH=false

# =============================================================================
# 步骤执行配置
# =============================================================================
STEP_DEFAULT_TIMEOUT=300
STEP_CACHE_ENABLED=true
STEP_CACHE_TTL=3600
STEP_MAX_RETRIES=3
STEP_RETRY_DELAY=1.0

# =============================================================================
# CORS安全配置
# =============================================================================
# 生产环境必须指定具体域名，不要使用*
CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# 性能配置
# =============================================================================
PERF_CONN_POOL_SIZE=20
PERF_CONN_IDLE_TIMEOUT=300
PERF_CONN_MAX_LIFETIME=3600
PERF_THREAD_POOL_SIZE=8
PERF_ASYNC_THREAD_POOL_SIZE=8

# =============================================================================
# 缓存配置
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your_redis_password_here
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/athena.log
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10

# =============================================================================
# 监控配置
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# 安全配置
# =============================================================================
SECRET_KEY=your_secret_key_here_change_in_production
ALLOWED_HOSTS=app.example.com,admin.example.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
