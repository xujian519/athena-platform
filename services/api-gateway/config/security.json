{
  "security": {
    "version": "1.0.0",
    "enabled": true,
    "zeroTrust": {
      "enabled": true,
      "policyEngine": {
        "endpoint": "http://zero-trust-auth:8080",
        "timeout": 5000,
        "retryAttempts": 3
      },
      "microSegmentation": {
        "enabled": true,
        "segments": {
          "ai-services": {
            "isolationLevel": "strict",
            "allowedIPs": ["10.0.1.0/24"],
            "ports": [8081, 8082, 8083]
          },
          "data-services": {
            "isolationLevel": "moderate", 
            "allowedIPs": ["10.0.2.0/24"],
            "ports": [5432, 6379, 9200]
          }
        }
      }
    },
    "authentication": {
      "type": "adaptive",
      "factors": {
        "primary": ["password"],
        "secondary": ["totp", "push"],
        "tertiary": ["biometric"]
      },
      "riskBased": {
        "enabled": true,
        "thresholds": {
          "low": 30,
          "medium": 60,
          "high": 80
        }
      },
      "mfa": {
        "requiredForRoles": ["admin", "developer", "analyst"],
        "gracePeriod": 86400000,
        "methods": ["totp", "sms", "push", "biometric"]
      }
    },
    "apiSecurity": {
      "owasp": {
        "enabled": true,
        "protections": [
          "sql_injection",
          "xss",
          "csrf", 
          "ssrf",
          "xxe",
          "insecure_deserialization",
          "security_misconfiguration",
          "vulnerable_components",
          "insufficient_logging",
          "broken_auth"
        ]
      },
      "rateLimit": {
        "global": {
          "window": 900000,
          "max": 10000
        },
        "perIP": {
          "window": 60000,
          "max": 100
        },
        "perUser": {
          "window": 300000,
          "max": 1000
        }
      },
      "inputValidation": {
        "maxLength": 1048576,
        "allowedTypes": ["json", "xml", "form-data"],
        "sanitization": true
      }
    },
    "dataProtection": {
      "encryption": {
        "inTransit": {
          "algorithm": "TLS_AES_256_GCM_SHA384",
          "minVersion": "TLS1.3"
        },
        "atRest": {
          "algorithm": "AES-256-GCM",
          "keyRotation": 7776000000
        },
        "fieldLevel": {
          "enabled": true,
          "sensitiveFields": [
            "email",
            "phone", 
            "ssn",
            "creditCard",
            "apiKey"
          ]
        }
      },
      "dataLossPrevention": {
        "enabled": true,
        "rules": [
          "ssn_detection",
          "credit_card_detection",
          "email_detection",
          "api_key_detection",
          "custom_pii_detection"
        ],
        "actions": {
          "low": "alert",
          "medium": "mask",
          "high": "block",
          "critical": "encrypt_and_alert"
        }
      },
      "retention": {
        "default": 2555000000,
        "sensitive": 7776000000,
        "audit": 31536000000
      }
    },
    "threatIntelligence": {
      "enabled": true,
      "feeds": [
        {
          "name": "abusech_ip",
          "type": "ip_reputation",
          "url": "https://urlhaus.abuse.ch/downloads/ipblocklist/",
          "updateInterval": 3600000
        },
        {
          "name": "phish_domains",
          "type": "domain_reputation", 
          "url": "https://openphish.com/feed.txt",
          "updateInterval": 1800000
        }
      ],
      "mlDetection": {
        "enabled": true,
        "models": [
          "anomaly_detection",
          "malware_detection",
          "phishing_detection"
        ],
        "confidenceThreshold": 0.8
      },
      "behaviorAnalysis": {
        "enabled": true,
        "learningWindow": 604800000,
        "anomalyThreshold": 2.5
      }
    },
    "compliance": {
      "gdpr": {
        "enabled": true,
        "dataSubjectRights": {
          "access": true,
          "rectification": true,
          "erasure": true,
          "portability": true,
          "restriction": true,
          "objection": true
        },
        "consentManagement": {
          "granular": true,
          "withdrawable": true,
          "auditTrail": true
        },
        "dataProcessingAgreement": true,
        "dataProtectionOfficer": true
      },
      "soc2": {
        "enabled": true,
        "trustServices": [
          "security",
          "availability", 
          "processing_integrity",
          "confidentiality",
          "privacy"
        ],
        "auditFrequency": 31536000000
      },
      "iso27001": {
        "enabled": false,
        "implementationDate": "2025-01-01",
        "scope": ["api-gateway", "auth-service", "data-protection"]
      }
    },
    "securityAnalytics": {
      "enabled": true,
      "metrics": {
        "collectionInterval": 60000,
        "retention": 2592000000,
        "aggregation": ["1m", "5m", "1h", "1d"]
      },
      "anomalyDetection": {
        "enabled": true,
        "algorithms": ["isolation_forest", "local_outlier_factor", "one_class_svm"],
        "sensitivity": 0.95
      },
      "forensics": {
        "enabled": true,
        "dataRetention": 31536000000,
        "evidenceCollection": ["logs", "network_traffic", "system_state", "memory_dump"]
      },
      "dashboard": {
        "refreshInterval": 30000,
        "exportFormats": ["pdf", "csv", "json"],
        "realTimeAlerts": true
      }
    },
    "incidentResponse": {
      "enabled": true,
      "automation": {
        "enabled": true,
        "responsePlans": {
          "security_incident": {
            "severity": "high",
            "autoActions": [
              "block_ip",
              "isolate_service",
              "rotate_credentials"
            ],
            "escalation": {
              "level1": "security_team",
              "level2": "management",
              "level3": "executive"
            }
          }
        }
      },
      "notification": {
        "channels": ["email", "slack", "sms"],
        "escalation": {
          "level1": 900000,
          "level2": 1800000,
          "level3": 3600000
        }
      },
      "recovery": {
        "autoRestore": true,
        "backupVerification": true,
        "postIncidentReview": true
      }
    },
    "monitoring": {
      "logging": {
        "level": "info",
        "format": "json",
        "outputs": ["file", "elasticsearch"],
        "securityEvents": true,
        "auditTrail": true
      },
      "metrics": {
        "enabled": true,
        "endpoints": ["/metrics"],
        "format": "prometheus",
        "interval": 15000
      },
      "healthChecks": {
        "enabled": true,
        "interval": 30000,
        "endpoints": ["/health", "/ready"],
        "dependencies": ["redis", "database", "auth-service"]
      },
      "alerting": {
        "enabled": true,
        "channels": ["email", "slack", "pagerduty"],
        "thresholds": {
          "errorRate": 0.01,
          "responseTime": 1000,
          "authFailures": 0.1,
          "securityEvents": 10
        }
      }
    }
  }
}