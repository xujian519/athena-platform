# API Gateway - 本地开发环境配置
# 从 ../.env.local 继承主要配置

# 服务端口
PORT=8080
HOST=0.0.0.0

# Node环境
NODE_ENV=development

# 日志
LOG_LEVEL=debug

# 数据库连接（连接到本地PostgreSQL）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=athena
POSTGRES_USER=athena
POSTGRES_PASSWORD=athena123

# Redis连接（连接到Docker容器）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# JWT配置
JWT_SECRET=dev-jwt-secret-key-change-in-production
JWT_EXPIRATION=24h

# CORS
CORS_ORIGINS=*

# 后端服务代理
YUNPAT_AGENT_URL=http://localhost:8087
