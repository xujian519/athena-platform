# Athena API Gateway 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 服务器配置
ATHENA_GATEWAY_SERVER_PORT=8080
ATHENA_GATEWAY_SERVER_HOST=0.0.0.0
ATHENA_GATEWAY_SERVER_MODE=debug
ATHENA_GATEWAY_SERVER_READ_TIMEOUT=30
ATHENA_GATEWAY_SERVER_WRITE_TIMEOUT=30
ATHENA_GATEWAY_SERVER_IDLE_TIMEOUT=60

# 数据库配置
ATHENA_GATEWAY_DATABASE_HOST=localhost
ATHENA_GATEWAY_DATABASE_PORT=5432
ATHENA_GATEWAY_DATABASE_USER=athena
ATHENA_GATEWAY_DATABASE_PASSWORD=athena_password
ATHENA_GATEWAY_DATABASE_DB_NAME=athena_gateway
ATHENA_GATEWAY_DATABASE_SSL_MODE=disable
ATHENA_GATEWAY_DATABASE_MAX_IDLE_CONNS=10
ATHENA_GATEWAY_DATABASE_MAX_OPEN_CONNS=100
ATHENA_GATEWAY_DATABASE_MAX_LIFETIME=3600

# Redis配置
ATHENA_GATEWAY_REDIS_HOST=localhost
ATHENA_GATEWAY_REDIS_PORT=6379
ATHENA_GATEWAY_REDIS_PASSWORD=
ATHENA_GATEWAY_REDIS_DB=0
ATHENA_GATEWAY_REDIS_POOL_SIZE=20

# JWT配置
ATHENA_GATEWAY_JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
ATHENA_GATEWAY_JWT_EXPIRATION_TIME=3600
ATHENA_GATEWAY_JWT_REFRESH_TIME=604800
ATHENA_GATEWAY_JWT_ISSUER=athena-gateway

# 限流配置
ATHENA_GATEWAY_RATE_LIMIT_ENABLED=true
ATHENA_GATEWAY_RATE_LIMIT_REQUESTS_PER_MINUTE=100
ATHENA_GATEWAY_RATE_LIMIT_BURST_SIZE=200
ATHENA_GATEWAY_RATE_LIMIT_WHITELIST_ENABLED=false
ATHENA_GATEWAY_RATE_LIMIT_WHITELIST=127.0.0.1,::1

# 服务配置
ATHENA_GATEWAY_SERVICES_AUTH_URL=http://localhost:9001
ATHENA_GATEWAY_SERVICES_AUTH_TIMEOUT=30
ATHENA_GATEWAY_SERVICES_AUTH_RETRY_ATTEMPTS=3
ATHENA_GATEWAY_SERVICES_AUTH_CIRCUIT_BREAKER_ENABLED=true
ATHENA_GATEWAY_SERVICES_AUTH_CIRCUIT_BREAKER_THRESHOLD=5
ATHENA_GATEWAY_SERVICES_AUTH_CIRCUIT_BREAKER_TIMEOUT=60
ATHENA_GATEWAY_SERVICES_AUTH_CIRCUIT_BREAKER_RESET_TIMEOUT=300
ATHENA_GATEWAY_SERVICES_AUTH_CIRCUIT_BREAKER_FAILURE_RATE=0.5

ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_URL=http://localhost:9002
ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_TIMEOUT=45
ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_RETRY_ATTEMPTS=3
ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_CIRCUIT_BREAKER_ENABLED=true
ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_CIRCUIT_BREAKER_THRESHOLD=5
ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_CIRCUIT_BREAKER_TIMEOUT=60
ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_CIRCUIT_BREAKER_RESET_TIMEOUT=300
ATHENA_GATEWAY_SERVICES_PATENT_SEARCH_CIRCUIT_BREAKER_FAILURE_RATE=0.5

ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_URL=http://localhost:9003
ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_TIMEOUT=30
ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_RETRY_ATTEMPTS=3
ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_CIRCUIT_BREAKER_ENABLED=true
ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_CIRCUIT_BREAKER_THRESHOLD=5
ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_CIRCUIT_BREAKER_TIMEOUT=60
ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_CIRCUIT_BREAKER_RESET_TIMEOUT=300
ATHENA_GATEWAY_SERVICES_USER_MANAGEMENT_CIRCUIT_BREAKER_FAILURE_RATE=0.5

ATHENA_GATEWAY_SERVICES_ANALYTICS_URL=http://localhost:9004
ATHENA_GATEWAY_SERVICES_ANALYTICS_TIMEOUT=60
ATHENA_GATEWAY_SERVICES_ANALYTICS_RETRY_ATTEMPTS=2
ATHENA_GATEWAY_SERVICES_ANALYTICS_CIRCUIT_BREAKER_ENABLED=true
ATHENA_GATEWAY_SERVICES_ANALYTICS_CIRCUIT_BREAKER_THRESHOLD=3
ATHENA_GATEWAY_SERVICES_ANALYTICS_CIRCUIT_BREAKER_TIMEOUT=120
ATHENA_GATEWAY_SERVICES_ANALYTICS_CIRCUIT_BREAKER_RESET_TIMEOUT=600
ATHENA_GATEWAY_SERVICES_ANALYTICS_CIRCUIT_BREAKER_FAILURE_RATE=0.3

# 监控配置
ATHENA_GATEWAY_MONITORING_ENABLED=true
ATHENA_GATEWAY_MONITORING_PORT=9090
ATHENA_GATEWAY_MONITORING_PATH=/metrics
ATHENA_GATEWAY_MONITORING_METRICS_URL=

# 日志配置
ATHENA_GATEWAY_LOGGING_LEVEL=info
ATHENA_GATEWAY_LOGGING_FORMAT=json
ATHENA_GATEWAY_LOGGING_OUTPUT=stdout
ATHENA_GATEWAY_LOGGING_FILENAME=gateway.log
ATHENA_GATEWAY_LOGGING_MAX_SIZE=100
ATHENA_GATEWAY_LOGGING_MAX_BACKUPS=10
ATHENA_GATEWAY_LOGGING_MAX_AGE=30
ATHENA_GATEWAY_LOGGING_COMPRESS=true

# 开发环境特定配置
ATHENA_GATEWAY_DEBUG=false
ATHENA_GATEWAY_PROFILE=false