# Athena迭代式搜索系统环境配置

# 环境设置
ATHENA_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=patent_db
DB_USER=postgres
DB_PASSWORD=

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Elasticsearch配置
ES_HOST=localhost
ES_PORT=9200

# Qwen LLM配置
QWEN_API_KEY=sk-051fca069bdb42978496df6fb4455e3a
DASHSCOPE_API_KEY=sk-051fca069bdb42978496df6fb4455e3a

# 外部搜索引擎API密钥（可选）
BAIDU_API_KEY=
BAIDU_API_SECRET=

BING_API_KEY=

SOGOU_API_KEY=

# 性能配置
ENABLE_PERFORMANCE_MONITORING=true
MAX_CONCURRENT_SEARCHES=10
CACHE_TTL=3600
