# 顶级专家版小娜专利系统环境配置文件
# 复制此文件为 .env 并填入实际值

# ===========================================
# 系统基础配置
# ===========================================
SYSTEM_ENV=development
SYSTEM_DEBUG=true
SYSTEM_LOG_LEVEL=INFO

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=sqlite:///data/xiaona_patent.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ===========================================
# LLM API配置
# ===========================================
# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

# Anthropic配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-opus-20240229

# 本地LLM配置
LOCAL_LLM_URL=http://localhost:8001/v1
LOCAL_LLM_MODEL=local-llm

# ===========================================
# 向量数据库配置 (Qdrant)
# ===========================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=patent_vectors
QDRANT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===========================================
# 图数据库配置 (Neo4j)
# ===========================================
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=patent_knowledge

# ===========================================
# Redis缓存配置
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password_here
REDIS_TTL=3600

# ===========================================
# 安全配置
# ===========================================
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_characters
JWT_EXPIRATION=3600
API_KEY_HEADER=Authorization
ENCRYPTION_KEY=your_encryption_key_here

# ===========================================
# 邮件服务配置
# ===========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@xiaona-patent.com

# ===========================================
# Webhook配置
# ===========================================
WEBHOOK_URL_1=https://your-webhook-url-1.com/endpoint
WEBHOOK_URL_2=https://your-webhook-url-2.com/endpoint

# ===========================================
# 监控配置
# ===========================================
METRICS_PORT=9090
HEALTH_CHECK_PATH=/health
PROMETHEUS_GATEWAY_URL=http://localhost:9091

# ===========================================
# 性能配置
# ===========================================
MAX_CONCURRENT_ANALYSES=10
QUEUE_SIZE=50
REQUEST_TIMEOUT=300
MAX_CONNECTIONS=1000

# ===========================================
# 文件存储配置
# ===========================================
UPLOAD_DIR=uploads
OUTPUT_DIR=output
TEMP_DIR=temp
MAX_FILE_SIZE=10485760  # 10MB

# ===========================================
# 日志配置
# ===========================================
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5
AUDIT_LOG=logs/audit.log

# ===========================================
# 开发配置
# ===========================================
PROFILING_ENABLED=false
PROFILING_OUTPUT_DIR=profiles
MOCK_LLM=true
MOCK_KNOWLEDGE_BASE=true
TEST_DATA_DIR=tests/data

# ===========================================
# 特性开关
# ===========================================
ENABLE_MULTI_MODAL_ANALYSIS=false
ENABLE_REAL_TIME_COLLABORATION=false
ENABLE_VOICE_INPUT=false
ENABLE_BATCH_ANALYSIS=true
ENABLE_EXPORT_TO_EXCEL=false
ENABLE_PATENT_FAMILY_ANALYSIS=false

# ===========================================
# 外部服务配置
# ===========================================
PATENT_OFFICE_API_KEY=your_patent_office_api_key
PATENT_OFFICE_BASE_URL=https://api.patentoffice.gov.cn
PATENT_OFFICE_TIMEOUT=30

# ===========================================
# 备份配置
# ===========================================
BACKUP_ENABLED=true
BACKUP_DIR=backups
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30