{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lyra Prompt Optimizer LLM Configuration",
  "description": "LLM服务配置用于Lyra提示词优化引擎",
  "version": "1.0.0",
  "updated_at": "2026-02-06T00:00:00.000000",

  "default_provider": "deepseek",
  "fallback_providers": ["zhipu", "ollama"],

  "providers": {
    "ollama": {
      "enabled": true,
      "description": "本地Ollama服务",
      "base_url": "http://localhost:11434",
      "timeout": 30,
      "models": {
        "default": "qwen:7b",
        "fast": "qwen:7b",
        "quality": "qwen2.5vl:latest"
      },
      "parameters": {
        "temperature": 0.3,
        "top_p": 0.9,
        "top_k": 40,
        "num_predict": 2048,
        "repeat_penalty": 1.1
      }
    },

    "zhipu": {
      "enabled": true,
      "description": "智谱AI GLM-4",
      "api_key": "54a69837dfd643d8ab7a7a72756ef837.uWBCuChZSM4aDRyq",
      "base_url": "https://open.bigmodel.cn/api/paas/v4/",
      "models": {
        "default": "glm-4",
        "fast": "glm-4-flash",
        "quality": "glm-4-plus"
      },
      "parameters": {
        "temperature": 0.3,
        "top_p": 0.7,
        "max_tokens": 2000
      }
    },

    "deepseek": {
      "enabled": true,
      "description": "DeepSeek AI",
      "api_key": "sk-b8f452a470e84a26a75f33474e5d7c08",
      "base_url": "https://api.deepseek.com/v1",
      "models": {
        "default": "deepseek-chat",
        "coder": "deepseek-coder"
      },
      "parameters": {
        "temperature": 0.3,
        "max_tokens": 2000
      }
    },

    "openai": {
      "enabled": false,
      "description": "OpenAI GPT",
      "api_key": "",
      "base_url": "https://api.openai.com/v1",
      "models": {
        "default": "gpt-4o-mini",
        "quality": "gpt-4o"
      },
      "parameters": {
        "temperature": 0.3,
        "max_tokens": 2000
      }
    },

    "anthropic": {
      "enabled": false,
      "description": "Anthropic Claude",
      "api_key": "",
      "base_url": "https://api.anthropic.com/v1",
      "models": {
        "default": "claude-3-5-sonnet-20241022",
        "quality": "claude-3-5-sonnet-20241022"
      },
      "parameters": {
        "temperature": 0.3,
        "max_tokens": 2000
      }
    }
  },

  "optimization_profiles": {
    "basic": {
      "temperature": 0.3,
      "max_tokens": 1500,
      "description": "快速优化，适用于简单提示词"
    },
    "detail": {
      "temperature": 0.2,
      "max_tokens": 2500,
      "description": "详细优化，适用于复杂提示词"
    },
    "creative": {
      "temperature": 0.6,
      "max_tokens": 2000,
      "description": "创意优化，适用于创意类任务"
    },
    "technical": {
      "temperature": 0.1,
      "max_tokens": 2000,
      "description": "技术优化，适用于技术类任务"
    }
  },

  "cache": {
    "enabled": true,
    "ttl": 3600,
    "max_size": 1000,
    "description": "优化结果缓存配置"
  },

  "fallback": {
    "enabled": true,
    "max_retries": 3,
    "fallback_to_rules": true,
    "description": "LLM服务失败时的降级配置"
  },

  "monitoring": {
    "log_requests": true,
    "log_responses": false,
    "track_tokens": true,
    "description": "监控和日志配置"
  }
}
