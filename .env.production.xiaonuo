# =============================================================================
# 小诺·双鱼座 - 生产环境变量模板
# Xiaonuo Pisces - Production Environment Variables Template
# =============================================================================
#
# 使用说明：
# 1. 复制此文件为 .env.production
# 2. 填写实际的配置值
# 3. 确保 .env.production 文件权限设置为 600
#
# =============================================================================

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------

# 服务环境（production, development, testing）
XIAONUO_ENVIRONMENT=production

# 服务版本
XIAONUO_VERSION=1.0.0

# 数据目录
XIAONUO_DATA_DIR=/var/lib/xiaonuo

# 日志目录
XIAONUO_LOG_DIR=/var/log/xiaonuo

# 备份目录
XIAONUO_BACKUP_DIR=/var/backups/xiaonuo

# -----------------------------------------------------------------------------
# 安全配置
# -----------------------------------------------------------------------------

# API密钥（生成方式: openssl rand -hex 32）
XIAONUO_API_KEY=your-api-key-here

# JWT密钥（生成方式: openssl rand -hex 32）
XIAONUO_JWT_SECRET=your-jwt-secret-here

# JWT过期时间（小时）
XIAONUO_JWT_EXPIRE_HOURS=24

# 加密密钥（用于敏感数据加密）
XIAONUO_ENCRYPTION_KEY=your-encryption-key-here

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------

# 监听地址（默认本地）
XIAONUO_HOST=127.0.0.1

# 监听端口
XIAONUO_PORT=8005

# 工作进程数
XIAONUO_WORKERS=1

# 启动超时时间（秒）
XIAONUO_STARTUP_TIMEOUT=30

# 健康检查间隔（秒）
XIAONUO_HEALTH_CHECK_INTERVAL=30

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------

# PostgreSQL数据库
XIAONUO_DB_HOST=localhost
XIAONUO_DB_PORT=5432
XIAONUO_DB_NAME=xiaonuo
XIAONUO_DB_USER=xiaonuo
XIAONUO_DB_PASSWORD=your-db-password-here

# Redis缓存
XIAONUO_REDIS_HOST=localhost
XIAONUO_REDIS_PORT=6379
XIAONUO_REDIS_DB=0
XIAONUO_REDIS_PASSWORD=your-redis-password-here

# -----------------------------------------------------------------------------
# 消息队列配置
# -----------------------------------------------------------------------------

# RabbitMQ
XIAONUO_RABBITMQ_HOST=localhost
XIAONUO_RABBITMQ_PORT=5672
XIAONUO_RABBITMQ_USER=xiaonuo
XIAONUO_RABBITMQ_PASSWORD=your-rabbitmq-password-here
XIAONUO_RABBITMQ_VHOST=/xiaonuo

# -----------------------------------------------------------------------------
# AI模型配置
# -----------------------------------------------------------------------------

# Claude API配置
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# 本地模型配置（如果使用）
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_PATH=/models/xiaonuo
LOCAL_MODEL_PORT=11434

# -----------------------------------------------------------------------------
# 协作配置
# -----------------------------------------------------------------------------

# 小娜服务地址
XIAONA_SERVICE_URL=http://localhost:8001
XIAONA_API_KEY=your-xiaona-api-key-here

# 云熙服务地址
YUNXI_SERVICE_URL=http://localhost:8087
YUNXI_API_KEY=your-yunxi-api-key-here

# 小宸服务地址
XIAOCHEN_SERVICE_URL=http://localhost:8030
XIAOCHEN_API_KEY=your-xiaochen-api-key-here

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
XIAONUO_LOG_LEVEL=INFO

# 日志格式（json, text）
XIAONUO_LOG_FORMAT=json

# 日志文件最大大小（MB）
XIAONUO_LOG_MAX_SIZE=100

# 日志备份数量
XIAONUO_LOG_BACKUP_COUNT=10

# 日志轮转周期（daily, weekly, monthly）
XIAONUO_LOG_ROTATION=daily

# -----------------------------------------------------------------------------
# 监控配置
# -----------------------------------------------------------------------------

# Prometheus指标端口
XIAONUO_METRICS_PORT=9095

# Prometheus指标路径
XIAONUO_METRICS_PATH=/metrics

# 性能监控间隔（秒）
XIAONUO_PERFORMANCE_INTERVAL=60

# 健康检查详细模式
XIAONUO_HEALTH_DETAILED=false

# -----------------------------------------------------------------------------
# 备份配置
# -----------------------------------------------------------------------------

# 启用自动备份
XIAONUO_BACKUP_ENABLED=true

# 备份间隔（小时）
XIAONUO_BACKUP_INTERVAL=24

# 备份保留天数
XIAONUO_BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# 性能配置
# -----------------------------------------------------------------------------

# 内存限制（MB）
XIAONUO_MEMORY_LIMIT=512

# CPU限制（0.1-1.0）
XIAONUO_CPU_LIMIT=0.5

# 响应超时（秒）
XIAONUO_RESPONSE_TIMEOUT=30

# 任务超时（秒）
XIAONUO_TASK_TIMEOUT=300

# 最大并发任务数
XIAONUO_MAX_CONCURRENT_TASKS=10

# -----------------------------------------------------------------------------
# 限流配置
# -----------------------------------------------------------------------------

# 启用限流
XIAONUO_RATE_LIMIT_ENABLED=true

# 每分钟请求数
XIAONUO_RATE_LIMIT_RPM=100

# 突发请求数
XIAONUO_RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# 调试配置
# -----------------------------------------------------------------------------

# 启用调试模式
XIAONUO_DEBUG=false

# 启用性能分析
XIAONUO_PROFILING=false

# 启用内存跟踪
XIAONUO_TRACE_MEMORY=false

# -----------------------------------------------------------------------------
# 通知配置
# -----------------------------------------------------------------------------

# 启用通知
XIAONUO_NOTIFICATIONS_ENABLED=false

# 通知邮件
XIAONUO_NOTIFY_EMAIL=your-email@example.com

# 通知Webhook
XIAONUO_NOTIFY_WEBHOOK=https://your-webhook-url

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------

# 时区
XIAONUO_TIMEZONE=Asia/Shanghai

# 语言
XIAONUO_LANGUAGE=zh_CN

# 工作目录
XIAONUO_WORK_DIR=/opt/xiaonuo

# PID文件路径
XIAONUO_PID_FILE=/var/run/xiaonuo.pid
