# 后端环境变量

# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=patents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# Qdrant配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Neo4j配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# 应用配置
APP_NAME=专利混合检索系统
APP_VERSION=1.0.0
DEBUG=false

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/patent-retrieval/api.log
