# 测试环境配置
NODE_ENV=development
VERSION=latest
LOG_LEVEL=debug

# 数据库配置（轻量级，适合测试）
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=athena_test
POSTGRES_USER=athena
POSTGRES_PASSWORD=test123
POSTGRES_CPU_LIMIT=1.0
POSTGRES_MEM_LIMIT=2G

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=test123
REDIS_MAX_MEMORY=512mb
REDIS_CPU_LIMIT=0.5
REDIS_MEM_LIMIT=512M

# Qdrant配置
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_LOG_LEVEL=DEBUG
QDRANT_MAX_THREADS=2
QDRANT_CPU_LIMIT=1.0
QDRANT_MEM_LIMIT=4G

# Neo4j配置
NEO4J_HOST=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_DATABASE=neo4j
NEO4J_PASSWORD=test123
NEO4J_PAGECACHE_SIZE=512M
NEO4J_HEAP_INIT=256m
NEO4J_HEAP_MAX=256m
NEO4J_LOG_LEVEL=INFO
NEO4J_CPU_LIMIT=1.0
NEO4J_MEM_LIMIT=2G
