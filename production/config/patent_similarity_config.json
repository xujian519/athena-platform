    "include_summary": true,
    "include_raw_text": false,
    "compression": false
  },
  "logging": {
    "level": "INFO",
    "file": "production/logs/cap02_data_prep.log",
    "max_bytes": 10485760,
    "backup_count": 5
  },
  "monitoring": {
    "enable_performance_metrics": true,
    "log_memory_usage": true,
    "log_processing_time": true,
    "alert_on_errors": true,
    "alert_threshold": 5
  }
