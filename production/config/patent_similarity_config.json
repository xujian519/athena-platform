{
  "models": {
    "bert_ner": {
      "model_path": "/Users/xujian/Athena工作平台/models/converted/hfl/chinese-roberta-wwm-ext-large",
      "device": "cpu",
      "cache_enabled": true
    },
    "bge_m3": {
      "model_path": "/Users/xujian/Athena工作平台/models/modelscope/Xorbits/bge-m3",
      "device": "cpu",
      "vector_dim": 1024,
      "cache_enabled": true
    },
    "llm": {
      "provider": "platform",
      "task_type": "patent_analysis",
      "temperature": 0.3,
      "max_tokens": 4000,
      "timeout": 120
    }
  },
  "processing": {
    "batch_size": 2,
    "max_pdfs_per_case": 10,
    "cleanup_between_batches": true,
    "enable_memory_management": true,
    "max_memory_mb": 6144
  },
  "output": {
    "directory": "production/output",
