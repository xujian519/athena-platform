{
  "service_group": "法律AI服务",
  "service_group_code": "LEGAL_AI_SERVICES",
  "version": "1.0.0",
  "description": "Athena法律智能分析与检索服务",
  "services": [
    {
      "name": "知识图谱API",
      "code": "KNOWLEDGE_GRAPH_API",
      "description": "统一的法律知识图谱查询和管理接口",
      "port": 9030,
      "endpoint": "http://localhost:9030",
      "health_check": "/health",
      "api_docs": "/docs",
      "module_path": "domains/legal-ai/apis/knowledge_graph_api.py",
      "dependencies": ["neo4j", "sqlite3"],
      "status": "ready"
    },
    {
      "name": "统一智能搜索",
      "code": "UNIFIED_INTELLIGENT_SEARCH",
      "description": "多引擎集成的智能搜索系统",
      "port": 9040,
      "endpoint": "http://localhost:9040",
      "health_check": "/health",
      "api_docs": "/docs",
      "module_path": "domains/legal-ai/apis/unified_intelligent_search.py",
      "dependencies": ["qdrant_client", "sentence_transformers"],
      "status": "ready"
    },
    {
      "name": "法律向量搜索",
      "code": "LEGAL_VECTOR_SEARCH",
      "description": "基于BGE模型的法律文档语义检索",
      "port": 9050,
      "endpoint": "http://localhost:9050",
      "module_path": "domains/legal-ai/services/legal_vector_search.py",
      "dependencies": ["sentence_transformers", "faiss-cpu"],
      "status": "ready"
    },
    {
      "name": "统一知识管理",
      "code": "UNIFIED_KNOWLEDGE_MANAGER",
      "description": "专业知识图谱与记忆模块统一管理",
      "port": 9060,
      "endpoint": "http://localhost:9060",
      "health_check": "/health",
      "api_docs": "/docs",
      "module_path": "domains/legal-ai/apis/unified_knowledge_manager.py",
      "dependencies": ["sqlite3"],
      "status": "ready"
    }
  ],
  "startup_script": "scripts/start_legal_ai_services.sh",
  "integration": {
    "core_platform": true,
    "api_gateway": true,
    "authentication": false,
    "monitoring": true
  },
  "features": {
    "knowledge_graph_query": {
      "description": "法律知识图谱查询",
      "enabled": true,
      "api_endpoint": "/graphs"
    },
    "intelligent_search": {
      "description": "智能语义搜索",
      "enabled": true,
      "api_endpoint": "/search"
    },
    "legal_document_retrieval": {
      "description": "法律文档检索",
      "enabled": true,
      "api_endpoint": "/legal/search"
    },
    "cross_domain_knowledge": {
      "description": "跨领域知识管理",
      "enabled": true,
      "api_endpoint": "/knowledge"
    }
  },
  "data_sources": {
    "legal_documents": "/data/legal_documents",
    "legal_knowledge_graph": "/data/knowledge/kg_main.db",
    "legal_vector_db": "/data/legal_vector_db",
    "case_database": "/data/legal_cases"
  },
  "monitoring": {
    "metrics_endpoint": "/metrics",
    "log_directory": "/logs/legal-ai",
    "health_checks": [
      "database_connection",
      "vector_index_availability",
      "search_response_time"
    ]
  },
  "api_routes": {
    "prefix": "/api/v1/legal-ai",
    "routes": {
      "knowledge": {
        "graphs": "GET /graphs",
        "search": "POST /search",
        "statistics": "GET /statistics"
      },
      "search": {
        "intelligent": "POST /search",
        "vector": "POST /vector/search",
        "semantic": "POST /semantic/search"
      },
      "management": {
        "graphs": "GET /graphs",
        "entities": "GET /entities",
        "relations": "GET /relations"
      }
    }
  },
  "last_updated": "2025-12-11T03:30:00Z",
  "created_by": "Athena平台自动化迁移"
}