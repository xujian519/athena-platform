# Athena工作平台 - 感知模块三层架构集成配置
# Perception Module Three-Layer Architecture Integration Configuration

# ============================================================================
# 三层数据库架构连接配置
# ============================================================================

# PostgreSQL - 主数据库（存储完整结构化数据）
PERCEPTION_PG_HOST=localhost
PERCEPTION_PG_PORT=5432
PERCEPTION_PG_DATABASE=athena
PERCEPTION_PG_USER=xujian
# PostgreSQL密码为空（本地Homebrew安装）

# Neo4j - 图数据库（存储三层知识图谱）
PERCEPTION_NEO4J_URI=bolt://localhost:7687
PERCEPTION_NEO4J_USER=neo4j
PERCEPTION_NEO4J_PASSWORD=athena123
PERCEPTION_NEO4J_DATABASE=athena

# Qdrant - 向量数据库（存储语义向量）
PERCEPTION_QDRANT_URL=http://localhost:6333
PERCEPTION_QDRANT_COLLECTION=perception_vectors

# Redis - 缓存层
PERCEPTION_REDIS_URL=redis://localhost:6379/1
PERCEPTION_REDIS_CACHE_TTL=3600

# ============================================================================
# 三层架构节点类型映射
# ============================================================================

# Layer 1: 法律法规层
PERCEPTION_LAYER1_LABELS=LawDocument,LawArticle,LegalConcept,PerceptionConcept
PERCEPTION_LAYER1_QUERY=MATCH (l:LawDocument) RETURN l

# Layer 2: 专利专业层
PERCEPTION_LAYER2_LABELS=PatentLawDocument,PatentGuideChapter,PatentReviewDecision
PERCEPTION_LAYER2_QUERY=MATCH (p:PatentLawDocument) RETURN p

# Layer 3: 判决文书层
PERCEPTION_LAYER3_LABELS=JudgmentDocument,JudgmentCitation,PerceptionApplication
PERCEPTION_LAYER3_QUERY=MATCH (j:JudgmentDocument) RETURN j

# ============================================================================
# 感知模块特定配置
# ============================================================================

# 感知输入类型映射到三层架构
PERCEPTION_INPUT_PATENT_DRAWING=PatentLawDocument  # 专利图纸 -> Layer 2
PERCEPTION_INPUT_CLAIM_TEXT=PatentLawDocument      # 权利要求 -> Layer 2
PERCEPTION_INPUT_LEGAL_TEXT=LawDocument           # 法律文本 -> Layer 1
PERCEPTION_INPUT_JUDGMENT=JudgmentDocument        # 判决文书 -> Layer 3

# 感知输出存储位置
PERCEPTION_OUTPUT_STORE_PG=true                  # 存储到PostgreSQL
PERCEPTION_OUTPUT_STORE_NEO4J=true               # 存储到Neo4j
PERCEPTION_OUTPUT_STORE_QDRANT=true              # 存储向量到Qdrant

# 感知结果向量生成
PERCEPTION_EMBEDDING_MODEL=bge-m3                # 使用BGE-M3模型
PERCEPTION_EMBEDDING_DIM=1024                     # 1024维向量
PERCEPTION_EMBEDDING_BATCH_SIZE=32               # 批处理大小

# ============================================================================
# 感知模块与三层架构的关系类型
# ============================================================================

# 感知模块特定关系
PERCEPTION_RELATION_EXTRACTS=EXTRACTS_FROM       # 提取特征
PERCEPTION_RELATION_ANALYZES=ANALYZES             # 分析内容
PERCEPTION_RELATION_PROCESS=PROCESS               # 处理数据
PERCEPTION_RELATION_INTERPRETS=INTERPRETS         # 解释法律
PERCEPTION_RELATION_ENABLES=ENABLES               # 使能应用

# ============================================================================
# 查询优化配置
# ============================================================================

# 三层跨层查询优化
PERCEPTION_CROSS_LAYER_OPTIMIZATION=true         # 启用跨层查询优化
PERCEPTION_QUERY_CACHE_ENABLED=true              # 启用查询缓存
PERCEPTION_QUERY_CACHE_SIZE=1000                 # 缓存大小

# 批量查询配置
PERCEPTION_BATCH_QUERY_SIZE=100                   # 批量查询大小
PERCEPTION_QUERY_TIMEOUT=30000                    # 查询超时（30秒）

# ============================================================================
# 性能监控配置
# ============================================================================

# 查询性能监控
PERFORMANCE_MONITORING_ENABLED=true              # 启用性能监控
PERFORMANCE_SLOW_QUERY_THRESHOLD=5000            # 慢查询阈值（5秒）
PERFORMANCE_QUERY_LOGGING=true                   # 查询日志记录

# 资源使用限制
PERCEPTION_MAX_CONCURRENT_QUERIES=10             # 最大并发查询数
PERCEPTION_MEMORY_LIMIT=2048                      # 内存限制（2GB）

# ============================================================================
# 数据同步配置
# ============================================================================

# PostgreSQL -> Neo4j 同步
SYNC_PG_TO_NEO4J_ENABLED=true                    # 启用PG到Neo4j同步
SYNC_PG_TO_NEO4J_BATCH_SIZE=500                  # 批量同步大小
SYNC_PG_TO_NEO4J_INTERVAL=3600                   # 同步间隔（1小时）

# PostgreSQL -> Qdrant 向量同步
SYNC_PG_TO_QDRANT_ENABLED=true                  # 启用PG到Qdrant向量同步
SYNC_PG_TO_QDRANT_BATCH_SIZE=100                # 批量同步大小
SYNC_EMBEDDING_MODEL=bge-m3                     # 向量化模型

# ============================================================================
# 感知模块扩展配置
# ============================================================================

# 感知概念（Layer 1扩展）
PERCEPTION_CONCEPTS=visual_perception,textual_perception,multimodal_perception,patent_drawing_perception,claim_analysis_perception

# 感知应用（Layer 3扩展）
PERCEPTION_APPLICATIONS=drawing_feature_extractor,claims_parser,multimodal_patent_analyzer

# 感知应用状态
PERCEPTION_APP_STATUS_ACTIVE=ACTIVE
PERCEPTION_APP_STATUS_DEPLOYED=DEPLOYED
PERCEPTION_APP_STATUS_TESTING=TESTING

# ============================================================================
# 日志配置
# ============================================================================

PERCEPTION_LOG_LEVEL=INFO
PERCEPTION_LOG_FORMAT=json
PERCEPTION_LOG_FILE=logs/perception_three_tier.log
PERCEPTION_LOG_ROTATION=50 MB
PERCEPTION_LOG_RETENTION=30 days

# ============================================================================
# 开发模式配置
# ============================================================================

PERCEPTION_DEV_MODE=false
PERCEPTION_DEBUG=false
PERCEPTION_TRACE_QUERIES=false
