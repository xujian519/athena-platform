{
  "dashboard": {
    "title": "智能路由引擎监控",
    "tags": ["athena", "router", "ai"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "路由请求总量",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(router_requests_total[5m]))",
            "legendFormat": "总QPS"
          },
          {
            "expr": "sum(rate(router_requests_total{router=\"new\"}[5m]))",
            "legendFormat": "新路由QPS"
          },
          {
            "expr": "sum(rate(router_requests_total{router=\"old\"}[5m]))",
            "legendFormat": "旧路由QPS"
          }
        ]
      },
      {
        "id": 2,
        "title": "路由准确率",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "router_accuracy_score",
            "legendFormat": "准确率"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "平均响应时间",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(router_response_time_seconds_bucket[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(router_response_time_seconds_bucket[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(router_response_time_seconds_bucket[5m]))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "id": 4,
        "title": "降级率",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(router_fallback_total[5m])) / sum(rate(router_requests_total[5m])) * 100",
            "legendFormat": "降级率"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "服务使用分布",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum by (service_id) (router_requests_total)",
            "legendFormat": "{{service_id}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "路由决策置信度分布",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum(count(router_decision_confidence_bucket) by (le))",
            "legendFormat": "{{le}}"
          }
        ]
      },
      {
        "id": 7,
        "title": "错误率",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(router_errors_total[5m])) / sum(rate(router_requests_total[5m])) * 100",
            "legendFormat": "错误率"
          }
        ]
      },
      {
        "id": 8,
        "title": "流量分配",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "sum(router_requests_total{router=\"new\"}) / sum(router_requests_total) * 100",
            "legendFormat": "新路由流量占比"
          }
        ]
      }
    ]
  }
}
