# 生产环境配置
# Production Environment Configuration
# Athena工作平台
# PostgreSQL 17.7 本地部署

# ========== 应用配置 ==========
APP_NAME=Athena工作平台
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.0.0

# ========== 服务端口 ==========
API_PORT=8000
API_HOST=0.0.0.0
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ========== PostgreSQL 17.7 配置 ==========
POSTGRES_VERSION=17.7
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DBNAME=athena_production

# 数据库连接池
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ========== Redis配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ========== Qdrant向量数据库 ==========
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=athena_vectors

# ========== Neo4j图数据库 ==========
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=athena

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=athena.log
LOG_ROTATION=100MB
LOG_RETENTION=30

# ========== 监控配置 ==========
ENABLE_METRICS=true
ENABLE_TRACING=false
METRICS_PORT=9090

# Prometheus
PROMETHEUS_RETENTION=15d
PROMETHEUS_STORAGE_SIZE=10GB

# ========== AI模型配置 ==========
# LLM提供商: zhipu, openai, anthropic, etc.
LLM_PROVIDER=zhipu
LLM_MODEL=glm-4-plus
LLM_API_KEY=your_api_key_here
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# Embedding模型
EMBEDDING_MODEL=bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024

# ========== 安全配置 ==========
SECRET_KEY=your_secret_key_change_this_in_production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT配置
JWT_SECRET_KEY=your_jwt_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# ========== 性能配置 ==========
# 并发配置
MAX_WORKERS=4
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=300

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# ========== 存储配置 ==========
# 向量存储
VECTOR_STORE=qdrant
VECTOR_DIMENSION=1024
VECTOR_INDEX_TYPE=HNSW

# 文件存储
STORAGE_TYPE=local
STORAGE_PATH=/var/lib/athena/storage
MAX_FILE_SIZE=100MB

# ========== 任务配置 ==========
# 异步任务
TASK_QUEUE=redis
TASK_RESULT_TTL=86400
TASK_MAX_RETRIES=3

# 定时任务
SCHEDULER_ENABLED=true
SCHEDULER_HEARTBEAT=60

# ========== Agent配置 ==========
AGENT_ENABLED=true
AGENT_TIMEOUT=300
AGENT_MAX_STEPS=50

# ========== MCP服务器配置 ==========
MCP_SERVER_ENABLED=true
MCP_SERVER_TIMEOUT=30

# 学术搜索MCP
ACADEMIC_SEARCH_MCP_URL=http://localhost:3001
PATENT_SEARCH_MCP_URL=http://localhost:3002

# ========== 专利数据配置 ==========
PATENT_DATA_SOURCE=local
PATENT_DATA_PATH=/var/lib/athena/data/patents
PATENT_CACHE_ENABLED=true
PATENT_CACHE_TTL=7200

# ========== 反馈系统配置 ==========
FEEDBACK_ENABLED=true
FEEDBACK_STORAGE_PATH=/var/lib/athena/data/feedback
FEEDBACK_AUTO_SAVE=true

# ========== 规划系统配置 ==========
PLANNER_TYPE=unified
PLANNER_CACHE_ENABLED=true
PLANNER_MAX_PARALLEL=5

# ========== 备份配置 ==========
BACKUP_ENABLED=true
BACKUP_PATH=/Volumes/AthenaData/Athena工作平台备份/backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"

# ========== 健康检查配置 ==========
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# ========== 限流配置 ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# ========== 邮件通知配置 ==========
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=athena@example.com
EMAIL_TO=admin@example.com

# ========== Slack通知配置 ==========
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts
SLACK_USERNAME=Athena Bot
