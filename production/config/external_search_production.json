{
  "production_settings": {
    "timeout": 30,
    "retry_count": 3,
    "enable_fallback": true,
    "max_concurrent_requests": 10,
    "cache_enabled": true,
    "cache_ttl": 3600
  },
  "engine_priorities": [
    {
      "engine": "tavily",
      "priority": 1,
      "weight": 0.4
    },
    {
      "engine": "metaso",
      "priority": 2,
      "weight": 0.35
    },
    {
      "engine": "bocha",
      "priority": 3,
      "weight": 0.25
    }
  ],
  "load_balancing": {
    "strategy": "weighted_round_robin",
    "health_check_interval": 60,
    "failure_threshold": 3
  },
  "monitoring": {
    "enabled": true,
    "metrics_collection": true,
    "health_check_endpoint": "/health",
    "metrics_endpoint": "/metrics"
  }
}