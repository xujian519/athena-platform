# API Key配置模板
# 请复制此文件为 .env 并填入实际的API Key

# [必需]
# 智谱清言 GLM-4.6
# 智谱清言大模型服务，提供GLM-4.6等模型
# 注册地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_api_key_here

# [可选]
# 百度文心一言
# 百度文心一言大模型服务
# 注册地址: https://aip.baidubce.com/
BAIDU_API_KEY=your_api_key_here

# [可选]
# 阿里通义千问
# 阿里云通义千问大模型服务
# 注册地址: https://dashscope.aliyuncs.com/
DASHSCOPE_API_KEY=your_api_key_here

# [可选]
# 科大讯飞星火
# 科大讯飞星火认知大模型
# 注册地址: https://xinghuo.xfyun.cn/
SPARK_API_KEY=your_api_key_here

# [可选]
# OpenAI GPT
# OpenAI GPT系列模型
# 注册地址: https://platform.openai.com/
OPENAI_API_KEY=your_api_key_here

# [可选]
# Anthropic Claude
# Anthropic Claude系列模型
# 注册地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# [可选]
# Google Gemini
# Google Gemini多模态模型
# 注册地址: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# [可选]
# ScrapingBee
# ScrapingBee网页爬虫服务
# 注册地址: https://www.scrapingbee.com/
SCRAPINGBEE_API_KEY=your_api_key_here

# [可选]
# Qwen API
# 阿里通义千问API服务
# 注册地址: https://dashscope.aliyuncs.com/
QWEN_API_KEY=your_api_key_here

