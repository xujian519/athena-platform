# ========================================
# Athena工作平台 - 测试环境配置
# Testing Environment
# ========================================

# 环境标识
ATHENA_ENV=testing
DEBUG=false
LOG_LEVEL=INFO
TEST_MODE=true

# 测试数据库
DATABASE_URL=sqlite:///data/athena_test.db

# 测试配置
DISABLE_AUTH=true
MOCK_EXTERNAL_SERVICES=true
