{
  "enable_reflection": true,
  "enable_collaboration": true,
  "enable_learning": true,
  "reflection_threshold": 0.90,
  "collaboration_threshold": 0.60,
  "learning_threshold": 0.80,
  "auto_refine": true,
  "auto_collaborate": true,

  "embedding_optimization": {
    "cache_enabled": true,
    "cache_size": 1000,
    "cache_ttl": 3600,
    "batch_embedding": true,
    "embedding_threshold": 0.90,
    "reuse_similarity_threshold": 0.92
  },

  "llm_optimization": {
    "use_local_cache": true,
    "response_cache_size": 500,
    "similar_query_threshold": 0.85,
    "max_tokens": 2000,
    "temperature": 0.7,
    "context_window": 4000
  },

  "smart_thresholds": {
    "reflection_auto_skip": 0.92,
    "collaboration_min_score": 0.65,
    "learning_min_impact": 4,
    "auto_refine_min_score": 0.75
  },

  "performance_optimization": {
    "parallel_processing": true,
    "max_concurrent_tasks": 5,
    "batch_size": 10,
    "timeout_seconds": 300,
    "enable_monitoring": true
  },

  "collaboration_config": {
    "expert_selection_strategy": "best_match",
    "notification_timeout": 600,
    "auto_assignment": true,
    "fallback_to_auto": true
  },

  "learning_config": {
    "knowledge_retention_days": 180,
    "pattern_min_occurrences": 3,
    "learning_frequency": "adaptive",
    "auto_cleanup": true,
    "export_learning_data": false
  },

  "logging_config": {
    "level": "INFO",
    "enable_performance_logging": true,
    "log_learning_events": true,
    "max_log_size_mb": 100
  }
}