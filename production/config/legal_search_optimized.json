{
  "legal_search_optimization": {
    "version": "1.0.0",
    "created_at": "2025-12-20T14:26:28",
    "description": "法律搜索系统优化配置",

    "search_engine_config": {
      "hybrid_search": {
        "enabled": true,
        "weights": {
          "vector_search": 0.6,
          "graph_reasoning": 0.3,
          "keyword_search": 0.1
        },
        "parallel_execution": true
      },

      "intelligent_routing": {
        "enabled": true,
        "routing_rules": [
          {
            "keywords": ["合同", "协议", "约定"],
            "target_collection": "legal_clauses_contract",
            "priority": "high"
          },
          {
            "keywords": ["专利", "商标", "知识产权"],
            "target_collection": "legal_clauses_ip",
            "priority": "high"
          },
          {
            "keywords": ["公司", "股东", "股权"],
            "target_collection": "legal_clauses_corporate",
            "priority": "high"
          },
          {
            "keywords": ["侵权", "责任", "赔偿"],
            "target_collection": "legal_clauses_tort",
            "priority": "medium"
          }
        ]
      }
    },

    "cache_strategy": {
      "multi_level_cache": {
        "l1_cache": {
          "type": "memory_cache",
          "size": "100MB",
          "ttl": 1800,
          "cache_keys": ["hot_legal_queries"]
        },
        "l2_cache": {
          "type": "redis",
          "size": "500MB",
          "ttl": 3600,
          "cache_keys": ["frequent_patterns"]
        },
        "l3_cache": {
          "type": "disk",
          "size": "2GB",
          "ttl": 7200,
          "cache_keys": ["complex_queries"]
        }
      }
    },

    "performance_targets": {
      "query_response_time": {
        "simple_query": "<100ms",
        "complex_query": "<300ms",
        "hybrid_query": "<500ms"
      },
      "throughput": {
        "concurrent_queries": 50,
        "queries_per_second": 100
      },
      "accuracy": {
        "relevance_score": ">0.8",
        "precision": ">0.85",
        "recall": ">0.80"
      }
    },

    "monitoring": {
      "metrics": [
        "query_response_time",
        "cache_hit_rate",
        "vector_search_accuracy",
        "graph_reasoning_time"
      ],
      "alerts": {
        "slow_query_threshold": "500ms",
        "cache_hit_rate_min": "70%",
        "error_rate_max": "5%"
      }
    },

    "scaling_strategy": {
      "horizontal_scaling": {
        "qdrant_replicas": 3,
        "load_balancing": "round_robin"
      },
      "vertical_scaling": {
        "memory_allocation": "4GB",
        "cpu_cores": 4,
        "storage_iops": "high"
      }
    }
  }
}