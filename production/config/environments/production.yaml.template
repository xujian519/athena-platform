# Athena工作平台生产环境配置模板
# 注意：这是模板文件，实际配置应使用环境变量或密钥管理工具

# 数据库配置
database:
  postgres:
    host: ${POSTGRES_HOST:localhost}
    port: ${POSTGRES_PORT:5432}
    database: ${POSTGRES_DB:athena_platform}
    username: ${POSTGRES_USER:athena}
    password: ${POSTGRES_PASSWORD}  # 从环境变量读取

  redis:
    host: ${REDIS_HOST:localhost}
    port: ${REDIS_PORT:6379}
    password: ${REDIS_PASSWORD}    # 从环境变量读取
    db: ${REDIS_DB:0}

  qdrant:
    host: ${QDRANT_HOST:localhost}
    port: ${QDRANT_PORT:6333}
    api_key: ${QDRANT_API_KEY}

  neo4j:
    uri: ${NEO4J_URI:bolt://localhost:7687}
    username: ${NEO4J_USERNAME:neo4j}
    password: ${NEO4J_PASSWORD}  # 从环境变量读取

  elasticsearch:
    host: ${ES_HOST:localhost}
    port: ${ES_PORT:9200}
    username: ${ES_USERNAME:elastic}
    password: ${ES_PASSWORD}  # 从环境变量读取

# 安全配置
security:
  jwt:
    secret_key: ${JWT_SECRET}        # 从环境变量读取
    algorithm: HS256
    expire_minutes: 720  # 12小时

  oauth:
    secret_key: ${OAUTH_SECRET}      # 从环境变量读取

  encryption:
    key: ${ENCRYPTION_KEY}         # 从环境变量读取

# API服务配置
api_services:
  firecrawl:
    api_key: ${FIRECRAWL_API_KEY}

  deepseek:
    api_key: ${DEEPSEEK_API_KEY}

  qwen:
    api_key: ${QWEN_API_KEY}

  jina:
    api_key: ${JINA_API_KEY}

  serper:
    api_key: ${SERPER_API_KEY}

  tavily:
    api_key: ${TAVILY_API_KEY}
    dev_key: ${TAVILY_DEV_KEY}

  bocha:
    api_key: ${BOCHA_API_KEY}

  metaso:
    api_key: ${METASO_API_KEY}

  scrapingbee:
    api_key: ${SCRAPINGBEE_API_KEY}

# 邮件配置
email:
  smtp_server: ${SMTP_SERVER}
  smtp_port: ${SMTP_PORT:587}
  username: ${EMAIL_USERNAME}
  password: ${EMAIL_PASSWORD}
  from_email: ${EMAIL_FROM}

# 消息队列配置
message_queue:
  rabbitmq:
    host: ${MQ_HOST:localhost}
    port: ${MQ_PORT:5672}
    username: ${MQ_USERNAME}
    password: ${MQ_PASSWORD}

# 监控配置
monitoring:
  grafana:
    username: ${GRAFANA_USERNAME:admin}
    password: ${GRAFANA_PASSWORD}  # 从环境变量读取

# 日志配置
logging:
  level: ${LOG_LEVEL:INFO}
  format: json

# 应用配置
app:
  name: athena-platform
  version: 2.0.0
  environment: production
  debug: false
  workers: ${WORKERS:4}

  # 安全设置
  cors_origins: ${CORS_ORIGINS}
  allow_origins: ${ALLOW_ORIGINS:false}

  # 性能设置
  max_connections: ${MAX_CONNECTIONS:1000}
  connection_timeout: ${CONNECTION_TIMEOUT:30}
  request_timeout: ${REQUEST_TIMEOUT:60}

  # 文件上传
  max_file_size: ${MAX_FILE_SIZE:10485760}  # 10MB
  upload_path: ${UPLOAD_PATH:/opt/athena/uploads}