{
  "api_gateway": {
    "name": "Athena Platform API Gateway",
    "version": "2.0.0",
    "description": "平台级API网关配置 - 集成混合爬虫服务",
    "owner": "Athena & 小诺"
  },
  "routes": [
    {
      "name": "混合爬虫API",
      "path": "/api/v2/crawler",
      "service": "platform-hybrid-crawler",
      "methods": ["GET", "POST", "PUT", "DELETE"],
      "strip_prefix": false,
      "load_balancing": {
        "enabled": false,
        "algorithm": "round_robin"
      },
      "rate_limiting": {
        "enabled": true,
        "requests_per_minute": 1000,
        "burst_size": 100
      },
      "authentication": {
        "enabled": false,
        "type": "none"
      },
      "cors": {
        "enabled": true,
        "origins": ["*"],
        "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
        "headers": ["*"],
        "credentials": false
      },
      "timeout": {
        "connect": 30,
        "read": 120,
        "write": 60
      },
      "retries": {
        "enabled": true,
        "max_attempts": 3,
        "backoff": "exponential"
      }
    }
  ],
  "services": [
    {
      "name": "platform-hybrid-crawler",
      "protocol": "http",
      "host": "localhost",
      "port": 8300,
      "health_check": {
        "enabled": true,
        "path": "/health",
        "interval": 30,
        "timeout": 10,
        "unhealthy_threshold": 3,
        "healthy_threshold": 2
      },
      "discovery": {
        "enabled": false,
        "type": "static"
      }
    }
  ],
  "middleware": {
    "request_logging": {
      "enabled": true,
      "format": "json",
      "include_body": false,
        "max_body_size": 1024
    },
    "response_logging": {
      "enabled": true,
      "format": "json",
      "include_body": false,
      "max_body_size": 1024
    },
    "metrics": {
      "enabled": true,
      "prometheus": {
        "enabled": true,
        "path": "/metrics",
        "port": 9001
      },
      "custom": {
        "enabled": true,
        "prefix": "athena_crawler"
      }
    },
    "tracing": {
      "enabled": true,
      "jaeger": {
        "enabled": false,
        "endpoint": "http://localhost:14268/api/traces"
      },
      "zipkin": {
        "enabled": false,
        "endpoint": "http://localhost:9411/api/v2/spans"
      }
    }
  },
  "security": {
    "waf": {
      "enabled": false,
      "rules": []
    },
    "ip_whitelist": {
      "enabled": false,
      "ips": []
    },
    "ip_blacklist": {
      "enabled": true,
      "ips": [
        "0.0.0.0/32"
      ]
    },
    "request_size_limit": {
      "enabled": true,
      "max_size": "10MB"
    },
    "response_size_limit": {
      "enabled": false,
      "max_size": "100MB"
    }
  },
  "monitoring": {
    "alerting": {
      "enabled": true,
      "channels": [
        {
          "type": "webhook",
          "name": "default",
          "url": "${ALERT_WEBHOOK_URL}",
          "enabled": false
        }
      ],
      "rules": [
        {
          "name": "high_error_rate",
          "condition": "error_rate > 0.1",
          "duration": "5m",
          "severity": "warning",
          "enabled": true
        },
        {
          "name": "service_down",
          "condition": "service_status != 1",
          "duration": "1m",
          "severity": "critical",
          "enabled": true
        },
        {
          "name": "high_response_time",
          "condition": "avg_response_time > 5s",
          "duration": "10m",
          "severity": "warning",
          "enabled": true
        }
      ]
    }
  },
  "caching": {
    "enabled": true,
    "redis": {
      "enabled": false,
      "host": "localhost",
      "port": 6379,
      "db": 0,
      "ttl": 300
    },
    "memory": {
      "enabled": true,
      "max_size": "100MB",
      "ttl": 60
    }
  },
  "compression": {
    "enabled": true,
    "algorithms": ["gzip", "br"],
    "min_size": 1024
  },
  "documentation": {
    "openapi": {
      "enabled": true,
      "path": "/api/docs",
      "version": "3.0.0",
      "title": "Athena Platform Crawler API",
      "description": "平台级混合爬虫API文档 - 由Athena和小诺控制"
    }
  }
}