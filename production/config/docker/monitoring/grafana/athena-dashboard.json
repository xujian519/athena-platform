{
  "dashboard": {
    "title": "Athena平台监控",
    "tags": ["athena", "production"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "服务健康状态",
        "type": "stat",
        "targets": [
          {
            "expr": "up",
            "refId": "A",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        }
      },
      {
        "id": 2,
        "title": "容器资源使用",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total[1m])",
            "refId": "A",
            "legendFormat": "{{container}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Redis命中率",
        "type": "gauge",
        "targets": [
          {
            "expr": "redis_keyspace_hits / (redis_keyspace_hits + redis_keyspace_misses) * 100",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 4,
        "title": "Qdrant请求速率",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(qdrant_requests_total[1m])",
            "refId": "A",
            "legendFormat": "请求/秒"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 8}
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  }
}
