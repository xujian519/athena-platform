# Athena工作平台 - Docker Compose环境变量配置
# Environment Variables for Docker Compose
#
# 复制此文件为 .env 并填写实际值

# ==================== 数据库配置 ====================
# PostgreSQL配置（注意：使用本地PostgreSQL 17.7，容器通过host.docker.internal访问）
DB_PASSWORD=athena123

# Redis配置
REDIS_PASSWORD=redis123

# ==================== 安全配置 ====================
# JWT密钥（用于身份认证）
JWT_SECRET=your-secret-key-change-this-in-production

# ==================== API密钥 ====================
# Semantic Scholar API密钥（用于学术论文搜索）
# 获取地址：https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# Jina AI API密钥（用于向量嵌入和重排序）
# 获取地址：https://cloud.jina.ai/
JINA_API_KEY=

# 高德地图API密钥（用于地图服务）
# 获取地址：https://console.amap.com/dev/key/app
GAODE_API_KEY=

# GitHub Token（用于GitHub集成）
# 获取地址：https://github.com/settings/tokens
GITHUB_TOKEN=

# ==================== 监控配置 ====================
# Grafana管理员账号
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_ROOT_URL=http://localhost:3000

# ==================== 应用配置 ====================
# 日志级别
LOG_LEVEL=INFO

# 启用编排器
ENABLE_ORCHESTRATOR=true

# ==================== 资源限制 ====================
# CPU限制（可选，默认在各docker-compose文件中配置）
# CPU_LIMIT=4.0
# CPU_RESERVATION=2.0

# 内存限制（可选，默认在各docker-compose文件中配置）
# MEMORY_LIMIT=8G
# MEMORY_RESERVATION=4G

# ==================== 网络配置 ====================
# 如果需要自定义网络子网，取消以下注释
# NETWORK_SUBNET_INFRASTRUCTURE=172.20.0.0/16
# NETWORK_SUBNET_CORE_SERVICES=172.21.0.0/16
# NETWORK_SUBNET_MCP_SERVERS=172.22.0.0/16
# NETWORK_SUBNET_APPLICATIONS=172.23.0.0/16
# NETWORK_SUBNET_MONITORING=172.24.0.0/16

# ==================== 端口配置 ====================
# 如果需要自定义端口，取消以下注释并修改
# 注意：修改端口可能影响服务间的通信
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# QDRANT_HTTP_PORT=6333
# QDRANT_GRPC_PORT=6334
# API_GATEWAY_PORT=8080
# XIAONUO_GATEWAY_PORT=8100
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000

# ==================== 开发模式配置 ====================
# 开发模式（启用调试日志、热重载等）
# DEVELOPMENT_MODE=false

# ==================== 备份配置 ====================
# 数据备份目录
BACKUP_DIR=/Users/xujian/Athena工作平台/backups

# 定时备份cron表达式（默认每天凌晨2点）
BACKUP_CRON=0 2 * * *

# 备份保留天数
BACKUP_RETENTION_DAYS=7
