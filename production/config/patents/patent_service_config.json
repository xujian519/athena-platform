{
    "patent_search": {
        "service_name": "Athena专利检索服务",
        "version": "1.0.0",
        "max_concurrent_searches": 3,
        "default_max_results": 20,
        "cache_enabled": true,
        "cache_ttl": 1800,
        "default_timeout": 30,
        "retry_attempts": 2
    },
    "data_sources": {
        "google_patents": {
            "enabled": true,
            "base_url": "https://patents.google.com",
            "rate_limit": {
                "requests_per_minute": 30,
                "delay_between_requests": 2.0
            }
        }
    },
    "analytics": {
        "enabled": true,
        "auto_analyze": true,
        "export_formats": ["json", "csv", "excel"],
        "visualization_charts": true
    }
}
