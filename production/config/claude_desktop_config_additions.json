// ============================================
// MCP 服务器配置更新
// ============================================
//
// 使用方法：
// 1. 备份当前配置: cp ~/.claude/claude_desktop_config.json ~/.claude/claude_desktop_config.json.backup
// 2. 手动编辑 ~/.claude/claude_desktop_config.json
// 3. 将以下配置添加到 "mcpServers" 对象中
//
// 或者使用命令直接添加:
// cat claude_desktop_config_additions.json

{
  "mcpServers": {
    // ========== 未注册的 MCP 服务器 ==========
    // 以下服务器需要添加到您的 Claude Desktop 配置中

    "chrome": {
      "command": "node",
      "args": ["/Users/xujian/Athena工作平台/mcp-servers/chrome-mcp-server/src/index.js"],
      "cwd": "/Users/xujian/Athena工作平台/mcp-servers/chrome-mcp-server",
      "env": {
        "CHROME_HEADLESS": "true"
      },
      "description": "Chrome 浏览器自动化 - 需要 Puppeteer"
    },

    "google-patents": {
      "command": "node",
      "args": ["/Users/xujian/Athena工作平台/mcp-servers/google-patents-meta-server/index.js"],
      "cwd": "/Users/xujian/Athena工作平台/mcp-servers/google-patents-meta-server",
      "description": "Google Patents 元数据检索 - 专利检索"
    },

    "patent-pdf-downloader": {
      "command": "node",
      "args": ["/Users/xujian/Athena工作平台/mcp-servers/patent-downloader-mcp-server/server.js"],
      "cwd": "/Users/xujian/Athena工作平台/mcp-servers/patent-downloader-mcp-server",
      "description": "专利 PDF 下载器 - 从 Google Patents 下载专利文档"
    },

    "gaode": {
      "command": "python3",
      "args": ["/Users/xujian/Athena工作平台/mcp-servers/gaode-mcp-server/run_server.py"],
      "cwd": "/Users/xujian/Athena工作平台/mcp-servers/gaode-mcp-server",
      "env": {
        "AMAP_API_KEY": "your_amap_api_key_here",
        "AMAP_SECRET_KEY": "your_amap_secret_key_here"
      },
      "description": "高德地图服务 - 地理位置和地图服务"
    }
  }
}
