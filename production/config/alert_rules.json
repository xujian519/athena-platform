[
  {
    "name": "database_connection_failure",
    "title": "数据库连接失败",
    "description": "无法连接到PostgreSQL数据库",
    "severity": "critical",
    "component": "database",
    "condition": "database.status == 'error'",
    "enabled": true
  },
  {
    "name": "qdrant_service_down",
    "title": "Qdrant服务不可用",
    "description": "Qdrant向量数据库服务无法访问",
    "severity": "error",
    "component": "qdrant",
    "condition": "qdrant.status == 'error'",
    "enabled": true
  },
  {
    "name": "api_response_slow",
    "title": "API响应缓慢",
    "description": "API服务响应时间超过阈值",
    "severity": "warning",
    "component": "api",
    "condition": "api.response_time_ms > 500",
    "enabled": true
  },
  {
    "name": "high_cpu_usage",
    "title": "CPU使用率过高",
    "description": "系统CPU使用率超过80%",
    "severity": "warning",
    "component": "system",
    "condition": "system.cpu_usage > 80",
    "enabled": true
  },
  {
    "name": "high_memory_usage",
    "title": "内存使用率过高",
    "description": "系统内存使用率超过85%",
    "severity": "error",
    "component": "system",
    "condition": "system.memory_usage > 85",
    "enabled": true
  },
  {
    "name": "disk_space_low",
    "title": "磁盘空间不足",
    "description": "磁盘使用率超过90%",
    "severity": "critical",
    "component": "system",
    "condition": "system.disk_usage > 90",
    "enabled": true
  },
  {
    "name": "backup_failure",
    "title": "备份任务失败",
    "description": "自动备份任务执行失败",
    "severity": "error",
    "component": "backup",
    "condition": "backup.status == 'failed'",
    "enabled": true
  },
  {
    "name": "docker_container_down",
    "title": "Docker容器异常",
    "description": "关键Docker容器未运行",
    "severity": "warning",
    "component": "docker",
    "condition": "docker.unhealthy_containers > 0",
    "enabled": true
  }
]