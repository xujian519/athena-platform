# ========================================
# 专利全文处理系统 - 环境配置
# Patent Full Text Processing System
# ========================================
# 继承平台基础配置 (config/unified/.env.base)
# 仅定义专利系统专用配置
# ========================================

# =============================================================================
# 环境标识
# =============================================================================
PATENT_ENV=production
PATENT_VERSION=3.0.0

# =============================================================================
# 专利系统专用路径
# =============================================================================
# 继承 ATHENA_HOME=/Users/xujian/Athena工作平台

# PDF存储路径
PATENT_PDF_PATH=${ATHENA_HOME}/patents/PDF
PATENT_CHECKPOINT_PATH=${ATHENA_HOME}/patents/checkpoints
PATENT_LOG_PATH=${ATHENA_HOME}/patents/logs

# 模型路径（继承平台MODEL_PATH）
PATENT_MODEL_PATH=${MODEL_PATH}/patent
PATENT_EMBEDDING_MODEL=${PATENT_MODEL_PATH}/bge-base-zh-v1.5
PATENT_SEQUENCE_TAGGER=${PATENT_MODEL_PATH}/chinese_legal_electra

# =============================================================================
# Qdrant向量数据库配置
# =============================================================================
# 继承平台基础配置 QDRANT_HOST, QDRANT_PORT
QDRANT_COLLECTION_NAME=patent_full_text_v2
QDRANT_VECTOR_SIZE=768
QDRANT_DISTANCE=Cosine
QDRANT_SHARD_NUM=4
QDRANT_REPLICA_NUM=1

# =============================================================================
# NebulaGraph图数据库配置
# =============================================================================
NEBULA_SPACE_NAME=patent_full_text_v2
NEBULA_USERNAME=root
NEBULA_PASSWORD=nebula
NEBULA_POOL_SIZE=10
NEBULA_TIMEOUT=30

# =============================================================================
# 专利处理配置
# =============================================================================
# 向量化配置
PATENT_ENABLE_LAYER1=true
PATENT_ENABLE_LAYER2=true
PATENT_ENABLE_LAYER3=true
PATENT_ENABLE_PER_CLAIM_VECTOR=true
PATENT_ENABLE_STRUCTURED_CHUNKING=true
PATENT_MAX_CLAIMS=50
PATENT_CHUNK_MAX_SIZE=500
PATENT_CHUNK_OVERLAP=50
PATENT_MAX_CHUNKS=20

# 三元组提取配置
PATENT_TRIPLE_STRATEGY=hybrid
PATENT_TRIPLE_ENABLE_RULES=true
PATENT_TRIPLE_RULE_CONFIDENCE=0.6
PATENT_TRIPLE_ENABLE_MODEL=false
PATENT_TRIPLE_MODEL_CONFIDENCE=0.7
PATENT_TRIPLE_ENABLE_CLOUD_LLM=false

# 知识图谱配置
PATENT_KG_AUTO_SAVE=false
PATENT_KG_BATCH_INSERT=true
PATENT_KG_BATCH_SIZE=100

# =============================================================================
# 性能优化配置
# =============================================================================
# 批处理
PATENT_BATCH_SIZE=10
PATENT_MAX_WORKERS=4
PATENT_USE_THREADING=true

# 重试机制
PATENT_MAX_RETRIES=3
PATENT_BACKOFF_FACTOR=2.0
PATENT_RETRY_TIMEOUT=300

# 超时配置
PATENT_REQUEST_TIMEOUT=60
PATENT_PROCESSING_TIMEOUT=300

# =============================================================================
# 缓存配置
# =============================================================================
# 继承平台 REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
PATENT_ENABLE_CACHE=true
PATENT_ENABLE_REDIS_CACHE=true
PATENT_CACHE_LEVEL=both
PATENT_CACHE_TTL=3600
PATENT_MEMORY_CACHE_MAX_SIZE=10000

# =============================================================================
# 日志配置
# =============================================================================
PATENT_LOG_LEVEL=INFO
PATENT_LOG_FORMAT=json
PATENT_LOG_FILE=${PATENT_LOG_PATH}/patent_processing.log
PATENT_LOG_MAX_BYTES=10485760
PATENT_LOG_BACKUP_COUNT=5

# 结构化日志
PATENT_ENABLE_JSON_LOG=true
PATENT_JSON_LOG_FILE=${PATENT_LOG_PATH}/patent_processing.jsonl

# =============================================================================
# 监控配置
# =============================================================================
PATENT_ENABLE_PERFORMANCE_MONITORING=true
PATENT_METRICS_RETENTION=86400
PATENT_ENABLE_HEALTH_CHECK=true
PATENT_HEALTH_CHECK_INTERVAL=30
PATENT_ENABLE_ALERTS=false
PATENT_ALERT_THRESHOLD=0.95

# =============================================================================
# API服务配置
# =============================================================================
PATENT_API_HOST=0.0.0.0
PATENT_API_PORT=8000
PATENT_API_WORKERS=4
PATENT_API_RELOAD=false
PATENT_API_LOG_LEVEL=info

# 限流配置
PATENT_ENABLE_RATE_LIMIT=true
PATENT_RATE_LIMIT=100
PATENT_REQUEST_TIMEOUT=300
PATENT_KEEPALIVE_TIMEOUT=65

# =============================================================================
# PDF监控服务配置
# =============================================================================
PATENT_MONITOR_ENABLED=true
PATENT_MONITOR_WATCH_DIR=${PATENT_PDF_PATH}
PATENT_MONITOR_CHECK_INTERVAL=5.0
PATENT_MONITOR_RECURSIVE=true
PATENT_MONITOR_AUTO_PROCESS=true

# =============================================================================
# 集成下载器配置
# =============================================================================
PATENT_DOWNLOADER_OUTPUT_DIR=${PATENT_PDF_PATH}
PATENT_DOWNLOADER_CHECKPOINT_FILE=${PATENT_CHECKPOINT_PATH}/download_mapping.json
PATENT_DOWNLOADER_MAX_RETRIES=3
PATENT_DOWNLOADER_TIMEOUT=30
PATENT_DOWNLOADER_DELAY=1.0

# =============================================================================
# 云端LLM配置（可选）
# =============================================================================
PATENT_CLOUD_LLM_PROVIDER=qwen
PATENT_CLOUD_LLM_API_KEY=
PATENT_CLOUD_LLM_BASE_URL=
