# ========================================
# 专利全文处理系统 - 测试环境配置
# Testing Environment
# ========================================

# 环境标识
PATENT_ENV=testing
DEBUG=true
PATENT_LOG_LEVEL=DEBUG
TEST_MODE=true

# 测试数据库
QDRANT_COLLECTION_NAME=patent_full_text_test
NEBULA_SPACE_NAME=patent_full_text_test

# 禁用非必要功能
PATENT_KG_AUTO_SAVE=false
PATENT_MONITOR_ENABLED=false
PATENT_ENABLE_ALERTS=false
