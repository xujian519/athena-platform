# ========================================
# 专利全文处理系统 - 开发环境配置
# Development Environment
# ========================================

# 环境标识
PATENT_ENV=development
DEBUG=true
PATENT_LOG_LEVEL=DEBUG

# 开发数据库
QDRANT_HOST=localhost
NEBULA_HOST=127.0.0.1

# 禁用生产功能
PATENT_KG_AUTO_SAVE=false
PATENT_MONITOR_ENABLED=false

# 开发优化
PATENT_BATCH_SIZE=5
PATENT_MAX_WORKERS=2
