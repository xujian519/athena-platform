# 生产环境配置模板
# Production Environment Configuration Template
# 复制此文件为 .env 并填写实际配置值
# Copy this file to .env and fill in actual configuration values

# ===========================
# 数据库配置 / Database Configuration
# ===========================

# PostgreSQL配置 (使用本地Homebrew安装的PostgreSQL 17.7)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=xujian
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# ⚠️ NebulaGraph已废弃 - 系统已迁移到 PostgreSQL + Qdrant 架构
# 以下配置已不再使用，仅为向后兼容保留
# NEBULA_HOST=localhost
# NEBULA_PORT=9669
# NEBULA_USER=root
# NEBULA_PASSWORD=nebula
# NEBULA_SPACE=athena_graph

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================
# 服务端口 / Service Ports
# ===========================

# API服务端口
API_PORT=8080
API_HOST=0.0.0.0

# NLP服务端口
NLP_SERVICE_PORT=8000
NLP_SERVICE_HOST=localhost

# 小诺服务端口（默认17能力版本）
XIAONUO_PORT=8017
XIAONUO_HOST=0.0.0.0

# ===========================
# 外部服务URL / External Service URLs
# ===========================

# Elasticsearch配置
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Qdrant向量数据库
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ===========================
# 安全配置 / Security Configuration
# ===========================

# JWT密钥 (生产环境必须修改)
JWT_SECRET_KEY=your_jwt_secret_key_change_in_production

# 加密密钥
ENCRYPTION_KEY=your_encryption_key_change_in_production

# API密钥 (如果需要)
API_KEY=your_api_key_if_needed

# ===========================
# 日志配置 / Logging Configuration
# ===========================

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=/var/log/athena/production.log

# ===========================
# 其他配置 / Other Configuration
# ===========================

# 环境名称
ENVIRONMENT=production

# 时区
TIMEZONE=Asia/Shanghai

# 最大工作进程数
MAX_WORKERS=4

# 请求超时时间(秒)
REQUEST_TIMEOUT=30
