{
  "patent_triple_property_analysis": {
    "metadata": {
      "version": "1.0",
      "created_date": "2025-12-12",
      "description": "专利三性（新颖性、创造性、实用性）分析和技术比对模板",
      "application_scenarios": [
        "专利申请前的新创性评估",
        "专利审查中的三性判断",
        "专利无效宣告请求",
        "专利侵权诉讼中的现有技术抗辩",
        "技术自由实施(FTO)分析",
        "专利布局和技术研发规划"
      ]
    },

    "novelty_analysis_template": {
      "name": "新颖性分析模板",
      "description": "基于专利法第22条的新颖性判断标准",
      "legal_basis": "专利法第22条第2款：新颖性，是指该发明或者实用新型不属于现有技术",

      "structure": {
        "target_analysis": {
          "patent_info": {
            "patent_number": "专利号",
            "application_date": "申请日",
            "title": "专利标题",
            "abstract": "专利摘要",
            "independent_claims": {
              "type": "array",
              "description": "独立权利要求列表"
            }
          },
          "technical_features": {
            "extracted_features": {
              "type": "array",
              "description": "提取的技术特征"
            },
            "essential_features": {
              "type": "array",
              "description": "必要技术特征"
            },
            "distinguishing_features": {
              "type": "array",
              "description": "区别特征"
            }
          }
        },

        "prior_art_analysis": {
          "search_results": {
            "patent_literature": {
              "type": "array",
              "description": "对比专利文献",
              "items": {
                "document_number": "文献编号",
                "publication_date": "公开日期",
                "title": "标题",
                "abstract": "摘要",
                "relevance_score": "相关度评分(0-1)",
                "overlapping_features": "重叠技术特征列表"
              }
            },
            "non_patent_literature": {
              "type": "array",
              "description": "非专利文献",
              "items": {
                "document_type": "文献类型(期刊/会议/标准等)",
                "title": "标题",
                "authors": "作者",
                "publication_date": "发表日期",
                "relevance_score": "相关度评分",
                "technical_disclosure": "技术披露内容"
              }
            },
            "public_use": {
              "type": "array",
              "description": "公开使用证据",
              "items": {
                "use_date": "使用日期",
                "use_location": "使用地点",
                "disclosure_content": "披露内容",
                "evidence_type": "证据类型"
              }
            }
          }
        },

        "novelty_comparison": {
          "feature_by_feature_analysis": {
            "type": "array",
            "description": "逐特征对比分析",
            "items": {
              "target_feature": {
                "feature_id": "特征ID",
                "description": "特征描述",
                "feature_type": "结构/功能/参数/位置等"
              },
              "prior_art_disclosure": {
                "document_reference": "对比文献",
                "disclosure_text": "披露内容",
                "similarity_assessment": "相似度评估"
              },
              "comparison_result": {
                "identical": "是否完全相同",
                "equivalent": "是否等同",
                "differences": "差异点",
                "conclusion": "该特征的新颖性结论"
              }
            }
          },

          "overall_assessment": {
            "complete_disclosure_found": {
              "found": "是否发现完整技术方案披露",
              "reference_documents": "披露文献列表",
              "disclosure_completeness": "披露完整度(%)"
            },
            "partial_disclosure_analysis": {
              "missing_essential_features": "未披露的必要技术特征",
              "distinguishing_features": "区别于现有技术的特征",
              "innovation_points": "创新点"
            },
            "novelty_conclusion": {
              "is_novel": "是否具备新颖性",
              "confidence_level": "判断置信度(高/中/低)",
              "reasoning": "判断理由",
              "risk_assessment": "风险评估"
            }
          }
        },

        "novelty_defense_strategies": {
          "if_lacking_novelty": {
            "amend_claims": "修改权利要求建议",
            "argue_distinctions": "区别点论证策略",
            "challenge_prior_art": "挑战对比文献"
          },
          "if_having_novelty": {
            "emphasize_innovations": "强调创新点",
            "document_differences": "文档化差异",
            "strengthen_claims": "强化权利要求保护范围"
          }
        }
      }
    },

