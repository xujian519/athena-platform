    "recognition_strategies": {
      "rule_based": {
        "enabled": true,
        "priority": 1,
        "description": "基于正则表达式的规则匹配",
        "advantages": [
          "快速准确",
          "不需要训练数据",
          "容易理解和修改"
        ],
        "limitations": [
          "需要手工维护规则",
          "难以处理新实体",
          "对上下文理解有限"
        ]
      },

      "statistical_ml": {
        "enabled": false,
        "priority": 2,
        "models": ["CRF", "HMM", "SVM"],
        "description": "基于统计机器学习的识别",
        "advantages": [
          "可以从数据中学习",
          "处理一定的上下文",
          "相对较好的泛化能力"
        ],
        "limitations": [
          "需要大量标注数据",
          "特征工程复杂",
          "难以捕捉长距离依赖"
        ]
      },

      "deep_learning": {
        "enabled": true,
        "priority": 3,
        "models": ["BERT", "RoBERTa", "ChatGLM"],
        "description": "基于深度学习的识别",
        "advantages": [
          "自动特征学习",
          "强大的上下文理解",
          "端到端训练"
        ],
        "limitations": [
          "需要大量计算资源",
          "训练时间长",
          "黑盒模型"
        ]
      },

      "llm_based": {
        "enabled": true,
        "priority": 4,
        "models": ["ChatGPT", "Claude", "ChatGLM", "LLaMA"],
        "description": "基于大语言模型的识别",
        "advantages": [
          "强大的语言理解",
          "零样本或少样本学习",
          "可解释性好"
        ],
        "limitations": [
          "推理速度慢",
          "成本高",
          "API依赖"
        ]
      }
    },

    "fusion_strategy": {
      "method": "weighted_voting",
      "weights": {
        "rule_based": 0.3,
        "statistical_ml": 0.2,
        "deep_learning": 0.3,
        "llm_based": 0.2
      },
      "confidence_threshold": 0.6,
      "conflict_resolution": "highest_confidence"
    },

    "evaluation_metrics": {
      "precision": "精确率",
      "recall": "召回率",
      "f1_score": "F1分数",
      "accuracy": "准确率"
    },

    "optimization_targets": {
      "precision": "> 0.90",
      "recall": "> 0.85",
      "f1_score": "> 0.87",
      "inference_time": "< 500ms per claim"
    },

    "training_data": {
      "annotated_patents": "专利标注数据集路径",
      "validation_split": 0.2,
      "test_split": 0.1,
      "data_augmentation": true
    },

    "infrastructure/infrastructure/deployment": {
      "batch_size": 32,
      "max_sequence_length": 512,
      "model_cache": true,
      "api_endpoint": "/api/v1/entity-recognition"
    }
  }
