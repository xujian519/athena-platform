# Athena Gateway Nginx 反向代理配置
# 用于在Nginx后部署Gateway，提供TLS、负载均衡等功能

# 上游服务器配置
upstream athena_gateway {
    # Gateway服务器列表
    server 127.0.0.1:8005 max_fails=3 fail_timeout=30s;
    # 如果有多个Gateway实例，添加更多server行
    # server 127.0.0.1:8006 max_fails=3 fail_timeout=30s;

    # 负载均衡策略（默认轮询）
    # least_conn;  # 最少连接
    # ip_hash;     # IP哈希
}

# HTTP重定向到HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name gateway.example.com;  # 替换为你的域名

    # 健康检查端点
    location /health {
        proxy_pass http://athena_gateway;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 其他请求重定向到HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS服务器配置
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name gateway.example.com;  # 替换为你的域名

    # SSL证书配置
    ssl_certificate /etc/nginx/ssl/gateway.crt;        # 证书路径
    ssl_certificate_key /etc/nginx/ssl/gateway.key;      # 私钥路径

    # SSL优化配置
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    # 现代SSL协议
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;

    # HSTS (HTTP Strict Transport Security)
    add_header Strict-Transport-Security "max-age=63072000" always;

    # OCSP Stapling
    ssl_stapling on;
    ssl_stapling_verify on;

    # 日志配置
    access_log /var/log/nginx/gateway-access.log;
    error_log /var/log/nginx/gateway-error.log;

    # 客户端请求大小限制
    client_max_body_size 100M;

    # 代理超时配置
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # 代理到Gateway
    location / {
        proxy_pass http://athena_gateway;

        # 传递原始请求信息
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # WebSocket支持
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 超时配置
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Prometheus指标端点（如果启用）
    location /metrics {
        proxy_pass http://athena_gateway;
        proxy_set_header Host $host;

        # 限制访问（可选：只允许特定IP）
        # allow 127.0.0.1;
        # allow 10.0.0.0/8;
        # deny all;
    }

    # 健康检查端点（不记录日志）
    location /health {
        proxy_pass http://athena_gateway;
        access_log off;
    }
}
